                background: #01579b;
            }

    body.dark-mode .top-bar {
        background: #1e293b;
        border-color: #334155;
    }

    body.dark-mode .greeting {
        color: #e2e8f0;
    }

    body.dark-mode .date-badge {
        background: #0f172a;
        border-color: #334155;
        color: #94a3b8;
    }

    body.dark-mode .date-range {
        background: #0f172a;
        border-color: #334155;
    }

    body.dark-mode .date-field input {
        background: transparent;
        color: #e2e8f0;
    }

    body.dark-mode .quick-filters {
        background: #0f172a;
        border-color: #334155;
    }

    body.dark-mode .filter-btn {
        color: #94a3b8;
    }

        body.dark-mode .filter-btn:hover {
            background: #334155;
            color: #4fc3f7;
        }

    /* Stats row - balanced cards */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-bottom: 16px;
    }

    .stat-card {
