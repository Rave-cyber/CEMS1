</style>

<div class="dash-wrapper">
    <div class="container-fluid px-2">

        <!-- TOP BAR -->
        <div class="top-bar">
            <div class="welcome-section">
                <div class="greeting">
                    Welcome back, <strong>@(ViewBag.UserFullName ?? User.Identity?.Name ?? "Driver")</strong>
                </div>
            </div>

            <div class="filter-section">
                <div class="filter-group">
                    <label>From</label>
                    <input type="date" id="metricsStart" value="@DateTime.UtcNow.AddMonths(-1).ToString("yyyy-MM-dd")">
                </div>
                <div class="filter-group">
                    <label>To</label>
                    <input type="date" id="metricsEnd" value="@DateTime.UtcNow.ToString("yyyy-MM-dd")">
                </div>
                <div class="quick-filters">
                    <button class="filter-btn" data-range="today">Today</button>
                    <button class="filter-btn" data-range="week">Week</button>
                    <button class="filter-btn active" data-range="month">Month</button>
                    <button class="filter-btn" data-range="year">Year</button>
                </div>
            </div>
        </div>

        <!-- Stats row -->
        <div class="stats-row">
            <a href="@Url.Action("MyReports", "Driver")" class="stat-card">
                <div class="stat-icon blue"><i class="bi bi-hourglass-split"></i></div>
                <div class="stat-content">
                    <div class="stat-label">PENDING</div>
                    <div class="stat-number"><span id="pendingCount">—</span></div>
                    <div class="stat-sub">awaiting review</div>
                </div>
            </a>
            <a href="@Url.Action("History", "Driver")" class="stat-card">
                <div class="stat-icon green"><i class="bi bi-check-circle"></i></div>
                <div class="stat-content">
                    <div class="stat-label">APPROVED (MTD)</div>
                    <div class="stat-number">₱<span id="approvedThisMonthTotal">0</span></div>
                    <div class="stat-sub">this month</div>
                </div>
            </a>
            <a href="@Url.Action("History", "Driver")" class="stat-card">
                <div class="stat-icon green"><i class="bi bi-wallet2"></i></div>
                <div class="stat-content">
                    <div class="stat-label">REIMBURSED</div>
                    <div class="stat-number">₱<span id="reimbursedTotal">0</span></div>
                    <div class="stat-sub">total paid</div>
                </div>
            </a>
            <a href="@Url.Action("History", "Driver")" class="stat-card">
                <div class="stat-icon red"><i class="bi bi-arrow-repeat"></i></div>
                <div class="stat-content">
                    <div class="stat-label">REJECTED</div>
                    <div class="stat-number"><span id="rejectedCount">—</span></div>
                    <div class="stat-sub">need revision</div>
                </div>
            </a>
        </div>

        <!-- Side by side: Chart + Budgets - WHITE SPACE FIXED -->
        <div class="dashboard-grid">
            <!-- Chart - NO WHITE SPACE -->
            <div class="chart-card">
                <div class="chart-header">
                    <i class="bi bi-bar-chart-fill"></i> Budget vs Actual
                </div>
                <div class="chart-container">
                    <canvas id="driverBudgetChart"></canvas>
                </div>
            </div>

            <!-- Budget list - DYNAMIC -->
            <div class="budget-card">
                <div class="budget-header">
                    <i class="bi bi-pie-chart-fill"></i> Category Budgets
                </div>
                <div class="budget-list" id="dynamicBudgetList">
                    <div style="color:#94a3b8; text-align:center; padding:16px;">Loading budget data...</div>
                </div>
            </div>
        </div>

        <!-- Recent reports -->
        @if (recentReports.Any())
        {
            <div class="table-card">
                <div class="table-header">
                    <span><i class="bi bi-file-text me-1" style="color:#0288d1;"></i> Recent Reports</span>
                </div>
                <div class="scroll-table">
                    <table class="compact-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Date</th>
                                <th class="text-right">Amount</th>
                                <th>Status</th>
                                <th>Budget</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in recentReports.Take(4))
                            {
                                <tr>
                                    <td>#@r.Id</td>
                                    <td>@r.SubmissionDate.ToLocalTime().ToString("MM/dd")</td>
                                    <td class="text-right">₱@r.TotalAmount.ToString("N0")</td>
                                    <td>@(r.Status == CEMS.Models.ReportStatus.PendingCEOApproval ? "CEO" : r.Status.ToString())</td>
                                    <td class="@(r.BudgetCheck == CEMS.Models.BudgetCheckStatus.OverBudget ? "text-danger" : "text-success")">
                                        @(r.BudgetCheck == CEMS.Models.BudgetCheckStatus.OverBudget ? "Over" : "OK")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Recent expense items -->
        <div class="table-card">
            <div class="table-header">
                <span><i class="bi bi-receipt me-1" style="color:#0288d1;"></i> Recent Transactions</span>
            </div>
            <div class="scroll-table">
                <table class="compact-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Category</th>
                            <th class="text-right">Amount</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Budget</th>
                        </tr>
                    </thead>
                    <tbody id="recentItems">
                        <!-- populated by JS -->
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

@await Html.PartialAsync("_SubmitExpenseModal", new CEMS.Models.Expense())

@if (TempData["Success"] != null)
{
    <div class="toast-mini" style="border-left:3px solid #2e7d32;">
        <i class="bi bi-check-circle-fill" style="color:#2e7d32;"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="toast-mini" style="border-left:3px solid #d32f2f;">
        <i class="bi bi-exclamation-triangle-fill" style="color:#d32f2f;"></i> @TempData["Error"]
    </div>
}