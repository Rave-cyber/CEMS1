        .dash-wrapper {
            padding: 10px;
        }

        .top-bar {
            flex-direction: column;
            padding: 10px 12px;
            gap: 10px;
            margin-bottom: 16px;
        }

        .welcome-section {
            width: 100%;
        }

        .greeting {
            font-size: 0.9rem;
        }

        .greeting strong {
            margin-left: 2px;
        }

        .filter-section {
            width: 100%;
            margin-left: 0;
            flex-direction: column;
            gap: 10px;
        }

        .filter-group {
            width: 100%;
            flex-direction: column;
            gap: 4px;
        }

        .filter-group label {
            font-size: 0.7rem;
        }

        .filter-group input {
            width: 100%;
            min-width: unset;
            padding: 8px 10px;
            font-size: 1rem;
        }

