@{
    ViewData["Title"] = "Driver Dashboard";
    Layout = "~/Views/Shared/_DriverLayout.cshtml";
    var budgets = ViewBag.Budgets as List<CEMS.Models.Budget> ?? new List<CEMS.Models.Budget>();
    decimal totalBudget = ViewBag.TotalBudget ?? 0m;
    decimal totalSpent = ViewBag.TotalSpent ?? 0m;
    decimal totalRemaining = ViewBag.TotalRemaining ?? 0m;
    var recentReports = ViewBag.RecentReports as List<CEMS.Models.ExpenseReport> ?? new List<CEMS.Models.ExpenseReport>();
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
let driverBudgetChart;

function renderDriverBudgetChart(budgets){
    const canvas = document.getElementById('driverBudgetChart');
    if(!canvas || !window.Chart){
        return;
    }

    const isDarkMode = document.body.classList.contains('dark-mode');
    const textColor = isDarkMode ? '#e8eef5' : '#0f1724';
    const gridColor = isDarkMode ? '#3a4452' : '#e9eef6';

    const labels = (budgets || []).map(b => b.category);
    const allocated = (budgets || []).map(b => b.allocated ?? 0);
    const spent = (budgets || []).map(b => b.spent ?? 0);

    if(driverBudgetChart){
        driverBudgetChart.destroy();
    }

    driverBudgetChart = new Chart(canvas, {
        type: 'bar',
        data: {
            labels,
            datasets: [
                {
                    label: 'Allocated',
                    data: allocated,
                    backgroundColor: 'rgba(26,107,181,0.2)',
                    borderColor: '#1a6bb5',
                    borderWidth: 1.5,
                    borderRadius: 4
                },
                {
                    label: 'Spent',
                    data: spent,
                    backgroundColor: 'rgba(239,68,68,0.2)',
                    borderColor: '#ef4444',
                    borderWidth: 1.5,
                    borderRadius: 4
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { 
                legend: { 
                    position: 'bottom',
                    labels: {
                        color: textColor,
                        font: { size: 12 }
                    }
                } 
            },
            scales: { 
                y: { 
                    beginAtZero: true,
                    ticks: { color: textColor },
                    grid: { color: gridColor }
                },
                x: {
                    ticks: { color: textColor },
                    grid: { color: gridColor }
                }
            }
        }
    });
}

function getDateFilters(){
    const start = document.getElementById('metricsStart')?.value;
    const end = document.getElementById('metricsEnd')?.value;
    const params = new URLSearchParams();
    if(start){ params.append('start', start); }
    if(end){ params.append('end', end); }
    const query = params.toString();
    return query ? `?${query}` : '';
}

async function loadDriverMetrics(){
    try{
        const res = await fetch('@Url.Action("Metrics","Driver")' + getDateFilters());
        if(!res.ok) throw new Error('Failed to load metrics');
        const data = await res.json();

        document.getElementById('pendingCount').textContent = data.pendingCount ?? 0;
        document.getElementById('rejectedCount').textContent = data.rejectedCount ?? 0;
        document.getElementById('approvedThisMonthTotal').textContent = (data.approvedThisMonthTotal ?? 0).toFixed(2);
        document.getElementById('reimbursedTotal').textContent = (data.reimbursedTotal ?? 0).toFixed(2);

        const tbody = document.getElementById('recentItems');
        tbody.innerHTML = '';
        for(const item of data.recent || []){
            const tr = document.createElement('tr');
            const isOver = item.budgetCheck === 'OverBudget';

            let statusClass = 'status-dot--default';
            let statusLabel = item.reportStatus;
            if(item.reportStatus === 'Submitted'){ statusClass = 'status-dot--pending'; }
            else if(item.reportStatus === 'Approved'){ statusClass = 'status-dot--approved'; }
            else if(item.reportStatus === 'Rejected'){ statusClass = 'status-dot--rejected'; }
            else if(item.reportStatus === 'PendingCEOApproval'){ statusClass = 'status-dot--pending'; statusLabel = 'Pending CEO'; }

            tr.innerHTML = `
                <td>${new Date(item.date).toLocaleDateString()}</td>
                <td><span class="category-chip">${item.category}</span></td>
                <td class="fw-semibold">₱${Number(item.amount).toFixed(2)}</td>
                <td class="text-muted">${item.description || '—'}</td>
                <td><span class="status-dot ${statusClass}"></span> ${statusLabel}</td>
                <td>${isOver ? '<span class="budget-flag budget-flag--over">Over</span>' : '<span class="budget-flag budget-flag--ok">OK</span>'}</td>
                <td>${item.receiptUrl ? `<a class="dash-link" target="_blank" href="${item.receiptUrl}">View</a>` : '<span class="text-muted">—</span>'}</td>
            `;
            tbody.appendChild(tr);
        }

        renderDriverBudgetChart(data.budgets || []);
    }catch(e){
        console.error(e);
    }
}

function toInputDate(d){
    return d.toISOString().slice(0, 10);
}

function setDefaultMonthFilter(){
    const now = new Date();
    const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
    const startEl = document.getElementById('metricsStart');
    const endEl   = document.getElementById('metricsEnd');
    if(startEl && !startEl.value) startEl.value = toInputDate(monthStart);
    if(endEl   && !endEl.value)   endEl.value   = toInputDate(now);
}

    document.addEventListener('DOMContentLoaded', ()=>{
    setDefaultMonthFilter();
    loadDriverMetrics();

    // auto reload when date inputs change
    document.getElementById('metricsStart')?.addEventListener('change', ()=> loadDriverMetrics());
    document.getElementById('metricsEnd')?.addEventListener('change', ()=> loadDriverMetrics());

    // Re-render chart on dark mode toggle
    document.addEventListener('darkModeToggled', () => {
        loadDriverMetrics();
    });

    // quick range buttons
    document.querySelectorAll('.quick-filter [data-range]').forEach(function(btn){
        btn.addEventListener('click', function(){
            var range = btn.getAttribute('data-range');
            var now = new Date();
            var start, end = now;
            if(range === 'today'){
                start = new Date(now.getFullYear(), now.getMonth(), now.getDate());
            } else if(range === 'week'){
                var day = now.getDay();
                start = new Date(now.getFullYear(), now.getMonth(), now.getDate() - day);
            } else if(range === 'month'){
                start = new Date(now.getFullYear(), now.getMonth(), 1);
            } else if(range === 'year'){
                start = new Date(now.getFullYear(), 0, 1);
            }
            var sEl = document.getElementById('metricsStart');
            var eEl = document.getElementById('metricsEnd');
            if(sEl && start) sEl.value = toInputDate(start);
            if(eEl) eEl.value = toInputDate(end);
            loadDriverMetrics();
        });
    });
});
</script>
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<style>
    :root {
        --d-primary: #1a6bb5; /* formal blue */
        --d-accent: #2ec4b6;  /* subtle accent */
        --d-bg: #f7fbfc;
        --d-card: #ffffff;
        --d-border: #e9eef6;
        --d-text: #0f1724;
        --d-muted: #6b7280;
        --d-radius: 8px;
        --d-radius-sm: 6px;
    }

    body.dark-mode {
        --d-bg: #1a1f2e;
        --d-card: #2d3748;
        --d-border: #3a4452;
        --d-text: #e8eef5;
        --d-muted: #a0aec0;
    }

    .dash-wrapper {
        background: var(--d-bg);
        min-height: calc(100vh - 80px);
        padding: 28px 0 40px;
        transition: background 0.3s ease;
    }

    /* ── Header ── */
    .dash-header {
        margin-bottom: 32px;
    }
    .dash-greeting {
        font-size: 1.65rem;
        font-weight: 700;
        color: var(--d-text);
        margin-bottom: 2px;
        transition: color 0.3s ease;
    }
    .dash-greeting span {
        color: var(--d-primary);
        font-weight:700;
    }
    .dash-date {
        color: var(--d-muted);
        font-size: .92rem;
        margin-top: 2px;
        transition: color 0.3s ease;
    }

    /* ── Stat Cards ── */
    .stat-card {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 10px;
        padding: 18px;
        display: flex;
        align-items: center;
        gap: 14px;
        transition: transform .12s ease, background 0.3s ease, border-color 0.3s ease;
        text-decoration: none !important;
        color: inherit !important;
    }
    .stat-card:hover { 
        transform: translateY(-2px);
    }
    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
        transition: background 0.3s ease, color 0.3s ease;
    }
    .stat-icon--pending  { background: rgba(26,107,181,.08);  color: #1a6bb5; }
    .stat-icon--approved { background: rgba(16,185,129,.08);  color: #10b981; }
    .stat-icon--money    { background: rgba(99,102,241,.08);  color: #6366f1; }
    .stat-icon--rejected { background: rgba(239,68,68,.08);   color: #ef4444; }

    body.dark-mode .stat-icon--pending  { background: rgba(46, 196, 182, .15); color: #5eead4; }
    body.dark-mode .stat-icon--approved { background: rgba(16, 185, 129, .15); color: #86efac; }
    body.dark-mode .stat-icon--money    { background: rgba(99, 102, 241, .15); color: #a5b4fc; }
    body.dark-mode .stat-icon--rejected { background: rgba(239, 68, 68, .15);  color: #fca5a5; }

    .stat-label {
        font-size: .76rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: var(--d-muted);
        margin-bottom: 4px;
        transition: color 0.3s ease;
    }
    .stat-value {
        font-size: 1.55rem;
        font-weight: 700;
        color: var(--d-text);
        line-height: 1.2;
        transition: color 0.3s ease;
    }
    .stat-sub {
        font-size: .8rem;
        color: var(--d-muted);
        margin-top: 2px;
        transition: color 0.3s ease;
    }

    /* ── Section Cards ── */
    .dash-card {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 20px;
        transition: background 0.3s ease, border-color 0.3s ease;
    }
    .dash-card-head {
        padding: 14px 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid var(--d-border);
        transition: border-color 0.3s ease;
    }
    .dash-card-title {
        font-size: .95rem;
        font-weight: 600;
        color: var(--d-text);
        display: flex;
        align-items: center;
        gap: 8px;
        transition: color 0.3s ease;
    }
    .dash-card-title i { color: var(--d-primary); font-size:1rem; }
    .dash-card-body { padding: 16px 18px; }
    .dash-link {
        color: var(--d-primary);
        text-decoration: none;
        font-weight: 500;
        font-size: .88rem;
        transition: color .2s;
    }
    .dash-link:hover {
        color: #155a9a;
    }

    /* Action Button (consistent with History/MyReports) */
    .view-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        background: rgba(26, 107, 181, .12);
        color: #fff;
        border: 1px solid rgba(26, 107, 181, .12);
        border-radius: var(--d-radius-sm);
        font-size: .85rem;
        font-weight: 500;
        text-decoration: none;
        transition: all .2s;
    }

    .view-btn:hover { background: #1a6bb5; color: #fff; }

    /* approve button style (green) */
    .approve-btn {
        background: #10b981;
        color: #fff;
        border: none;
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
    }
    .approve-btn:hover { filter: brightness(.95); }

    /* ── Budget Progress ── */
    .budget-item {
        padding: 14px 0;
    }
    .budget-item + .budget-item {
        border-top: 1px solid var(--d-border);
        transition: border-color 0.3s ease;
    }
    .budget-label {
        font-weight: 600;
        color: var(--d-text);
        font-size: .9rem;
        transition: color 0.3s ease;
    }
    .budget-remain {
        font-size: .8rem;
        font-weight: 500;
    }
    .budget-remain--ok   { color: #0d8b7d; }
    .budget-remain--over { color: #dc2626; }

    body.dark-mode .budget-remain--ok   { color: #5eead4; }
    body.dark-mode .budget-remain--over { color: #fca5a5; }

    .budget-bar { height: 6px; border-radius: 3px; background: #f1f5f9; margin-top: 8px; overflow: hidden; transition: background 0.3s ease; }
    .budget-bar-fill { height: 100%; border-radius: 3px; }
    .budget-bar-fill--ok     { background: var(--d-primary); }
    .budget-bar-fill--warn   { background: #f59e0b; }
    .budget-bar-fill--danger { background: #ef4444; }

    body.dark-mode .budget-bar { background: #374151; }

    .budget-amounts {
        font-size: .76rem;
        color: var(--d-muted);
        margin-top: 4px;
        transition: color 0.3s ease;
    }

    /* ── Tables ── */
    .dash-table {
        width: 100%;
        margin-bottom: 0;
    }
    .dash-table thead th {
        background: #f8fafc;
        color: var(--d-muted);
        font-weight: 600;
        font-size: .76rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        padding: 11px 16px;
        border: none;
        transition: background 0.3s ease, color 0.3s ease;
    }

    body.dark-mode .dash-table thead th {
        background: #374151;
        color: var(--d-muted);
    }

    .dash-table tbody td {
        padding: 13px 16px;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
        color: var(--d-text);
        font-size: .88rem;
        transition: color 0.3s ease, border-color 0.3s ease;
    }

    body.dark-mode .dash-table tbody td {
        border-bottom-color: #4b5563;
    }

    .dash-table tbody tr:last-child td {
        border-bottom: none;
    }
    .dash-table tbody tr:hover {
        background: #f8fafc;
        transition: background 0.2s ease;
    }

    body.dark-mode .dash-table tbody tr:hover {
        background: #374151;
    }

    /* ── Status Dots ── */
    .status-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-right: 6px;
        vertical-align: middle;
    }
    .status-dot--pending  { background: #f59e0b; }
    .status-dot--approved { background: #10b981; }
    .status-dot--rejected { background: #ef4444; }
    .status-dot--ceo      { background: #6366f1; }
    .status-dot--default  { background: #94a3b8; }

    /* ── Category Chip ── */
    .category-chip {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 6px;
        background: rgba(46,196,182,.1);
        color: #0d8b7d;
        font-size: .82rem;
        font-weight: 500;
        transition: background 0.3s ease, color 0.3s ease;
    }

    body.dark-mode .category-chip {
        background: rgba(46, 196, 182, .2);
        color: #5eead4;
    }

    /* ── Budget Flag ── */
    .budget-flag {
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
    }
    .budget-flag--over { color: #ef4444; }
    .budget-flag--ok   { color: #10b981; }

    /* ── Toast ── */
    .dash-toast {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 1055;
        padding: 14px 22px;
        border-radius: var(--d-radius-sm);
        font-size: .9rem;
        font-weight: 500;
        box-shadow: 0 8px 24px rgba(0,0,0,.12);
        animation: slideUp .4s ease;
        transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
    }
    .dash-toast--success {
        background: #ecfdf5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }

    body.dark-mode .dash-toast--success {
        background: rgba(16, 185, 129, .15);
        color: #86efac;
        border: 1px solid rgba(16, 185, 129, .3);
    }

    .dash-toast--error {
        background: #fef2f2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    body.dark-mode .dash-toast--error {
        background: rgba(239, 68, 68, .15);
        color: #fca5a5;
        border: 1px solid rgba(239, 68, 68, .3);
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 768px) {
        .dash-wrapper { padding: 20px 0 32px; }
    }

    .chart-wrap {
        height: 260px;
    }
    .chart-wrap canvas {
        width: 100% !important;
        height: 100% !important;
    }

    .filter-card {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 10px;
        padding: 12px 16px;
        margin-bottom: 16px;
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        gap: 10px 14px;
        transition: background 0.3s ease, border-color 0.3s ease;
    }
    .filter-card label {
        font-size: .8rem;
        font-weight: 600;
        color: var(--d-muted);
        margin-bottom: 3px;
        transition: color 0.3s ease;
    }
    .filter-card input {
        border: 1px solid var(--d-border);
        border-radius: 6px;
        padding: 5px 8px;
        font-size: .85rem;
        color: var(--d-text);
        background: var(--d-card);
        transition: border-color 0.3s ease, background 0.3s ease, color 0.3s ease;
    }

    .filter-card input:focus {
        outline: none;
        border-color: var(--d-primary);
        background: var(--d-card);
    }

    .filter-actions .btn {
        font-size: .84rem;
        font-weight: 600;
        border-radius: 6px;
        padding: 5px 12px;
    }

    .quick-filter {
        display: inline-flex;
        gap: 6px;
        align-items: center;
    }
    .quick-filter .btn {
        padding: 5px 8px;
        font-size: .82rem;
        border-radius: 6px;
        transition: all 0.2s ease;
    }

    /* Fix text-muted for dark mode */
    .text-muted {
        color: var(--d-muted) !important;
    }
</style>

<div class="dash-wrapper">
    <div class="container-fluid px-4">

        <!-- ── Header ── -->
        <div class="dash-header d-flex justify-content-between align-items-end flex-wrap gap-2">
            <div>
                <h1 class="dash-greeting">Welcome back, <span>@User.Identity?.Name</span></h1>
                <p class="dash-date mb-0">
                    <i class="bi bi-calendar3 me-1"></i>
                    @DateTime.Now.ToString("dddd, MMMM d yyyy")
                </p>
            </div>
           @*  <a href="@Url.Action("Expenses", "Driver")" class="btn px-4 py-2 text-white" style="background:var(--d-gradient);border:none;border-radius:var(--d-radius-sm);font-weight:600;">
                <i class="bi bi-plus-lg me-1"></i> New Expense
            </a> *@
        </div>

        <!-- Filter Card -->
        <div style="background: var(--d-card); border: 1px solid var(--d-border); border-radius: 10px; padding: 12px 14px; margin-bottom: 20px;">
            <div style="display: flex; gap: 8px; align-items: flex-end; flex-wrap: wrap; justify-content: space-between;">
                <div style="display: flex; gap: 8px; align-items: flex-end; flex-wrap: wrap;">
                    <div style="flex: 1; min-width: 160px;">
                        <label for="metricsStart" class="form-label" style="margin-bottom: 4px; font-size: 0.85rem; font-weight: 600; color: var(--d-muted);">From</label>
                        <input type="date" id="metricsStart" style="padding: 8px 10px; border: 1px solid var(--d-border); border-radius: 6px; font-size: 0.9rem; width: 100%;" />
                    </div>
                    <div style="flex: 1; min-width: 160px;">
                        <label for="metricsEnd" class="form-label" style="margin-bottom: 4px; font-size: 0.85rem; font-weight: 600; color: var(--d-muted);">To</label>
                        <input type="date" id="metricsEnd" style="padding: 8px 10px; border: 1px solid var(--d-border); border-radius: 6px; font-size: 0.9rem; width: 100%;" />
                    </div>
                </div>
                <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-range="today" style="padding: 6px 12px; border: 1px solid var(--d-border); background: var(--d-card); color: var(--d-text); border-radius: 6px; font-size: 0.85rem; font-weight: 600; cursor: pointer;">Today</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-range="week" style="padding: 6px 12px; border: 1px solid var(--d-border); background: var(--d-card); color: var(--d-text); border-radius: 6px; font-size: 0.85rem; font-weight: 600; cursor: pointer;">Week</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-range="month" style="padding: 6px 12px; border: 1px solid var(--d-border); background: var(--d-card); color: var(--d-text); border-radius: 6px; font-size: 0.85rem; font-weight: 600; cursor: pointer;">Month</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-range="year" style="padding: 6px 12px; border: 1px solid var(--d-border); background: var(--d-card); color: var(--d-text); border-radius: 6px; font-size: 0.85rem; font-weight: 600; cursor: pointer;">Year</button>
                </div>
            </div>
        </div>

        <!-- ── Stats Row ── -->
        <div class="row g-3 mb-4">
            <div class="col-xl-3 col-sm-6">
                <a href="@Url.Action("MyReports", "Driver")" class="stat-card">
                    <div class="stat-icon stat-icon--pending">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                    <div>
                        <div class="stat-label">Pending</div>
                        <div class="stat-value"><span id="pendingCount">—</span></div>
                        <div class="stat-sub">Expense requests</div>
                    </div>
                </a>
            </div>
            <div class="col-xl-3 col-sm-6">
                <a href="@Url.Action("History", "Driver")" class="stat-card">
                    <div class="stat-icon stat-icon--approved">
                        <i class="bi bi-check2-circle"></i>
                    </div>
                    <div>
                        <div class="stat-label">Approved</div>
                        <div class="stat-value">₱<span id="approvedThisMonthTotal">0.00</span></div>
                        <div class="stat-sub">This month</div>
                    </div>
                </a>
            </div>
            <div class="col-xl-3 col-sm-6">
                <a href="@Url.Action("History", "Driver")" class="stat-card">
                    <div class="stat-icon stat-icon--money">
                        <i class="bi bi-wallet2"></i>
                    </div>
                    <div>
                        <div class="stat-label">Reimbursed</div>
                        <div class="stat-value">₱<span id="reimbursedTotal">0.00</span></div>
                        <div class="stat-sub">Total reimbursed</div>
                    </div>
                </a>
            </div>
            <div class="col-xl-3 col-sm-6">
                <a href="@Url.Action("History", "Driver")" class="stat-card">
                    <div class="stat-icon stat-icon--rejected">
                        <i class="bi bi-arrow-repeat"></i>
                    </div>
                    <div>
                        <div class="stat-label">Rejected</div>
                        <div class="stat-value"><span id="rejectedCount">—</span></div>
                        <div class="stat-sub">Need revision</div>
                    </div>
                </a>
            </div>
        </div>

        <div class="dash-card">
            <div class="dash-card-head">
                <div class="dash-card-title"><i class="bi bi-bar-chart"></i> Budget by Category</div>
            </div>
            <div class="dash-card-body">
                <div class="chart-wrap">
                    <canvas id="driverBudgetChart"></canvas>
                </div>
            </div>
        </div>

        <!-- ── Budget Limits ── -->
        @if (budgets.Any())
        {
            <div class="dash-card">
                <div class="dash-card-head">
                    <div class="dash-card-title"><i class="bi bi-pie-chart"></i> Category Usage</div>
                </div>
                <div class="dash-card-body">
                    <p class="text-muted mb-3" style="font-size:.85rem;">Budgets set by management. Expenses exceeding limits are flagged automatically.</p>
                    <div class="row">
                        @foreach (var b in budgets)
                        {
                            var remaining = b.Allocated - b.Spent;
                            var pct = b.Allocated == 0 ? 0 : (int)Math.Round((double)(b.Spent / b.Allocated * 100));
                            var isOver = remaining < 0;
                            <div class="col-lg-4 col-md-6">
                                <div class="budget-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="budget-label">@b.Category</span>
                                        <span class="budget-remain @(isOver ? "budget-remain--over" : "budget-remain--ok")">
                                            @(isOver ? $"Over by ₱{Math.Abs(remaining):N2}" : $"₱{remaining:N2} left")
                                        </span>
                                    </div>
                                    <div class="budget-bar">
                                        <div class="budget-bar-fill @(pct >= 100 ? "budget-bar-fill--danger" : pct >= 75 ? "budget-bar-fill--warn" : "budget-bar-fill--ok")"
                                             style="width:@Math.Min(pct, 100)%"></div>
                                    </div>
                                    <div class="budget-amounts">₱@b.Spent.ToString("N2") / ₱@b.Allocated.ToString("N2")</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- ── Recent Reports ── -->
        @if (recentReports.Any())
        {
            <div class="dash-card">
                <div class="dash-card-head">
                    <div class="dash-card-title"><i class="bi bi-file-earmark-bar-graph"></i> Recent Reports</div>
                    <a href="@Url.Action("MyReports", "Driver")" class="dash-link">View all <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="dash-card-body p-0">
                    <div class="table-responsive">
                        <table class="dash-table">
                            <thead>
                                <tr>
                                    <th>Report</th>
                                    <th>Submitted</th>
                                    <th>Total</th>
                                    <th>Status</th>
                                    <th>Budget</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in recentReports)
                                {
                                    var statusClass = r.Status switch
                                    {
                                        CEMS.Models.ReportStatus.Submitted => "status-dot--pending",
                                        CEMS.Models.ReportStatus.Approved => "status-dot--approved",
                                        CEMS.Models.ReportStatus.Rejected => "status-dot--rejected",
                                        CEMS.Models.ReportStatus.PendingCEOApproval => "status-dot--ceo",
                                        _ => "status-dot--default"
                                    };
                                    var statusLabel = r.Status switch
                                    {
                                        CEMS.Models.ReportStatus.PendingCEOApproval => "Pending CEO",
                                        _ => r.Status.ToString()
                                    };
                                    <tr>
                <td class="fw-semibold">#@r.Id</td>
                                        <td>@r.SubmissionDate.ToLocalTime().ToString("MMM d, yyyy")</td>
                                        <td class="fw-semibold">₱@r.TotalAmount.ToString("N2")</td>
                <td>@statusLabel</td>
                                        <td>
                                            @if (r.BudgetCheck == CEMS.Models.BudgetCheckStatus.OverBudget)
                                            {
                                                <span class="budget-flag budget-flag--over">Over budget</span>
                                            }
                                            else
                                            {
                                                <span class="budget-flag budget-flag--ok">Within budget</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- ── Recent Expense Items ── -->
        <div class="dash-card">
            <div class="dash-card-head">
                <div class="dash-card-title"><i class="bi bi-receipt-cutoff"></i> Recent Expense Items</div>
            </div>
            <div class="dash-card-body p-0">
                <div class="table-responsive">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Category</th>
                                <th>Amount</th>
                                <th>Description</th>
                                <th>Status</th>
                                <th>Budget</th>
                                <th>Receipt</th>
                            </tr>
                        </thead>
                        <tbody id="recentItems">
                            <!-- populated by JS -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

@* Render submit modal *@
@await Html.PartialAsync("_SubmitExpenseModal", new CEMS.Models.Expense())

@* TempData alerts *@
@if (TempData["Success"] != null)
{
    <div class="dash-toast dash-toast--success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="dash-toast dash-toast--error">@TempData["Error"]</div>
}
