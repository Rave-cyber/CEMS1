@{
    ViewData["Title"] = "Driver Dashboard";
    Layout = "~/Views/Shared/_DriverLayout.cshtml";
    var recentReports = ViewBag.RecentReports as List<CEMS.Models.ExpenseReport> ?? new List<CEMS.Models.ExpenseReport>();
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        let driverBudgetChart;

        function renderDriverBudgetChart(budgets){
            const canvas = document.getElementById('driverBudgetChart');
            if(!canvas || !window.Chart) return;

            const isDarkMode = document.body.classList.contains('dark-mode');
            const textColor = isDarkMode ? '#e2e8f0' : '#1e293b';
            const gridColor = isDarkMode ? '#334155' : '#e2e8f0';

            const labels = (budgets || []).map(b => b.category);
            const allocated = (budgets || []).map(b => b.allocated ?? 0);
            const spent = (budgets || []).map(b => b.spent ?? 0);

            if(driverBudgetChart) driverBudgetChart.destroy();

            driverBudgetChart = new Chart(canvas, {
                type: 'bar',
                data: {
                    labels,
                    datasets: [
                        {
                            label: 'Budget',
                            data: allocated,
                            backgroundColor: 'rgba(2, 136, 209, 0.7)',
                            borderColor: '#0288d1',
                            borderWidth: 1,
                            borderRadius: 4
                        },
                        {
                            label: 'Spent',
                            data: spent,
                            backgroundColor: 'rgba(46, 125, 50, 0.7)',
                            borderColor: '#2e7d32',
                            borderWidth: 1,
                            borderRadius: 4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    layout: {
                        padding: {
                            top: 0,
                            bottom: 0,
                            left: 0,
                            right: 0
                        }
                    },
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top',
                            align: 'end',
                            labels: {
                                boxWidth: 10,
                                boxHeight: 10,
                                font: { size: 9 }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: gridColor, drawBorder: false },
                            ticks: { color: textColor, font: { size: 9 } }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: textColor, font: { size: 9 } }
                        }
                    }
                }
            });
        }

        function getDateFilters(){
            const start = document.getElementById('metricsStart')?.value;
            const end = document.getElementById('metricsEnd')?.value;
            const params = new URLSearchParams();
            if(start) params.append('start', start);
            if(end) params.append('end', end);
            return params.toString() ? `?${params}` : '';
        }

        async function loadDriverMetrics(){
            try{
                const res = await fetch('@Url.Action("Metrics", "Driver")' + getDateFilters());
                if(!res.ok) throw new Error('Failed to load metrics');
                const data = await res.json();

                document.getElementById('pendingCount').textContent = data.pendingCount ?? 0;
                document.getElementById('rejectedCount').textContent = data.rejectedCount ?? 0;
                document.getElementById('approvedThisMonthTotal').textContent = (data.approvedThisMonthTotal ?? 0).toFixed(2);
                document.getElementById('reimbursedTotal').textContent = (data.reimbursedTotal ?? 0).toFixed(2);

                const tbody = document.getElementById('recentItems');
                tbody.innerHTML = '';
                for(const item of data.recent || []){
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td>${new Date(item.date).toLocaleDateString()}</td>
                        <td>${item.category}</td>
                        <td class="text-right">₱${Number(item.amount).toFixed(2)}</td>
                        <td>${item.description?.substring(0, 15) || '—'}</td>
                        <td>${item.reportStatus}</td>
                        <td class="${item.budgetCheck === 'OverBudget' ? 'text-danger' : 'text-success'}">${item.budgetCheck === 'OverBudget' ? 'Over' : 'OK'}</td>
                    `;
                    tbody.appendChild(tr);
                }

                // ✅ DYNAMIC: Render budget list from API data
                const budgetListContainer = document.getElementById('dynamicBudgetList');
                budgetListContainer.innerHTML = '';
                if(data.budgets && data.budgets.length > 0){
                    for(const b of data.budgets){
                        const remaining = b.allocated - b.spent;
                        const pct = b.allocated === 0 ? 0 : Math.round((b.spent / b.allocated) * 100);
                        const statusClass = pct >= 100 ? 'danger' : pct >= 80 ? 'warning' : '';

                        const div = document.createElement('div');
                        div.className = 'budget-item';
                        div.innerHTML = `
                            <div class="budget-row">
                                <span class="budget-category">${b.category}</span>
                                <span class="budget-numbers">₱${Number(b.spent).toLocaleString('en-PH', {minimumFractionDigits: 0})} / ₱${Number(b.allocated).toLocaleString('en-PH', {minimumFractionDigits: 0})}</span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill ${statusClass}" style="width:${Math.min(pct, 100)}%"></div>
                            </div>
                            <div class="budget-remaining">
                                ${remaining >= 0 ? `₱${Number(remaining).toLocaleString('en-PH', {minimumFractionDigits: 0})} remaining` : `₱${Number(Math.abs(remaining)).toLocaleString('en-PH', {minimumFractionDigits: 0})} over`}
                            </div>
                        `;
                        budgetListContainer.appendChild(div);
                    }
                } else {
                    budgetListContainer.innerHTML = '<div style="color:#94a3b8; text-align:center; padding:16px;">No budget data</div>';
                }

                renderDriverBudgetChart(data.budgets || []);
            }catch(e){
                console.error(e);
            }
        }

        function toInputDate(d){
            return d.toISOString().slice(0, 10);
        }

        document.addEventListener('DOMContentLoaded', () => {
            const now = new Date();
            document.getElementById('metricsStart').value = toInputDate(new Date(now.getFullYear(), now.getMonth(), 1));
            document.getElementById('metricsEnd').value = toInputDate(now);

            loadDriverMetrics();

            document.getElementById('metricsStart').addEventListener('change', loadDriverMetrics);
            document.getElementById('metricsEnd').addEventListener('change', loadDriverMetrics);

            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.addEventListener('click', function(){
                    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');

                    const range = this.dataset.range;
                    const now = new Date();
                    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
                    let start = new Date();

                    if(range === 'today') start = new Date(today.getFullYear(), today.getMonth(), today.getDate());
                    else if(range === 'week') {
                        start = new Date(today);
                        start.setDate(today.getDate() - 6);
                    }
                    else if(range === 'month') start = new Date(now.getFullYear(), now.getMonth(), 1);
                    else if(range === 'year') start = new Date(now.getFullYear(), 0, 1);

                    document.getElementById('metricsStart').value = toInputDate(start);
                    document.getElementById('metricsEnd').value = toInputDate(new Date());

                    loadDriverMetrics();
                });
            });
        });
    </script>
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<style>
    /* Balanced Compact Design - with subtle depth */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #f1f5f9;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

        body.dark-mode {
            background: #0f172a;
            color: #e2e8f0;
        }

    .dash-wrapper {
        padding: 16px;
    }

    /* TOP BAR STYLE */
    .top-bar {
        background: white;
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.03);
        border: 1px solid #f0f3f7;
    }

    .welcome-section {
        display: flex;
        align-items: center;
        gap: 0;
        flex-wrap: nowrap;
        min-width: auto;
    }

    .greeting {
        font-size: 1rem;
        color: #1e293b;
    }

        .greeting strong {
            color: #0288d1;
            font-weight: 600;
            margin-left: 4px;
        }

    .date-badge {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #f8fafc;
        padding: 5px 14px;
        border-radius: 30px;
        border: 1px solid #edf2f7;
        color: #475569;
        font-size: 0.9rem;
    }

        .date-badge i {
            color: #0288d1;
            font-size: 0.85rem;
        }

    .filter-section {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        margin-left: auto;
        flex-shrink: 1;
    }

    .filter-group {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

    .filter-group label {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        color: #64748b;
        letter-spacing: 0.3px;
        white-space: nowrap;
    }

    .filter-group input {
        padding: 6px 10px;
        border: 1px solid #e9eef2;
        border-radius: 6px;
        font-size: 0.9rem;
        color: #1e293b;
        background: white;
        width: auto;
        min-width: 120px;
    }

    .filter-group input:focus {
        outline: none;
        border-color: #0288d1;
        box-shadow: 0 0 0 3px rgba(2, 136, 209, 0.1);
    }

    body.dark-mode .filter-group input {
        background: #0f172a;
        border-color: #334155;
        color: #e2e8f0;
    }

    body.dark-mode .filter-group input:focus {
        border-color: #0288d1;
        box-shadow: 0 0 0 3px rgba(2, 136, 209, 0.2);
    }

    .date-range {
        display: flex;
        align-items: center;
        gap: 12px;
        background: #f8fafc;
        padding: 4px 12px;
        border-radius: 8px;
        border: 1px solid #edf2f7;
    }

    .date-field {
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .date-field span {
            font-size: 0.75rem;
            font-weight: 600;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .date-field input {
            width: 100px;
            padding: 5px 8px;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            font-size: 0.85rem;
            color: #1e293b;
            background: white;
            border: none;
            background: transparent;
            font-weight: 500;
        }

    .quick-filters {
        display: flex;
        align-items: center;
        gap: 2px;
        background: #f8fafc;
        padding: 4px;
        border-radius: 8px;
        border: 1px solid #edf2f7;
        flex-shrink: 0;
    }

    .filter-btn {
        padding: 6px 16px;
        border: none;
        background: transparent;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 500;
        color: #475569;
        cursor: pointer;
        transition: all 0.2s ease;
        white-space: nowrap;
        flex-shrink: 0;
    }

