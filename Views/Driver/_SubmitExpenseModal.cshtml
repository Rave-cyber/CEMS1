@model CEMS.Models.Expense
<div class="modal fade" id="submitExpenseModal" tabindex="-1" aria-labelledby="submitExpenseModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="submitExpenseModalLabel">New Expense</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="submitExpenseForm" asp-action="Submit" asp-controller="Driver" method="post" enctype="multipart/form-data">
          @Html.AntiForgeryToken()
          <div class="mb-2">
            <select asp-for="Category" class="form-select form-select-sm" aria-label="Category">
                <option value="">Category</option>
                <option>Fuel</option>
                <option>Toll</option>
                <option>Maintenance</option>
                <option>Meal</option>
            </select>
          </div>

          <div class="mb-2">
            <input asp-for="Amount" class="form-control form-control-sm" placeholder="Amount" />
          </div>

          <div class="mb-2">
            <input asp-for="Date" type="date" class="form-control form-control-sm" />
          </div>

          <div class="mb-2">
            <textarea asp-for="Description" class="form-control form-control-sm" placeholder="Description (optional)"></textarea>
          </div>

          <div class="mb-2">
            <input type="file" name="receipt" class="form-control form-control-sm" />
          </div>
        </form>
        <div id="submitExpenseFeedback" class="mt-2"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button type="button" id="submitExpenseBtn" class="btn btn-dark btn-sm">Submit</button>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var submitBtn = document.getElementById('submitExpenseBtn');
  submitBtn?.addEventListener('click', async function () {
    var form = document.getElementById('submitExpenseForm');
    var feedback = document.getElementById('submitExpenseFeedback');
    var formData = new FormData(form);

    feedback.innerHTML = '';

      try {
        // Include antiforgery token header if present (helps server-side validation for AJAX requests)
        var tokenInput = form.querySelector('input[name="__RequestVerificationToken"]');
        var headers = {
          'X-Requested-With': 'XMLHttpRequest'
        };
        if (tokenInput && tokenInput.value) {
          headers['RequestVerificationToken'] = tokenInput.value;
        }

        var response = await fetch(form.action, {
          method: 'POST',
          credentials: 'same-origin',
          headers: headers,
          body: formData
        });

        var contentType = response.headers.get('content-type') || '';
        if (contentType.indexOf('application/json') !== -1) {
          var json = await response.json();
          if (json.success) {
            feedback.innerHTML = '<div class="alert alert-success">' + json.message + '</div>';
            setTimeout(function() { location.reload(); }, 900);
          } else {
            var msg = json.message || (json.errors ? json.errors.join('<br/>') : 'Failed to submit.');
            feedback.innerHTML = '<div class="alert alert-danger">' + msg + '</div>';
          }
        } else {
          // Non-JSON response (e.g. HTML login page or error page) — surface text for debugging
          var text = await response.text();
          feedback.innerHTML = '<div class="alert alert-danger">Unexpected response: ' + (text.length > 300 ? text.substring(0,300) + '...' : text) + '</div>';
          console.warn('Non-JSON response received when submitting expense:', text);
        }
      } catch (err) {
        // Network-level failures show err.message (e.g. "Failed to fetch")
        feedback.innerHTML = '<div class="alert alert-danger">Network error: ' + (err.message || 'Unable to submit expenses. Please check your connection and try again.') + '</div>';
        console.error('Error submitting expense:', err);
      }
  });
});
</script>