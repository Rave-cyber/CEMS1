@section Scripts {
<script>
    // ── Stepper form logic ──
    let currentStep = 1;
    const totalSteps = 4;

    function showStep(step) {
        // Hide all steps
        document.getElementById('step1Content').style.display = 'none';
        document.getElementById('step2Content').style.display = 'none';
        document.getElementById('step3Content').style.display = 'none';
        document.getElementById('step4Content').style.display = 'none';

        // Show current step
        document.getElementById('step' + step + 'Content').style.display = 'block';

        // Update indicators
        updateIndicators(step);

        // Update button visibility
        document.getElementById('prevBtn').style.display = step === 1 ? 'none' : 'inline-block';
        document.getElementById('nextBtn').style.display = step === totalSteps ? 'none' : 'inline-block';
        document.getElementById('submitBtn').style.display = step === totalSteps ? 'inline-block' : 'none';

        currentStep = step;
    }

    function updateIndicators(activeStep) {
        for (let i = 1; i <= totalSteps; i++) {
            const indicator = document.getElementById('step' + i + 'Indicator');
            if (i <= activeStep) {
                indicator.style.background = 'var(--d-primary)';
                indicator.style.color = 'white';
                const label = indicator.parentElement.querySelector('span');
                if (label) label.style.color = 'var(--d-text)';
            } else {
                indicator.style.background = 'var(--d-border)';
                indicator.style.color = 'var(--d-muted)';
                const label = indicator.parentElement.querySelector('span');
                if (label) label.style.color = 'var(--d-muted)';
            }
        }
    }

    function validateStep(step) {
        if (step === 1) {
            const email = document.getElementById('createEmail').value.trim();
            const password = document.getElementById('createPassword').value.trim();
            const confirmPassword = document.getElementById('createConfirmPassword').value.trim();

            if (!email || !password || !confirmPassword) {
                alert('Please enter email, password, and confirm password.');
                return false;
            }
            if (password.length < 6) {
                alert('Password must be at least 6 characters.');
                return false;
            }
            if (password !== confirmPassword) {
                alert('Passwords do not match.');
                return false;
            }
        } else if (step === 2) {
            const fullName = document.getElementById('createFullName').value.trim();
            if (!fullName) {
                alert('Please enter full name.');
                return false;
            }
        }
        return true;
    }

    function updateReview() {
        document.getElementById('reviewEmail').textContent = document.getElementById('createEmail').value || '-';
        document.getElementById('reviewName').textContent = document.getElementById('createFullName').value || '-';
        const role = document.getElementById('createRole').value;
        document.getElementById('reviewRole').textContent = role || 'Not assigned';
        document.getElementById('reviewContact').textContent = document.getElementById('createContactNumber').value || '-';

        const street = document.getElementById('createStreet').value;
        const barangay = document.getElementById('createBarangay').value;
        const city = document.getElementById('createCity').value;
        const province = document.getElementById('createProvince').value;
        const zipCode = document.getElementById('createZipCode').value;
        const country = document.getElementById('createCountry').value;

        const address = [street, barangay, city, province, zipCode, country]
            .filter(x => x)
            .join(', ') || '-';
        document.getElementById('reviewAddress').textContent = address;
    }

    document.getElementById('nextBtn')?.addEventListener('click', function () {
        if (validateStep(currentStep)) {
            if (currentStep === totalSteps - 1) {
                updateReview();
            }
            showStep(currentStep + 1);
        }
    });

    document.getElementById('prevBtn')?.addEventListener('click', function () {
        showStep(currentStep - 1);
    });

    // Click on step indicator to jump
    for (let i = 1; i <= currentStep; i++) {
        document.getElementById('step' + i + 'Indicator')?.addEventListener('click', function () {
            if (i <= currentStep) {
                showStep(i);
            }
        });
    }

    // ── Modal helpers (bootstrap is guaranteed loaded here) ──
    function openEditModal(userId) {
        var modalEl = document.getElementById('editUserModal');
        var modalBody = document.getElementById('editUserModalBody');
        modalBody.innerHTML = '<div class="text-center py-4">Loading...</div>';

        var myModal = new bootstrap.Modal(modalEl);
        myModal.show();

        fetch('@Url.Action("EditUser", "SuperAdmin")' + '?userId=' + encodeURIComponent(userId))
            .then(function (r) { return r.text(); })
            .then(function (html) {
                modalBody.innerHTML = html;
                // Initialize PSGC for edit modal after content loads
                initializeEditPSGC();
            })
            .catch(function () { modalBody.innerHTML = '<div class="text-danger">Failed to load form.</div>'; });
    }

    // Initialize PSGC for edit modal
    function initializeEditPSGC() {
        // Province input
        (function () {
            var input = document.getElementById('editProvince');
            var codeEl = document.getElementById('editProvinceCode');
            var dd = document.getElementById('editProvinceDropdown');
            var cityInput = document.getElementById('editCity');
            var cityCode = document.getElementById('editCityCode');
            var brgyInput = document.getElementById('editBarangay');

            if (!input) return; // Elements not ready yet

            function onProvinceSelect(item) {
                cityInput.value = '';
                cityCode.value = '';
                cityInput.disabled = false;
                cityInput.placeholder = 'Loading cities...';
                brgyInput.value = '';
                brgyInput.disabled = true;
                brgyInput.placeholder = 'Select city first';
                psgcCities = [];
                psgcBarangays = [];
                document.getElementById('editCityDropdown').classList.remove('show');
                document.getElementById('editBarangayDropdown').classList.remove('show');

                fetch(PSGC_BASE + '/provinces/' + item.code + '/cities-municipalities/')
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        psgcCities = data.sort(function (a, b) { return a.name.localeCompare(b.name); });
                        cityInput.placeholder = 'Type to search city...';
                        cityInput.focus();
                    })
                    .catch(function () { cityInput.placeholder = 'Failed to load cities'; });
            }

            input.addEventListener('input', function () {
                codeEl.value = '';
                var filtered = psgcFilter(psgcProvinces, input.value);
                psgcRenderDropdown(dd, filtered, input, codeEl, onProvinceSelect);
            });

            input.addEventListener('focus', function () {
                if (psgcProvinces.length > 0) {
                    var filtered = psgcFilter(psgcProvinces, input.value);
                    psgcRenderDropdown(dd, filtered, input, codeEl, onProvinceSelect);
                }
            });

            input.addEventListener('blur', function () {
                setTimeout(function () { dd.classList.remove('show'); }, 200);
            });

            input.addEventListener('keydown', function (e) {
                var filtered = psgcFilter(psgcProvinces, input.value);
                psgcKeyboard(e, dd, input, codeEl, filtered, onProvinceSelect);
            });
        })();

        // City input
        (function () {
            var input = document.getElementById('editCity');
            var codeEl = document.getElementById('editCityCode');
            var dd = document.getElementById('editCityDropdown');
            var brgyInput = document.getElementById('editBarangay');

            if (!input) return;

            function onCitySelect(item) {
                brgyInput.value = '';
                brgyInput.disabled = false;
                brgyInput.placeholder = 'Loading barangays...';
                psgcBarangays = [];
                document.getElementById('editBarangayDropdown').classList.remove('show');

                fetch(PSGC_BASE + '/cities-municipalities/' + item.code + '/barangays/')
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        psgcBarangays = data.sort(function (a, b) { return a.name.localeCompare(b.name); });
                        brgyInput.placeholder = 'Type to search barangay...';
                        brgyInput.focus();
                    })
                    .catch(function () { brgyInput.placeholder = 'Failed to load barangays'; });
            }

            input.addEventListener('input', function () {
                codeEl.value = '';
                var filtered = psgcFilter(psgcCities, input.value);
                psgcRenderDropdown(dd, filtered, input, codeEl, onCitySelect);
            });

            input.addEventListener('focus', function () {
                if (psgcCities.length > 0) {
                    var filtered = psgcFilter(psgcCities, input.value);
                    psgcRenderDropdown(dd, filtered, input, codeEl, onCitySelect);
                }
            });

            input.addEventListener('blur', function () {
                setTimeout(function () { dd.classList.remove('show'); }, 200);
            });

            input.addEventListener('keydown', function (e) {
                var filtered = psgcFilter(psgcCities, input.value);
                psgcKeyboard(e, dd, input, codeEl, filtered, onCitySelect);
            });
        })();

        // Barangay input
        (function () {
            var input = document.getElementById('editBarangay');
            var dd = document.getElementById('editBarangayDropdown');

            if (!input) return;

            input.addEventListener('input', function () {
                var filtered = psgcFilter(psgcBarangays, input.value);
                psgcRenderDropdown(dd, filtered, input, null, null);
            });

            input.addEventListener('focus', function () {
                if (psgcBarangays.length > 0) {
                    var filtered = psgcFilter(psgcBarangays, input.value);
                    psgcRenderDropdown(dd, filtered, input, null, null);
                }
            });

            input.addEventListener('blur', function () {
                setTimeout(function () { dd.classList.remove('show'); }, 200);
            });

            input.addEventListener('keydown', function (e) {
                var filtered = psgcFilter(psgcBarangays, input.value);
                psgcKeyboard(e, dd, input, null, filtered, null);
            });
        })();

        // Preload provinces if not cached
        psgcLoadProvinces();
    }

    function openCreateAccountModal() {
        var form = document.getElementById('createAccountForm');
        if (form) form.reset();

        // Reset PSGC state
        document.getElementById('createProvinceCode').value = '';
        document.getElementById('createCityCode').value = '';
        document.getElementById('createCity').disabled = true;
        document.getElementById('createCity').placeholder = 'Select province first';
        document.getElementById('createBarangay').disabled = true;
        document.getElementById('createBarangay').placeholder = 'Select city first';
        document.getElementById('provinceDropdown').classList.remove('show');
        document.getElementById('cityDropdown').classList.remove('show');
        document.getElementById('barangayDropdown').classList.remove('show');
        document.getElementById('createCountry').value = 'Philippines';

        // Preload provinces if not cached
        psgcLoadProvinces();

        currentStep = 1;
        showStep(1);

        var modalEl = document.getElementById('createAccountModal');
        var myModal = new bootstrap.Modal(modalEl);
        myModal.show();
    }

    // ── PSGC API Integration ──
    var PSGC_BASE = 'https://psgc.gitlab.io/api';
    var psgcProvinces = [];
    var psgcCities = [];
    var psgcBarangays = [];
    var psgcActiveIndex = -1; // keyboard navigation index

    function psgcLoadProvinces() {
        if (psgcProvinces.length > 0) return; // already cached
        var dd = document.getElementById('provinceDropdown');
        dd.innerHTML = '<div class="psgc-spinner"><i class="bi bi-arrow-repeat"></i> Loading provinces...</div>';
        fetch(PSGC_BASE + '/provinces/')
            .then(function (r) { return r.json(); })
            .then(function (data) {
                psgcProvinces = data.sort(function (a, b) { return a.name.localeCompare(b.name); });
                dd.innerHTML = '';
            })
            .catch(function () {
                dd.innerHTML = '<div class="psgc-empty">Failed to load provinces</div>';
            });
    }

    function psgcRenderDropdown(dropdown, items, inputEl, codeEl, onSelect) {
        dropdown.innerHTML = '';
        psgcActiveIndex = -1;
        if (items.length === 0) {
            dropdown.innerHTML = '<div class="psgc-empty">No results found</div>';
            dropdown.classList.add('show');
            return;
        }
        items.forEach(function (item, idx) {
            var div = document.createElement('div');
            div.className = 'psgc-item';
            div.textContent = item.name;
            div.setAttribute('data-code', item.code);
            div.setAttribute('data-index', idx);
            div.addEventListener('mousedown', function (e) {
                e.preventDefault(); // prevent blur before click registers
                inputEl.value = item.name;
                if (codeEl) codeEl.value = item.code;
                dropdown.classList.remove('show');
                if (onSelect) onSelect(item);
            });
            dropdown.appendChild(div);
        });
        dropdown.classList.add('show');
    }

    function psgcFilter(list, query) {
        var q = query.toLowerCase().trim();
        if (!q) return list.slice(0, 50); // show first 50 when empty
        return list.filter(function (item) {
            return item.name.toLowerCase().indexOf(q) !== -1;
        }).slice(0, 50);
    }

    function psgcKeyboard(e, dropdown, inputEl, codeEl, items, onSelect) {
        var allItems = dropdown.querySelectorAll('.psgc-item');
        if (!allItems.length) return;
        if (e.key === 'ArrowDown') {
            e.preventDefault();
            psgcActiveIndex = Math.min(psgcActiveIndex + 1, allItems.length - 1);
            allItems.forEach(function (el, i) { el.classList.toggle('active', i === psgcActiveIndex); });
            allItems[psgcActiveIndex].scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            psgcActiveIndex = Math.max(psgcActiveIndex - 1, 0);
            allItems.forEach(function (el, i) { el.classList.toggle('active', i === psgcActiveIndex); });
            allItems[psgcActiveIndex].scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'Enter' && psgcActiveIndex >= 0) {
            e.preventDefault();
            allItems[psgcActiveIndex].dispatchEvent(new Event('mousedown'));
        } else if (e.key === 'Escape') {
            dropdown.classList.remove('show');
        }
    }

    // Province input
    (function () {
        var input = document.getElementById('createProvince');
        var codeEl = document.getElementById('createProvinceCode');
        var dd = document.getElementById('provinceDropdown');
        var cityInput = document.getElementById('createCity');
        var cityCode = document.getElementById('createCityCode');
        var brgyInput = document.getElementById('createBarangay');

        function onProvinceSelect(item) {
            // Reset downstream
            cityInput.value = '';
            cityCode.value = '';
            cityInput.disabled = false;
            cityInput.placeholder = 'Loading cities...';
            brgyInput.value = '';
            brgyInput.disabled = true;
            brgyInput.placeholder = 'Select city first';
            psgcCities = [];
            psgcBarangays = [];
            document.getElementById('cityDropdown').classList.remove('show');
            document.getElementById('barangayDropdown').classList.remove('show');

            // Fetch cities for this province
            fetch(PSGC_BASE + '/provinces/' + item.code + '/cities-municipalities/')
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    psgcCities = data.sort(function (a, b) { return a.name.localeCompare(b.name); });
                    cityInput.placeholder = 'Type to search city...';
                    cityInput.focus();
                })
                .catch(function () {
                    cityInput.placeholder = 'Failed to load cities';
                });
        }

        input.addEventListener('input', function () {
            codeEl.value = ''; // clear code when user types manually
            var filtered = psgcFilter(psgcProvinces, input.value);
            psgcRenderDropdown(dd, filtered, input, codeEl, onProvinceSelect);
        });

        input.addEventListener('focus', function () {
            if (psgcProvinces.length > 0) {
                var filtered = psgcFilter(psgcProvinces, input.value);
                psgcRenderDropdown(dd, filtered, input, codeEl, onProvinceSelect);
            }
        });

        input.addEventListener('blur', function () {
            setTimeout(function () { dd.classList.remove('show'); }, 200);
        });

        input.addEventListener('keydown', function (e) {
            var filtered = psgcFilter(psgcProvinces, input.value);
            psgcKeyboard(e, dd, input, codeEl, filtered, onProvinceSelect);
        });
    })();

    // City input
    (function () {
        var input = document.getElementById('createCity');
        var codeEl = document.getElementById('createCityCode');
        var dd = document.getElementById('cityDropdown');
        var brgyInput = document.getElementById('createBarangay');

        function onCitySelect(item) {
            brgyInput.value = '';
            brgyInput.disabled = false;
            brgyInput.placeholder = 'Loading barangays...';
            psgcBarangays = [];
            document.getElementById('barangayDropdown').classList.remove('show');

            fetch(PSGC_BASE + '/cities-municipalities/' + item.code + '/barangays/')
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    psgcBarangays = data.sort(function (a, b) { return a.name.localeCompare(b.name); });
                    brgyInput.placeholder = 'Type to search barangay...';
                    brgyInput.focus();
                })
                .catch(function () {
                    brgyInput.placeholder = 'Failed to load barangays';
                });
        }

        input.addEventListener('input', function () {
            codeEl.value = '';
            var filtered = psgcFilter(psgcCities, input.value);
            psgcRenderDropdown(dd, filtered, input, codeEl, onCitySelect);
        });

        input.addEventListener('focus', function () {
            if (psgcCities.length > 0) {
                var filtered = psgcFilter(psgcCities, input.value);
                psgcRenderDropdown(dd, filtered, input, codeEl, onCitySelect);
            }
        });

        input.addEventListener('blur', function () {
            setTimeout(function () { dd.classList.remove('show'); }, 200);
        });

        input.addEventListener('keydown', function (e) {
            var filtered = psgcFilter(psgcCities, input.value);
            psgcKeyboard(e, dd, input, codeEl, filtered, onCitySelect);
        });
    })();

    // Barangay input
    (function () {
        var input = document.getElementById('createBarangay');
        var dd = document.getElementById('barangayDropdown');

        input.addEventListener('input', function () {
            var filtered = psgcFilter(psgcBarangays, input.value);
            psgcRenderDropdown(dd, filtered, input, null, null);
        });

        input.addEventListener('focus', function () {
            if (psgcBarangays.length > 0) {
                var filtered = psgcFilter(psgcBarangays, input.value);
                psgcRenderDropdown(dd, filtered, input, null, null);
            }
        });

        input.addEventListener('blur', function () {
            setTimeout(function () { dd.classList.remove('show'); }, 200);
        });

        input.addEventListener('keydown', function (e) {
            var filtered = psgcFilter(psgcBarangays, input.value);
            psgcKeyboard(e, dd, input, null, filtered, null);
        });
    })();

    // Close PSGC dropdowns when clicking outside
    document.addEventListener('click', function (e) {
        if (!e.target.closest('.psgc-wrapper')) {
            document.querySelectorAll('.psgc-dropdown').forEach(function (dd) { dd.classList.remove('show'); });
        }
    });

    // ── Filters & buttons ──
    (function () {
        function applyUserFilters() {
            var q = document.getElementById('userSearch')?.value || '';
            var role = document.getElementById('userRoleFilter')?.value || '';
            var status = document.getElementById('userStatusFilter')?.value || '';

            var params = [];
            if (q) params.push('q=' + encodeURIComponent(q));
            if (role) params.push('role=' + encodeURIComponent(role));
            if (status) params.push('status=' + encodeURIComponent(status));
            params.push('page=1'); // Reset to page 1 when filtering

            window.location.href = '@Url.Action("Users", "SuperAdmin")' + (params.length ? ('?' + params.join('&')) : '');
        }

        // Restore filter state
        var filterQuery = '@Html.Raw((filterQuery ?? "").Replace("'", "\\'"))';
        var filterRole = '@Html.Raw((filterRole ?? "").Replace("'", "\\'"))';
        var filterStatus = '@Html.Raw((filterStatus ?? "").Replace("'", "\\'"))';

        if (filterQuery) document.getElementById('userSearch').value = filterQuery;
        if (filterRole) document.getElementById('userRoleFilter').value = filterRole;
        if (filterStatus) document.getElementById('userStatusFilter').value = filterStatus;

        // Search (debounced)
        var searchEl = document.getElementById('userSearch');
        if (searchEl) {
            var timer;
            searchEl.addEventListener('input', function () {
                clearTimeout(timer);
                timer = setTimeout(applyUserFilters, 400);
            });
        }

        // Dropdowns
        document.getElementById('userRoleFilter')?.addEventListener('change', applyUserFilters);
        document.getElementById('userStatusFilter')?.addEventListener('change', applyUserFilters);

        // Create Account button
        document.getElementById('createAccountBtn')?.addEventListener('click', openCreateAccountModal);

        // PDF Export
        document.getElementById('exportPdfBtn')?.addEventListener('click', function () {
            var q = document.getElementById('userSearch')?.value || '';
            var role = document.getElementById('userRoleFilter')?.value || '';
            var status = document.getElementById('userStatusFilter')?.value || '';

            var params = [];
            if (q) params.push('q=' + encodeURIComponent(q));
            if (role) params.push('role=' + encodeURIComponent(role));
            if (status) params.push('status=' + encodeURIComponent(status));

            window.location.href = '@Url.Action("ExportUsersPdf", "SuperAdmin")' + (params.length ? ('?' + params.join('&')) : '');
        });
    })();
</script>
}
