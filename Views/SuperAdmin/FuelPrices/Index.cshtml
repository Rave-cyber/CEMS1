@{
    ViewData["Title"] = "Fuel Price Management";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";

    var fuelPrices = (List<CEMS.Models.FuelPrice>)ViewBag.FuelPrices;
}

<link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />

<div class="page-wrapper">
    <div class="container-fluid px-4">

        <!-- Page Header -->
        <div class="page-header">
            @* <h1 class="page-title">
                <i class="bi bi-fuel-pump"></i> Fuel Price Management
            </h1> *@
            <p class="page-subtitle">Manually set and adjust fuel prices visible across the system.</p>
        </div>

        <!-- Stats Row -->
        <div class="row g-3 mb-4">
            <div class="col-sm-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon stat-icon--primary"><i class="bi bi-fuel-pump-fill"></i></div>
                    <div>
                        <div class="stat-label">Total Fuel Types</div>
                        <div class="stat-value">@fuelPrices.Count</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon stat-icon--success"><i class="bi bi-graph-up-arrow"></i></div>
                    <div>
                        <div class="stat-label">Highest Price</div>
                        <div class="stat-value">₱@(fuelPrices.Any() ? fuelPrices.Max(f => f.Price).ToString("N2") : "0.00")</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon stat-icon--warning"><i class="bi bi-graph-down-arrow"></i></div>
                    <div>
                        <div class="stat-label">Lowest Price</div>
                        <div class="stat-value">₱@(fuelPrices.Any() ? fuelPrices.Min(f => f.Price).ToString("N2") : "0.00")</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon stat-icon--info"><i class="bi bi-calculator"></i></div>
                    <div>
                        <div class="stat-label">Average Price</div>
                        <div class="stat-value">₱@(fuelPrices.Any() ? fuelPrices.Average(f => f.Price).ToString("N2") : "0.00")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Add Fuel Price Form -->
            <div class="col-lg-4">
                <div class="dash-card">
                    <div class="dash-card-head">
                        <i class="bi bi-plus-circle"></i> Add Fuel Type
                    </div>
                    <div class="dash-card-body">
                        <form method="post" asp-action="CreateFuelPrice" asp-controller="SuperAdmin">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Fuel Name <span class="text-danger">*</span></label>
                                <input type="text" name="name" class="form-control" placeholder="e.g. Unleaded 91" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Description</label>
                                <input type="text" name="description" class="form-control" placeholder="e.g. Regular Gasoline (91 RON)" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Price (₱) <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text">₱</span>
                                    <input type="number" name="price" class="form-control" step="0.01" min="0.01" placeholder="0.00" required />
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Unit</label>
                                <select name="unit" class="form-select">
                                    <option value="/L">/L (per Liter)</option>
                                    <option value="/kg">/kg (per Kilogram)</option>
                                    <option value="/gal">/gal (per Gallon)</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Icon</label>
                                <select name="icon" class="form-select">
                                    <option value="bi-droplet-fill">💧 Droplet (Gasoline)</option>
                                    <option value="bi-truck">🚛 Truck (Diesel)</option>
                                    <option value="bi-lightning-charge-fill">⚡ Lightning (High Octane)</option>
                                    <option value="bi-fire">🔥 Fire (Kerosene)</option>
                                    <option value="bi-cloud-fill">☁️ Cloud (LPG)</option>
                                    <option value="bi-leaf-fill">🌿 Leaf (Biofuel)</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Category</label>
                                <select name="cssClass" class="form-select">
                                    <option value="gasoline">Gasoline</option>
                                    <option value="premium">Premium</option>
                                    <option value="highoctane">High Octane</option>
                                    <option value="diesel">Diesel</option>
                                    <option value="kerosene">Kerosene</option>
                                    <option value="lpg">LPG</option>
                                    <option value="bio">Biofuel</option>
                                </select>
                            </div>
                            <button type="submit" class="btn w-100" style="background: var(--d-primary); color: #fff; font-weight: 600; border-radius: 8px; padding: 10px;">
                                <i class="bi bi-plus-lg me-1"></i> Add Fuel Type
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Fuel Price List -->
            <div class="col-lg-8">
                <div class="dash-card">
                    <div class="dash-card-head">
                        <i class="bi bi-list-ul"></i> Current Fuel Prices
                        <span class="ms-auto" style="font-size: 0.8rem; color: var(--d-muted); font-weight: 400;">
                            @fuelPrices.Count fuel type(s)
                        </span>
                    </div>
                    <div class="dash-card-body p-0">
                        @if (fuelPrices.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead>
                                        <tr style="background: linear-gradient(135deg, rgba(26,107,181,0.03), rgba(16,185,129,0.03));">
                                            <th style="padding: 12px 16px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--d-muted); letter-spacing: 0.5px;">Fuel Type</th>
                                            <th style="padding: 12px 16px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--d-muted); letter-spacing: 0.5px;">Price</th>
                                            <th style="padding: 12px 16px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--d-muted); letter-spacing: 0.5px;">Unit</th>
                                            <th style="padding: 12px 16px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--d-muted); letter-spacing: 0.5px;">Last Updated</th>
                                            <th style="padding: 12px 16px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--d-muted); letter-spacing: 0.5px; text-align: right;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var fp in fuelPrices)
                                        {
                                            <tr>
                                                <td style="padding: 14px 16px;">
                                                    <div class="d-flex align-items-center gap-3">
                                                        <div class="stat-icon stat-icon--primary" style="width: 40px; height: 40px; border-radius: 8px; font-size: 1.1rem;">
                                                            <i class="bi @fp.Icon"></i>
                                                        </div>
                                                        <div>
                                                            <div style="font-weight: 600; color: var(--d-text);">@fp.Name</div>
                                                            <div style="font-size: 0.78rem; color: var(--d-muted);">@fp.Description</div>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td style="padding: 14px 16px;">
                                                    <span style="font-size: 1.1rem; font-weight: 700; color: var(--d-primary);">₱@fp.Price.ToString("N2")</span>
                                                </td>
                                                <td style="padding: 14px 16px; color: var(--d-muted);">@fp.Unit</td>
                                                <td style="padding: 14px 16px;">
                                                    <span style="font-size: 0.82rem; color: var(--d-muted);">@fp.UpdatedAt.ToString("MMM dd, yyyy h:mm tt")</span>
                                                </td>
                                                <td style="padding: 14px 16px; text-align: right;">
                                                    <button class="btn btn-sm me-1" style="background: rgba(26,107,181,0.1); color: var(--d-primary); border: none; border-radius: 6px; padding: 6px 12px; font-weight: 600;"
                                                            data-bs-toggle="modal" data-bs-target="#editModal-@fp.Id">
                                                        <i class="bi bi-pencil-square"></i> 
                                                    </button>
                                                    <form method="post" asp-action="DeleteFuelPrice" asp-controller="SuperAdmin" class="d-inline"
                                                          onsubmit="return confirm('Are you sure you want to delete this fuel type?');">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@fp.Id" />
                                                        <button type="submit" class="btn btn-sm" style="background: rgba(239,68,68,0.1); color: var(--d-danger); border: none; border-radius: 6px; padding: 6px 12px; font-weight: 600;">
                                                            <i class="bi bi-trash3"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-fuel-pump" style="font-size: 3rem; color: var(--d-muted); opacity: 0.3;"></i>
                                <p class="mt-3" style="color: var(--d-muted); font-size: 0.9rem;">No fuel prices configured yet. Add your first fuel type using the form.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Edit Modals -->
@foreach (var fp in fuelPrices)
{
    <div class="modal fade" id="editModal-@fp.Id" tabindex="-1" aria-labelledby="editModalLabel-@fp.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border: none; border-radius: 12px; overflow: hidden;">
                <div class="modal-header" style="background: linear-gradient(135deg, rgba(26,107,181,0.05), rgba(46,196,182,0.05)); border-bottom: 1px solid var(--d-border);">
                    <h5 class="modal-title" id="editModalLabel-@fp.Id" style="font-weight: 700; color: var(--d-text);">
                        <i class="bi bi-pencil-square me-2" style="color: var(--d-primary);"></i>Edit Fuel Price
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form method="post" asp-action="UpdateFuelPrice" asp-controller="SuperAdmin">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@fp.Id" />
                    <div class="modal-body" style="padding: 24px;">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Fuel Name <span class="text-danger">*</span></label>
                            <input type="text" name="name" class="form-control" value="@fp.Name" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Description</label>
                            <input type="text" name="description" class="form-control" value="@fp.Description" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Price (₱) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">₱</span>
                                <input type="number" name="price" class="form-control" step="0.01" min="0.01" value="@fp.Price" required />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Unit</label>
                            <select name="unit" class="form-select">
                                @{ var units = new[] { ("/L", "/L (per Liter)"), ("/kg", "/kg (per Kilogram)"), ("/gal", "/gal (per Gallon)") }; }
                                @foreach (var (val, label) in units)
                                {
                                    if (fp.Unit == val) { <option value="@val" selected="selected">@label</option> }
                                    else { <option value="@val">@label</option> }
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Icon</label>
                            <select name="icon" class="form-select">
                                @{ var icons = new[] { ("bi-droplet-fill", "💧 Droplet (Gasoline)"), ("bi-truck", "🚛 Truck (Diesel)"), ("bi-lightning-charge-fill", "⚡ Lightning (High Octane)"), ("bi-fire", "🔥 Fire (Kerosene)"), ("bi-cloud-fill", "☁️ Cloud (LPG)"), ("bi-leaf-fill", "🌿 Leaf (Biofuel)") }; }
                                @foreach (var (val, label) in icons)
                                {
                                    if (fp.Icon == val) { <option value="@val" selected="selected">@label</option> }
                                    else { <option value="@val">@label</option> }
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Category</label>
                            <select name="cssClass" class="form-select">
                                @{ var cats = new[] { ("gasoline", "Gasoline"), ("premium", "Premium"), ("highoctane", "High Octane"), ("diesel", "Diesel"), ("kerosene", "Kerosene"), ("lpg", "LPG"), ("bio", "Biofuel") }; }
                                @foreach (var (val, label) in cats)
                                {
                                    if (fp.CssClass == val) { <option value="@val" selected="selected">@label</option> }
                                    else { <option value="@val">@label</option> }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer" style="border-top: 1px solid var(--d-border); padding: 16px 24px;">
                        <button type="button" class="btn" style="background: var(--d-bg); color: var(--d-muted); border: 1px solid var(--d-border); border-radius: 8px; padding: 8px 20px; font-weight: 600;" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn" style="background: var(--d-primary); color: #fff; border-radius: 8px; padding: 8px 20px; font-weight: 600;">
                            <i class="bi bi-check-lg me-1"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
