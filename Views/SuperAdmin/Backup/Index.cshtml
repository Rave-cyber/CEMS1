@using CEMS.Services
@{
    ViewData["Title"] = "Backup & Recovery";
    var backups = ViewBag.BackupHistory as List<BackupFileInfo> ?? new List<BackupFileInfo>();
}

@if (TempData["Success"] != null)
{
    <div style="background:#f0fdf4;border:1px solid #86efac;border-radius:10px;padding:14px 18px;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
        <i class="bi bi-check-circle-fill" style="color:#16a34a;font-size:1.1rem;"></i>
        <span style="color:#166534;font-weight:500;font-size:0.9rem;">@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:10px;padding:14px 18px;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
        <i class="bi bi-exclamation-circle-fill" style="color:#dc2626;font-size:1.1rem;"></i>
        <span style="color:#991b1b;font-weight:500;font-size:0.9rem;">@TempData["Error"]</span>
    </div>
}

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px;">

    @* Create Backup *@
    <div style="background:white;border:1px solid #e9eef6;border-radius:12px;padding:24px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
            <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#1a6bb5,#2ec4b6);display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-cloud-arrow-up-fill" style="color:white;font-size:1rem;"></i>
            </div>
            <div>
                <h5 style="font-weight:700;color:#1e293b;margin:0;font-size:1rem;">Create Backup</h5>
                <p style="color:#64748b;font-size:0.78rem;margin:0;">Saves to server + downloads a copy</p>
            </div>
        </div>
        <form asp-action="CreateBackup" asp-controller="SuperAdmin" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" style="width:100%;background:linear-gradient(135deg,#1a6bb5,#2ec4b6);color:white;border:none;border-radius:8px;padding:11px;font-weight:600;font-size:0.9rem;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;">
                <i class="bi bi-database-fill-add"></i> Create Backup Now
            </button>
        </form>
    </div>

    @* Upload & Restore *@
    <div style="background:white;border:1px solid #e9eef6;border-radius:12px;padding:24px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
            <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#f59e0b,#ef4444);display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-cloud-arrow-down-fill" style="color:white;font-size:1rem;"></i>
            </div>
            <div>
                <h5 style="font-weight:700;color:#1e293b;margin:0;font-size:1rem;">Upload & Restore</h5>
                <p style="color:#64748b;font-size:0.78rem;margin:0;">Upload a .zip backup file from your computer</p>
            </div>
        </div>
        <form asp-action="RestoreBackup" asp-controller="SuperAdmin" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="file" name="backupFile" accept=".zip" required
                   style="width:100%;border:1.5px solid #e2e8f0;border-radius:8px;padding:8px 12px;font-size:0.85rem;margin-bottom:10px;" />
            <button type="submit"
                    onclick="return confirm('Restore from this file? Existing data will be preserved and deleted records will be brought back.')"
                    style="width:100%;background:linear-gradient(135deg,#f59e0b,#ef4444);color:white;border:none;border-radius:8px;padding:11px;font-weight:600;font-size:0.9rem;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;">
                <i class="bi bi-arrow-counterclockwise"></i> Restore from File
            </button>
        </form>
    </div>
</div>

@* Stored Backups on Server *@
<div style="background:white;border:1px solid #e9eef6;border-radius:12px;padding:24px;">
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
        <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#8b5cf6);display:flex;align-items:center;justify-content:center;">
            <i class="bi bi-archive-fill" style="color:white;font-size:1rem;"></i>
        </div>
        <div>
            <h5 style="font-weight:700;color:#1e293b;margin:0;font-size:1rem;">Stored Backups</h5>
            <p style="color:#64748b;font-size:0.78rem;margin:0;">Backups saved on the server — click Restore to bring back deleted data</p>
        </div>
    </div>

    @if (!backups.Any())
    {
        <div style="text-align:center;padding:32px;color:#94a3b8;">
            <i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px;"></i>
            <p style="font-size:0.9rem;margin:0;">No backups stored yet. Create one above.</p>
        </div>
    }
    else
    {
        <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;font-size:0.88rem;">
                <thead>
                    <tr style="background:#f8fafc;border-bottom:2px solid #e9eef6;">
                        <th style="padding:10px 14px;text-align:left;font-weight:600;color:#64748b;">File Name</th>
                        <th style="padding:10px 14px;text-align:left;font-weight:600;color:#64748b;">Created</th>
                        <th style="padding:10px 14px;text-align:right;font-weight:600;color:#64748b;">Size</th>
                        <th style="padding:10px 14px;text-align:center;font-weight:600;color:#64748b;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var backup in backups)
                    {
                        <tr style="border-bottom:1px solid #f1f5f9;">
                            <td style="padding:12px 14px;">
                                <div style="display:flex;align-items:center;gap:8px;">
                                    <i class="bi bi-file-zip-fill" style="color:#6366f1;font-size:1rem;"></i>
                                    <span style="font-weight:500;color:#1e293b;">@backup.DisplayName</span>
                                </div>
                            </td>
                            <td style="padding:12px 14px;color:#64748b;">
                                @backup.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")
                            </td>
                            <td style="padding:12px 14px;text-align:right;color:#64748b;">
                                @if (backup.SizeBytes < 1024 * 1024)
                                {
                                    <span>@((backup.SizeBytes / 1024.0).ToString("F1")) KB</span>
                                }
                                else
                                {
                                    <span>@((backup.SizeBytes / 1024.0 / 1024.0).ToString("F2")) MB</span>
                                }
                            </td>
                            <td style="padding:12px 14px;text-align:center;">
                                <form asp-action="RestoreStoredBackup" asp-controller="SuperAdmin" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="fileName" value="@backup.FileName" />
                                    <button type="submit"
                                            onclick="return confirm('Restore from @backup.FileName?\n\nExisting data will be preserved.\nDeleted records will be brought back.')"
                                            style="background:linear-gradient(135deg,#1a6bb5,#2ec4b6);color:white;border:none;border-radius:6px;padding:6px 14px;font-weight:600;font-size:0.8rem;cursor:pointer;display:inline-flex;align-items:center;gap:6px;">
                                        <i class="bi bi-arrow-counterclockwise"></i> Restore
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div style="background:#fffbeb;border:1px solid #fde68a;border-radius:10px;padding:14px 18px;margin-top:20px;display:flex;gap:10px;">
    <i class="bi bi-info-circle-fill" style="color:#d97706;font-size:1rem;flex-shrink:0;margin-top:2px;"></i>
    <div style="font-size:0.82rem;color:#92400e;line-height:1.6;">
        <strong>How restore works:</strong> Restoring a backup does <strong>not</strong> delete your current data.
        Records that were deleted after the backup was created will be <strong>brought back</strong>.
        Records that already exist will be <strong>updated</strong> to match the backup.
        New records added after the backup are <strong>kept</strong>.
    </div>
</div>
