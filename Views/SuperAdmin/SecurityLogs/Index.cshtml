@{
    ViewData["Title"] = "Security Logs";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";

    var logs = (List<CEMS.Models.AuditLog>)ViewBag.Logs;
    var threatSummary = (CEMS.Services.SecurityThreatSummary)ViewBag.ThreatSummary;
    var securityActions = (List<string>)ViewBag.SecurityActions;

    var filterSeverity = ViewBag.FilterSeverity as string;
    var filterAction   = ViewBag.FilterAction as string;
    var filterIp       = ViewBag.FilterIp as string;
    var filterStart    = ViewBag.FilterStart as DateTime?;
    var filterEnd      = ViewBag.FilterEnd as DateTime?;
    int currentPage    = ViewBag.CurrentPage ?? 1;
    int totalPages     = ViewBag.TotalPages ?? 1;
    int totalCount     = ViewBag.TotalCount ?? 0;

    string SeverityBadge(string? details)
    {
        if (details == null) return "<span class=\"badge bg-secondary\">Info</span>";
        if (details.Contains("[Critical]")) return "<span class=\"badge sev-critical\">Critical</span>";
        if (details.Contains("[High]"))     return "<span class=\"badge sev-high\">High</span>";
        if (details.Contains("[Medium]"))   return "<span class=\"badge sev-medium\">Medium</span>";
        if (details.Contains("[Low]"))      return "<span class=\"badge sev-low\">Low</span>";
        return "<span class=\"badge bg-secondary\">Info</span>";
    }

    string ActionIcon(string action) => action switch
    {
        "BruteForceDetected"        => "bi-shield-exclamation text-danger",
        "CredentialStuffingDetected"=> "bi-bug text-danger",
        "SuspiciousLoginSuccess"    => "bi-exclamation-triangle text-warning",
        "NewIpLogin"                => "bi-geo-alt text-info",
        "FailedLoginAttempt"        => "bi-x-circle text-danger",
        "UserLogin"                 => "bi-box-arrow-in-right text-success",
        "UserLogout"                => "bi-box-arrow-right text-secondary",
        _                           => "bi-shield text-muted"
    };
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<style>
    .page-wrapper { background: #f1f5f9; min-height: calc(100vh - 80px); padding: 20px 0 40px; }
    .page-header  { padding: 0 16px; margin-bottom: 20px; }
    .page-title   { font-size: 1.5rem; font-weight: 700; color: #1e293b; display: flex; align-items: center; gap: 12px; margin-bottom: 4px; }
    .page-subtitle{ color: #64748b; font-size: 0.9rem; }

    /* Stat cards */
    .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; padding: 0 16px; margin-bottom: 20px; }
    .stat-card { background: white; border-radius: 12px; padding: 16px 20px; border: 1px solid #e9eef6; display: flex; align-items: center; gap: 14px; }
    .stat-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; flex-shrink: 0; }
    .stat-icon.red    { background: #fef2f2; color: #dc2626; }
    .stat-icon.orange { background: #fff7ed; color: #ea580c; }
    .stat-icon.yellow { background: #fefce8; color: #ca8a04; }
    .stat-icon.blue   { background: #eff6ff; color: #2563eb; }
    .stat-value { font-size: 1.6rem; font-weight: 700; color: #1e293b; line-height: 1; }
    .stat-label { font-size: 0.78rem; color: #64748b; margin-top: 2px; }

    /* Filter bar */
    .filter-bar { background: white; border-radius: 12px; padding: 14px 20px; margin: 0 16px 20px; border: 1px solid #e9eef6; display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-end; }
    .filter-bar .form-label { font-size: 0.75rem; font-weight: 600; color: #64748b; text-transform: uppercase; margin-bottom: 4px; }
    .filter-bar .form-control, .filter-bar .form-select { font-size: 0.875rem; border-color: #e2e8f0; border-radius: 8px; padding: 6px 10px; }
    .filter-bar .form-control:focus, .filter-bar .form-select:focus { border-color: #0288d1; box-shadow: 0 0 0 3px rgba(2,136,209,0.1); }
    .btn-filter { background: #0288d1; color: white; border: none; border-radius: 8px; padding: 7px 18px; font-size: 0.875rem; font-weight: 500; cursor: pointer; }
    .btn-filter:hover { background: #0277bd; }
    .btn-clear  { background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; border-radius: 8px; padding: 7px 14px; font-size: 0.875rem; text-decoration: none; }
    .btn-clear:hover { background: #e2e8f0; }

    /* Table */
    .table-card { background: white; border-radius: 12px; margin: 0 16px; border: 1px solid #e9eef6; overflow: hidden; }
    .table-header { padding: 14px 20px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
    .table-title  { font-size: 1rem; font-weight: 600; color: #1e293b; display: flex; align-items: center; gap: 8px; }
    .table-count  { font-size: 0.8rem; color: #64748b; background: #f1f5f9; padding: 3px 10px; border-radius: 20px; }
    .log-table    { width: 100%; border-collapse: collapse; }
    .log-table th { background: #f8fafc; padding: 10px 14px; font-size: 0.75rem; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.4px; border-bottom: 1px solid #e9eef6; white-space: nowrap; }
    .log-table td { padding: 10px 14px; font-size: 0.85rem; color: #334155; border-bottom: 1px solid #f8fafc; vertical-align: middle; }
    .log-table tr:last-child td { border-bottom: none; }
    .log-table tr:hover td { background: #f8fafc; }

    /* Severity badges */
    .badge { font-size: 0.72rem; font-weight: 600; padding: 3px 8px; border-radius: 6px; }
    .sev-critical { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
    .sev-high     { background: #fff7ed; color: #ea580c; border: 1px solid #fed7aa; }
    .sev-medium   { background: #fefce8; color: #ca8a04; border: 1px solid #fde68a; }
    .sev-low      { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; }

    /* Action badge */
    .action-pill { display: inline-flex; align-items: center; gap: 5px; background: #f1f5f9; border-radius: 6px; padding: 3px 8px; font-size: 0.78rem; font-weight: 500; color: #334155; white-space: nowrap; }

    /* IP chip */
    .ip-chip { font-family: monospace; font-size: 0.8rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 5px; padding: 2px 7px; color: #475569; }

    /* Details text */
    .details-text { max-width: 340px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #64748b; font-size: 0.82rem; }

    /* Pagination */
    .pagination-bar { display: flex; align-items: center; justify-content: space-between; padding: 12px 20px; border-top: 1px solid #f1f5f9; flex-wrap: wrap; gap: 8px; }
    .pagination-info { font-size: 0.82rem; color: #64748b; }
    .pagination-btns { display: flex; gap: 4px; }
    .page-btn { padding: 5px 12px; border: 1px solid #e2e8f0; border-radius: 6px; background: white; font-size: 0.82rem; color: #475569; text-decoration: none; cursor: pointer; }
    .page-btn:hover { background: #f1f5f9; }
    .page-btn.active { background: #0288d1; color: white; border-color: #0288d1; }
    .page-btn.disabled { opacity: 0.4; pointer-events: none; }

    /* Empty state */
    .empty-state { text-align: center; padding: 60px 20px; color: #94a3b8; }
    .empty-state i { font-size: 3rem; margin-bottom: 12px; display: block; }

    body.dark-mode .stat-card, body.dark-mode .filter-bar, body.dark-mode .table-card { background: #1e293b; border-color: #334155; }
    body.dark-mode .log-table th { background: #0f172a; color: #94a3b8; }
    body.dark-mode .log-table td { color: #cbd5e1; border-color: #1e293b; }
    body.dark-mode .log-table tr:hover td { background: #0f172a; }
    body.dark-mode .page-title, body.dark-mode .table-title, body.dark-mode .stat-value { color: #e2e8f0; }
    body.dark-mode .action-pill { background: #0f172a; color: #94a3b8; }
    body.dark-mode .ip-chip { background: #0f172a; border-color: #334155; color: #94a3b8; }
</style>

<div class="page-wrapper">
    <!-- Header -->
    <div class="page-header">
        <div class="page-title">
            <i class="bi bi-shield-lock-fill" style="color:#dc2626;"></i>
            Security Logs
        </div>
        <div class="page-subtitle">Monitor login activity, threat detections, and suspicious behaviour</div>
    </div>

    <!-- Stat Cards -->
    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-icon red"><i class="bi bi-x-circle-fill"></i></div>
            <div>
                <div class="stat-value">@threatSummary.FailedLoginsLast1h</div>
                <div class="stat-label">Failed Logins (1h)</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon orange"><i class="bi bi-globe2"></i></div>
            <div>
                <div class="stat-value">@threatSummary.UniqueAttackerIpsLast1h</div>
                <div class="stat-label">Attacker IPs (1h)</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon yellow"><i class="bi bi-lock-fill"></i></div>
            <div>
                <div class="stat-value">@threatSummary.LockedAccountsLast1h</div>
                <div class="stat-label">Locked Accounts (1h)</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-shield-exclamation"></i></div>
            <div>
                <div class="stat-value">@threatSummary.RecentThreats.Count</div>
                <div class="stat-label">Threats (24h)</div>
            </div>
        </div>
    </div>

    <!-- Filter Bar -->
    <form method="get" asp-action="SecurityLogs" asp-controller="SuperAdmin">
        <div class="filter-bar">
            <div>
                <label class="form-label">Action</label>
                <select name="action" class="form-select" style="min-width:200px;">
                    <option value="">All Actions</option>
                    @foreach (var a in securityActions)
                    {
                        <option value="@a" selected="@(filterAction == a ? "selected" : null)">@a</option>
                    }
                </select>
            </div>
            <div>
                <label class="form-label">Severity</label>
                <select name="severity" class="form-select" style="min-width:130px;">
                    <option value="">All</option>
                    @foreach (var s in new[] { "Critical", "High", "Medium", "Low" })
                    {
                        <option value="@s" selected="@(filterSeverity == s ? "selected" : null)">@s</option>
                    }
                </select>
            </div>
            <div>
                <label class="form-label">IP Address</label>
                <input type="text" name="ip" class="form-control" placeholder="e.g. 192.168.1.1"
                       value="@filterIp" style="min-width:160px;" />
            </div>
            <div>
                <label class="form-label">From</label>
                <input type="date" name="start" class="form-control"
                       value="@filterStart?.ToString("yyyy-MM-dd")" style="min-width:140px;" />
            </div>
            <div>
                <label class="form-label">To</label>
                <input type="date" name="end" class="form-control"
                       value="@filterEnd?.ToString("yyyy-MM-dd")" style="min-width:140px;" />
            </div>
            <div style="display:flex;gap:8px;align-items:flex-end;">
                <button type="submit" class="btn-filter"><i class="bi bi-funnel me-1"></i>Filter</button>
                <a href="@Url.Action("SecurityLogs", "SuperAdmin")" class="btn-clear">Clear</a>
            </div>
        </div>
    </form>

    <!-- Logs Table -->
    <div class="table-card">
        <div class="table-header">
            <div class="table-title">
                <i class="bi bi-list-ul" style="color:#0288d1;"></i>
                Security Events
            </div>
            <span class="table-count">@totalCount record@(totalCount != 1 ? "s" : "")</span>
        </div>

        @if (!logs.Any())
        {
            <div class="empty-state">
                <i class="bi bi-shield-check"></i>
                <div style="font-size:1rem;font-weight:600;color:#475569;">No security events found</div>
                <div style="font-size:0.85rem;margin-top:4px;">Try adjusting your filters or check back later.</div>
            </div>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table class="log-table">
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>Severity</th>
                            <th>Action</th>
                            <th>IP Address</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in logs)
                        {
                            <tr>
                                <td style="white-space:nowrap;color:#64748b;font-size:0.8rem;">
                                    @log.Timestamp.ToLocalTime().ToString("MMM d, yyyy")<br />
                                    <span style="font-size:0.75rem;">@log.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                </td>
                                <td>@Html.Raw(SeverityBadge(log.Details))</td>
                                <td>
                                    <span class="action-pill">
                                        <i class="bi @ActionIcon(log.Action)"></i>
                                        @log.Action
                                    </span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(log.IpAddress))
                                    {
                                        <span class="ip-chip">@log.IpAddress</span>
                                    }
                                    else
                                    {
                                        <span style="color:#cbd5e1;">—</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        // Strip the [Severity] prefix from display since we show it as a badge
                                        var cleanDetails = log.Details ?? "";
                                        foreach (var sev in new[] { "[Critical] ", "[High] ", "[Medium] ", "[Low] " })
                                            cleanDetails = cleanDetails.Replace(sev, "");
                                    }
                                    <span class="details-text" title="@cleanDetails">@cleanDetails</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <div class="pagination-bar">
                    <div class="pagination-info">
                        Page @currentPage of @totalPages
                    </div>
                    <div class="pagination-btns">
                        <a class="page-btn @(currentPage <= 1 ? "disabled" : "")"
                           href="@Url.Action("SecurityLogs", "SuperAdmin", new { action = filterAction, severity = filterSeverity, ip = filterIp, start = filterStart?.ToString("yyyy-MM-dd"), end = filterEnd?.ToString("yyyy-MM-dd"), page = currentPage - 1 })">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                        @for (int p = Math.Max(1, currentPage - 2); p <= Math.Min(totalPages, currentPage + 2); p++)
                        {
                            <a class="page-btn @(p == currentPage ? "active" : "")"
                               href="@Url.Action("SecurityLogs", "SuperAdmin", new { action = filterAction, severity = filterSeverity, ip = filterIp, start = filterStart?.ToString("yyyy-MM-dd"), end = filterEnd?.ToString("yyyy-MM-dd"), page = p })">
                                @p
                            </a>
                        }
                        <a class="page-btn @(currentPage >= totalPages ? "disabled" : "")"
                           href="@Url.Action("SecurityLogs", "SuperAdmin", new { action = filterAction, severity = filterSeverity, ip = filterIp, start = filterStart?.ToString("yyyy-MM-dd"), end = filterEnd?.ToString("yyyy-MM-dd"), page = currentPage + 1 })">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </div>
                </div>
            }
        }
    </div>
</div>
