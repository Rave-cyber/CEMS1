@{
    ViewData["Title"] = "CEMS - Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CEMS - Expense Management System</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #2ec4b6;
            --primary-dark: #0d8b7d;
            --accent: #1a6bb5;
            --accent-dark: #12507d;
            --surface: #ffffff;
            --bg: #f0f7fa;
            --text: #0f1724;
            --text-muted: #5a6a7a;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            min-height: 100vh;
            background: var(--bg);
            overflow-x: hidden;
            color: var(--text);
        }

        /* ── Animated background grid ── */
        .bg-grid {
            position: fixed; inset: 0; z-index: 0; pointer-events: none;
            background-image:
                radial-gradient(circle at 1px 1px, rgba(26,107,181,.07) 1px, transparent 0);
            background-size: 40px 40px;
        }
        .bg-glow {
            position: fixed; z-index: 0; pointer-events: none; border-radius: 50%;
            filter: blur(100px); opacity: .45;
        }
        .bg-glow--1 { width: 600px; height: 600px; top: -10%; left: -5%;  background: rgba(46,196,182,.3); animation: glow-drift 18s ease-in-out infinite alternate; }
        .bg-glow--2 { width: 500px; height: 500px; bottom: -8%; right: -5%; background: rgba(26,107,181,.25); animation: glow-drift 22s ease-in-out infinite alternate-reverse; }
        .bg-glow--3 { width: 350px; height: 350px; top: 40%; left: 50%;  background: rgba(46,196,182,.15); animation: glow-drift 15s ease-in-out infinite alternate; }

        @@keyframes glow-drift {
            0%   { transform: translate(0, 0) scale(1); }
            100% { transform: translate(60px, -40px) scale(1.15); }
        }

        /* ── Top navbar ── */
        .top-nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 clamp(20px, 4vw, 60px); height: 70px;
            background: rgba(255,255,255,.72);
            backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);
            border-bottom: 1px solid rgba(26,107,181,.08);
            transition: box-shadow .3s;
        }
        .top-nav.scrolled { box-shadow: 0 4px 24px rgba(15,23,36,.08); }

        .nav-brand {
            display: flex; align-items: center; gap: 10px;
            text-decoration: none; font-weight: 800; font-size: 1.5rem;
            background: linear-gradient(135deg, var(--accent), var(--primary));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .nav-brand i { font-size: 1.3rem; }

        .nav-login {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 9px 24px; border-radius: 8px; font-weight: 600; font-size: .9rem;
            background: linear-gradient(135deg, var(--accent), var(--primary));
            color: #fff; text-decoration: none; border: none; cursor: pointer;
            transition: transform .25s, box-shadow .25s;
            box-shadow: 0 4px 16px rgba(26,107,181,.2);
        }
        .nav-login:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(26,107,181,.3); color: #fff; text-decoration: none; }

        /* ── Hero section ── */
        .hero {
            position: relative; z-index: 1;
            min-height: 100vh; display: grid;
            grid-template-columns: 1fr 1fr; gap: 60px;
            align-items: center; max-width: 1260px;
            margin: 0 auto; padding: 100px clamp(20px, 4vw, 60px) 60px;
        }

        /* Staggered entrance */
        .hero-left > * {
            opacity: 0; transform: translateY(30px);
            animation: fadeUp .7s ease forwards;
        }
        .hero-left > *:nth-child(1) { animation-delay: .15s; }
        .hero-left > *:nth-child(2) { animation-delay: .3s; }
        .hero-left > *:nth-child(3) { animation-delay: .45s; }
        .hero-left > *:nth-child(4) { animation-delay: .6s; }
        .hero-left > *:nth-child(5) { animation-delay: .75s; }
        .hero-left > *:nth-child(6) { animation-delay: .9s; }

        @@keyframes fadeUp {
            to { opacity: 1; transform: translateY(0); }
        }

        .badge-pill {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 6px 16px; border-radius: 50px; font-size: .82rem; font-weight: 600;
            background: rgba(46,196,182,.1); color: var(--primary-dark);
            border: 1px solid rgba(46,196,182,.2); margin-bottom: 20px;
            width: fit-content;
        }
        .badge-pill i { font-size: .7rem; animation: pulse-dot 2s ease-in-out infinite; }
        @@keyframes pulse-dot { 0%,100% { opacity: 1; } 50% { opacity: .3; } }

        .hero-title {
            font-size: clamp(2.2rem, 4vw, 3.2rem); font-weight: 800;
            line-height: 1.15; margin-bottom: 12px; color: var(--text);
        }
        .hero-title span {
            background: linear-gradient(135deg, var(--accent), var(--primary));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-sub {
            font-size: 1.1rem; color: var(--text-muted); line-height: 1.7;
            max-width: 480px; margin-bottom: 32px;
        }

        .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 48px; }

        .btn-primary-lg {
            display: inline-flex; align-items: center; gap: 10px;
            padding: 14px 36px; border-radius: 12px; font-weight: 700; font-size: 1.05rem;
            background: linear-gradient(135deg, var(--accent), var(--primary));
            color: #fff; text-decoration: none; border: none; cursor: pointer;
            transition: transform .3s, box-shadow .3s;
            box-shadow: 0 8px 28px rgba(26,107,181,.22);
            position: relative; overflow: hidden;
        }
        .btn-primary-lg:hover { transform: translateY(-3px); box-shadow: 0 14px 40px rgba(26,107,181,.32); color: #fff; text-decoration: none; }
        .btn-primary-lg::after {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,.25), transparent);
            transform: translateX(-100%); transition: transform .6s;
        }
        .btn-primary-lg:hover::after { transform: translateX(100%); }

        .btn-ghost {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 14px 28px; border-radius: 12px; font-weight: 600; font-size: 1.05rem;
            background: rgba(26,107,181,.06); color: var(--accent);
            text-decoration: none; border: 1px solid rgba(26,107,181,.15);
            transition: background .25s, border-color .25s;
        }
        .btn-ghost:hover { background: rgba(26,107,181,.12); border-color: rgba(26,107,181,.25); color: var(--accent); text-decoration: none; }

        /* Stats row */
        .hero-stats {
            display: flex; gap: 36px;
        }
        .hero-stat { display: flex; flex-direction: column; }
        .hero-stat strong {
            font-size: 1.6rem; font-weight: 800; color: var(--text);
            display: flex; align-items: baseline; gap: 4px;
        }
        .hero-stat strong span { font-size: .85rem; color: var(--primary); font-weight: 700; }
        .hero-stat small { font-size: .82rem; color: var(--text-muted); margin-top: 2px; }

        /* ── Dashboard mockup (right side) ── */
        .hero-right {
            position: relative; display: flex; align-items: center; justify-content: center;
            perspective: 1200px;
        }

        .mockup-wrapper {
            position: relative; width: 100%; max-width: 520px;
            opacity: 0; transform: translateY(40px) rotateY(-6deg);
            animation: mockup-in .9s ease .5s forwards;
        }
        @@keyframes mockup-in { to { opacity: 1; transform: translateY(0) rotateY(0); } }

        .mockup-card {
            background: var(--surface); border-radius: 18px;
            border: 1px solid rgba(26,107,181,.1);
            box-shadow: 0 20px 60px rgba(15,23,36,.1), 0 1px 3px rgba(15,23,36,.06);
            overflow: hidden;
        }

        /* Mockup top bar */
        .mock-topbar {
            display: flex; align-items: center; gap: 10px;
            padding: 14px 20px; border-bottom: 1px solid #eef2f7;
            background: linear-gradient(135deg, rgba(26,107,181,.03), rgba(46,196,182,.03));
        }
        .mock-dots { display: flex; gap: 6px; }
        .mock-dots span { width: 10px; height: 10px; border-radius: 50%; }
        .mock-dots span:nth-child(1) { background: #ef4444; }
        .mock-dots span:nth-child(2) { background: #f59e0b; }
        .mock-dots span:nth-child(3) { background: #10b981; }
        .mock-topbar-title { font-size: .78rem; font-weight: 600; color: var(--text-muted); margin-left: 8px; }

        .mock-body { padding: 20px; }

        /* Stat mini-cards row */
        .mock-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 18px; }
        .mock-stat {
            padding: 14px; border-radius: 10px; border: 1px solid #eef2f7;
            animation: stat-pop .5s ease forwards;
            opacity: 0; transform: scale(.9);
        }
        .mock-stat:nth-child(1) { animation-delay: .9s; }
        .mock-stat:nth-child(2) { animation-delay: 1.1s; }
        .mock-stat:nth-child(3) { animation-delay: 1.3s; }
        @@keyframes stat-pop { to { opacity: 1; transform: scale(1); } }

        .mock-stat-icon {
            width: 32px; height: 32px; border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: .85rem; margin-bottom: 8px;
        }
        .mock-stat-icon--blue { background: rgba(26,107,181,.1); color: var(--accent); }
        .mock-stat-icon--green { background: rgba(46,196,182,.1); color: var(--primary-dark); }
        .mock-stat-icon--amber { background: rgba(245,158,11,.1); color: #d97706; }

        .mock-stat-val { font-size: 1.15rem; font-weight: 700; color: var(--text); line-height: 1; }
        .mock-stat-label { font-size: .7rem; color: var(--text-muted); margin-top: 3px; }

        /* Chart area */
        .mock-chart-area {
            background: #f8fafc; border-radius: 12px; padding: 16px;
            border: 1px solid #eef2f7; margin-bottom: 14px;
        }
        .mock-chart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
        .mock-chart-header strong { font-size: .82rem; color: var(--text); }
        .mock-chart-header span { font-size: .7rem; color: var(--primary); font-weight: 600; padding: 3px 10px; background: rgba(46,196,182,.1); border-radius: 20px; }

        .mock-bars { display: flex; align-items: flex-end; gap: 8px; height: 90px; }
        .mock-bar {
            flex: 1; border-radius: 5px 5px 0 0; min-width: 0;
            transform-origin: bottom; transform: scaleY(0);
            animation: bar-grow .6s ease forwards;
        }
        .mock-bar:nth-child(1)  { animation-delay: 1.2s; height: 55%; background: rgba(26,107,181,.2); }
        .mock-bar:nth-child(2)  { animation-delay: 1.3s; height: 75%; background: rgba(26,107,181,.3); }
        .mock-bar:nth-child(3)  { animation-delay: 1.4s; height: 45%; background: rgba(46,196,182,.3); }
        .mock-bar:nth-child(4)  { animation-delay: 1.5s; height: 90%; background: linear-gradient(to top, var(--accent), var(--primary)); }
        .mock-bar:nth-child(5)  { animation-delay: 1.6s; height: 60%; background: rgba(46,196,182,.3); }
        .mock-bar:nth-child(6)  { animation-delay: 1.7s; height: 80%; background: rgba(26,107,181,.3); }
        .mock-bar:nth-child(7)  { animation-delay: 1.8s; height: 50%; background: rgba(46,196,182,.2); }
        .mock-bar:nth-child(8)  { animation-delay: 1.9s; height: 70%; background: rgba(26,107,181,.25); }

        @@keyframes bar-grow { to { transform: scaleY(1); } }

        /* Recent transactions */
        .mock-txn-header { font-size: .78rem; font-weight: 700; color: var(--text-muted); margin-bottom: 10px; text-transform: uppercase; letter-spacing: .4px; }
        .mock-txn {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 0; border-bottom: 1px solid #f1f5f9;
            opacity: 0; animation: fadeUp .4s ease forwards;
        }
        .mock-txn:last-child { border-bottom: none; }
        .mock-txn:nth-child(2) { animation-delay: 1.6s; }
        .mock-txn:nth-child(3) { animation-delay: 1.8s; }
        .mock-txn:nth-child(4) { animation-delay: 2.0s; }

        .mock-txn-dot {
            width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
        }
        .mock-txn-dot--green { background: #10b981; }
        .mock-txn-dot--blue  { background: var(--accent); }
        .mock-txn-dot--amber { background: #f59e0b; }
        .mock-txn-info { flex: 1; min-width: 0; }
        .mock-txn-name { font-size: .82rem; font-weight: 600; color: var(--text); }
        .mock-txn-cat  { font-size: .7rem; color: var(--text-muted); }
        .mock-txn-amt  { font-size: .85rem; font-weight: 700; }
        .mock-txn-amt--green { color: #10b981; }
        .mock-txn-amt--red   { color: #ef4444; }

        /* Floating cards */
        .float-card {
            position: absolute; z-index: 10;
            background: var(--surface); border-radius: 12px;
            padding: 12px 16px; border: 1px solid rgba(26,107,181,.1);
            box-shadow: 0 8px 24px rgba(15,23,36,.1);
            display: flex; align-items: center; gap: 10px;
            animation: float-bounce 5s ease-in-out infinite;
            opacity: 0;
        }
        .float-card--1 {
            top: 8%; right: -10px;
            animation-delay: 1.5s;
            animation: float-card-in .5s ease 1.5s forwards, float-bounce 5s ease-in-out 2s infinite;
        }
        .float-card--2 {
            bottom: 12%; left: -20px;
            animation-delay: 1.8s;
            animation: float-card-in .5s ease 1.8s forwards, float-bounce 5s ease-in-out 2.3s infinite;
        }

        @@keyframes float-card-in { to { opacity: 1; } }
        @@keyframes float-bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .float-card-icon {
            width: 36px; height: 36px; border-radius: 8px;
            display: flex; align-items: center; justify-content: center; font-size: .9rem;
        }
        .float-card-icon--green { background: rgba(16,185,129,.1); color: #10b981; }
        .float-card-icon--blue  { background: rgba(26,107,181,.1); color: var(--accent); }
        .float-card-text strong { display: block; font-size: .82rem; color: var(--text); }
        .float-card-text small  { font-size: .7rem; color: var(--text-muted); }

        /* ── Features row ── */
        .features {
            position: relative; z-index: 1; max-width: 1260px;
            margin: 0 auto; padding: 0 clamp(20px, 4vw, 60px) 80px;
            display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
        }
        .feat {
            background: var(--surface); border-radius: 14px;
            padding: 24px; border: 1px solid rgba(26,107,181,.08);
            transition: transform .3s, box-shadow .3s;
            opacity: 0; transform: translateY(20px);
            animation: fadeUp .5s ease forwards;
        }
        .feat:nth-child(1) { animation-delay: 1.2s; }
        .feat:nth-child(2) { animation-delay: 1.35s; }
        .feat:nth-child(3) { animation-delay: 1.5s; }
        .feat:nth-child(4) { animation-delay: 1.65s; }
        .feat:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(15,23,36,.08); }

        .feat-icon {
            width: 44px; height: 44px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; margin-bottom: 14px;
        }
        .feat-icon--blue  { background: rgba(26,107,181,.1); color: var(--accent); }
        .feat-icon--green { background: rgba(46,196,182,.1); color: var(--primary-dark); }
        .feat-icon--amber { background: rgba(245,158,11,.1); color: #d97706; }
        .feat-icon--rose  { background: rgba(239,68,68,.08); color: #ef4444; }

        .feat h4 { font-size: .92rem; font-weight: 700; color: var(--text); margin-bottom: 6px; }
        .feat p  { font-size: .82rem; color: var(--text-muted); line-height: 1.6; }

        /* ── Responsive ── */
        @@media (max-width: 1024px) {
            .hero { grid-template-columns: 1fr; gap: 40px; text-align: center; padding-top: 110px; }
            .hero-left > * { margin-left: auto; margin-right: auto; }
            .hero-sub { margin-left: auto; margin-right: auto; }
            .hero-actions { justify-content: center; }
            .hero-stats { justify-content: center; }
            .hero-right { order: -1; }
            .mockup-wrapper { max-width: 440px; }
            .float-card { display: none; }
            .features { grid-template-columns: repeat(2, 1fr); }
        }

        @@media (max-width: 576px) {
            .hero { padding-top: 90px; gap: 30px; }
            .hero-title { font-size: 1.9rem; }
            .hero-stats { gap: 20px; }
            .hero-stat strong { font-size: 1.3rem; }
            .mock-stats { grid-template-columns: 1fr; }
            .features { grid-template-columns: 1fr; }
            .btn-ghost { display: none; }
        }
    </style>
</head>
<body>
    <!-- Background effects -->
    <div class="bg-grid"></div>
    <div class="bg-glow bg-glow--1"></div>
    <div class="bg-glow bg-glow--2"></div>
    <div class="bg-glow bg-glow--3"></div>

    <!-- Top navbar removed -->

    <!-- Hero -->
    <section class="hero">
        <div class="hero-left">
            <div class="badge-pill">
                <i class="fas fa-circle"></i> Corporate Expense Management
            </div>

            <h1 class="hero-title">
                Take Control of<br>
                Your <span>Company Expenses</span>
            </h1>

            <p class="hero-sub">
                Submit, track, and approve expense reports in real time.
                Smart budget monitoring and multi-level approvals keep your finances on track.
            </p>

            <div class="hero-actions">
                <a href="/Identity/Account/Login" class="btn-primary-lg">
                    Login to Dashboard
                </a>
                <a href="#features" class="btn-ghost">
                    See How It Works
                </a>
            </div>

            <div class="hero-stats">
                <div class="hero-stat">
                    <strong>98<span>%</span></strong>
                    <small>Faster Approvals</small>
                </div>
                <div class="hero-stat">
                    <strong>₱2.4<span>M+</span></strong>
                    <small>Expenses Tracked</small>
                </div>
                <div class="hero-stat">
                    <strong>5<span>Roles</span></strong>
                    <small>Multi-Level Access</small>
                </div>
            </div>
        </div>

        <div class="hero-right">
            <div class="mockup-wrapper">
                <!-- Floating accent cards -->
                <div class="float-card float-card--1">
                    <div class="float-card-icon float-card-icon--green"><i class="fas fa-check"></i></div>
                    <div class="float-card-text">
                        <strong>Report Approved</strong>
                        <small>Just now &middot; Manager</small>
                    </div>
                </div>
                <div class="float-card float-card--2">
                    <div class="float-card-icon float-card-icon--blue"><i class="fas fa-receipt"></i></div>
                    <div class="float-card-text">
                        <strong>₱12,450.00</strong>
                        <small>New expense submitted</small>
                    </div>
                </div>

                <div class="mockup-card">
                    <div class="mock-topbar">
                        <div class="mock-dots"><span></span><span></span><span></span></div>
                        <span class="mock-topbar-title">CEMS &mdash; Manager Dashboard</span>
                    </div>
                    <div class="mock-body">
                        <!-- Mini stat cards -->
                        <div class="mock-stats">
                            <div class="mock-stat">
                                <div class="mock-stat-icon mock-stat-icon--blue"><i class="fas fa-file-invoice"></i></div>
                                <div class="mock-stat-val">24</div>
                                <div class="mock-stat-label">Pending Reports</div>
                            </div>
                            <div class="mock-stat">
                                <div class="mock-stat-icon mock-stat-icon--green"><i class="fas fa-check-double"></i></div>
                                <div class="mock-stat-val">156</div>
                                <div class="mock-stat-label">Approved</div>
                            </div>
                            <div class="mock-stat">
                                <div class="mock-stat-icon mock-stat-icon--amber"><i class="fas fa-coins"></i></div>
                                <div class="mock-stat-val">₱84K</div>
                                <div class="mock-stat-label">This Month</div>
                            </div>
                        </div>

                        <!-- Chart -->
                        <div class="mock-chart-area">
                            <div class="mock-chart-header">
                                <strong>Monthly Expenses</strong>
                                <span>+12% vs last month</span>
                            </div>
                            <div class="mock-bars">
                                <div class="mock-bar"></div>
                                <div class="mock-bar"></div>
                                <div class="mock-bar"></div>
                                <div class="mock-bar"></div>
                                <div class="mock-bar"></div>
                                <div class="mock-bar"></div>
                                <div class="mock-bar"></div>
                                <div class="mock-bar"></div>
                            </div>
                        </div>

                        <!-- Transactions -->
                        <div class="mock-txn-header">Recent Activity</div>
                        <div class="mock-txn">
                            <div class="mock-txn-dot mock-txn-dot--green"></div>
                            <div class="mock-txn-info">
                                <div class="mock-txn-name">Fuel Reimbursement</div>
                                <div class="mock-txn-cat">Transportation</div>
                            </div>
                            <div class="mock-txn-amt mock-txn-amt--green">₱3,200</div>
                        </div>
                        <div class="mock-txn">
                            <div class="mock-txn-dot mock-txn-dot--blue"></div>
                            <div class="mock-txn-info">
                                <div class="mock-txn-name">Hotel Booking</div>
                                <div class="mock-txn-cat">Accommodation</div>
                            </div>
                            <div class="mock-txn-amt mock-txn-amt--red">₱8,500</div>
                        </div>
                        <div class="mock-txn">
                            <div class="mock-txn-dot mock-txn-dot--amber"></div>
                            <div class="mock-txn-info">
                                <div class="mock-txn-name">Office Supplies</div>
                                <div class="mock-txn-cat">Miscellaneous</div>
                            </div>
                            <div class="mock-txn-amt mock-txn-amt--red">₱1,750</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

