@{
    ViewData["Title"] = "Expense Overview";
    Layout = "~/Views/Shared/_CEOLayout.cshtml";
    var reports = ViewBag.Reports as List<CEMS.Models.PendingExpenseReportDto> ?? new List<CEMS.Models.PendingExpenseReportDto>();
    var currentUserName = User?.Identity?.Name ?? "Unknown";
    // Safely handle FilterStart/FilterEnd which may be string or DateTime
    object rawStart = ViewBag.FilterStart;
    object rawEnd = ViewBag.FilterEnd;
    string filterStart;
    string filterEnd;
    if (rawStart is DateTime ds) filterStart = ds.ToString("yyyy-MM-dd"); else filterStart = rawStart as string ?? DateTime.UtcNow.ToString("yyyy-MM-01");
    if (rawEnd is DateTime de) filterEnd = de.ToString("yyyy-MM-dd"); else filterEnd = rawEnd as string ?? DateTime.UtcNow.ToString("yyyy-MM-dd");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<style>
    .summary-section {
        padding: 16px 20px;
        background: #f8fafc;
        border-top: 1px solid var(--d-border);
    }

    .export-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #1a6bb5; /* blue */
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 8px 16px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
    }

    .export-btn:hover {
        background: #155a9a; /* darker blue */
        transform: translateY(-1px);
        box-shadow: 0 2px 8px rgba(26, 107, 181, 0.2);
    }

    /* Compact export adjustments (applied during export) */
    .export-compact .dash-table th,
    .export-compact .dash-table td {
        padding: 4px !important;
        font-size: 10px !important;
    }
    .cat-truncate {
        max-width: 220px;
        display: inline-block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        vertical-align: middle;
    }
    .export-compact .page-subtitle { font-size: 12px !important; }

    /* Add a small right margin so the table doesn't touch the edge when exported */
    .table-card { margin-right: 18px; }

    /* Export metadata shown only during export */
    .export-metadata { display: none; font-size: 0.95rem; color: var(--d-muted); margin-bottom: 8px; }

    @@media print {
        body, html { background: #fff !important; }
        nav, header, footer, .no-print, .export-btn { display: none !important; }
        .page-wrapper { padding: 0 !important; min-height: auto !important; }
        .filter-card { display: none !important; }
        .container-fluid { padding: 0 !important; }
        .page-title { font-size: 1.3rem !important; }
        .dash-table { width: 100% !important; border-collapse: collapse !important; }
        .dash-table th, .dash-table td { border: 1px solid #ddd !important; padding: 8px !important; text-align: left !important; }
        .dash-table th { background: #f8fafc !important; font-weight: bold !important; }
    }

    /* helper to hide cells only during PDF generation via JS toggling */
    .hide-for-pdf { display: none !important; }

    /* Quick filter active state */
    .quick-filter .btn.active {
        /* Match CEO dashboard active filter appearance */
        background: #0288d1 !important;
        color: #fff !important;
        border-color: #01579b !important;
        box-shadow: 0 2px 8px rgba(2,136,209,0.3) !important;
    }
   /* Controls Bottom - Modern Pagination */
    .controls-bottom {
        margin-top: 40px;
        padding: 12px 0;
        background: transparent;
        border: none;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .controls-pagination {
        margin: 0;
    }

    .controls-pagination .pagination {
        margin: 0;
        gap: 4px;
        align-items: center;
    }

    .controls-pagination .page-item {
        margin: 0;
    }

    .controls-pagination .page-link {
        color: var(--d-primary);
        border-color: var(--d-border);
        background: var(--d-card);
        font-size: 0.9rem;
        padding: 8px 11px;
        min-width: 40px;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        border-radius: 6px;
        transition: all 0.2s ease;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    }

    .controls-pagination .page-link:hover:not(.disabled) {
        background: rgba(26, 107, 181, 0.08);
        color: #155a9a;
        border-color: var(--d-primary);
        transform: translateY(-1px);
        box-shadow: 0 2px 4px rgba(26, 107, 181, 0.15);
    }

    body.dark-mode .controls-pagination .page-link {
        background: #2d3748;
    }

    body.dark-mode .controls-pagination .page-link:hover:not(.disabled) {
        background: rgba(46, 196, 182, 0.12);
        color: #5eead4;
    }

    .controls-pagination .page-item.disabled .page-link {
        background: #f1f5f9;
        color: #cbd5e1;
        cursor: not-allowed;
        box-shadow: none;
    }

    body.dark-mode .controls-pagination .page-item.disabled .page-link {
        background: #374151;
        color: #6b7280;
    }

    .controls-pagination .page-item.active .page-link {
        background: linear-gradient(135deg, var(--d-primary) 0%, #0a5a9f 100%);
        border-color: var(--d-primary);
        color: white;
        font-weight: 700;
        box-shadow: 0 2px 8px rgba(26, 107, 181, 0.3);
    }

    .controls-pagination .page-item.active .page-link:hover {
        background: linear-gradient(135deg, #155a9a 0%, #094085 100%);
    }

    .pagination-info {
        font-size: 0.85rem;
        color: var(--d-muted);
        transition: color 0.3s ease;
    }

    
</style>

<div class="page-wrapper">
    <div class="container-fluid px-4">
        <div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 16px;">
            <div>
                @* <h1 class="page-title">
                    <i class="bi bi-receipt"></i>
                    Expense Overview
                </h1> *@
                <p class="page-subtitle">View all expenses across the organization.</p>
            </div>
            <button onclick="downloadExpenseOverviewPDF()" class="export-btn no-print">
                 Export PDF
            </button>
            <div class="export-metadata no-print" id="exportMetadata">Exported by: <strong>@currentUserName</strong> on <strong id="exportTimestamp"></strong></div>
        </div>

        <!-- Quick Filter & Date Range -->
        <div class="filter-card">
            <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap; justify-content: space-between;">
                <div style="display: flex; gap: 8px; align-items: flex-end; flex-wrap: wrap;">
                    <div style="flex: 1; min-width: 160px;">
                        <label class="small text-muted" style="font-weight: 600; margin-bottom: 4px; display: block;">From</label>
                        <input type="date" id="expenseStart" value="@filterStart" />
                    </div>
                    <div style="flex: 1; min-width: 160px;">
                        <label class="small text-muted" style="font-weight: 600; margin-bottom: 4px; display: block;">To</label>
                        <input type="date" id="expenseEnd" value="@filterEnd" />
                    </div>
                </div>
                <div style="display: flex; gap: 6px; align-items: center;">
                    <div class="quick-filter">
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-range="today">Today</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-range="week">Week</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-range="month">Month</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-range="year">Year</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Results -->
        @if (reports.Any())
        {
            <div class="table-card">
                <div class="table-responsive">
                    <table class="dash-table" id="ceoExpenseTable">
                        <thead>
                            <tr>
                                <th>Report #</th>
                                <th>Driver</th>
                                <th>Category</th>
                                <th>Total Amount</th>
                                <th>Submitted</th>
                                <th>Status</th>
                                <th>Budget Check</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var dto in reports)
                            {
                                var r = dto.Report;
                                <tr>
                                    <td><strong>#@r.Id</strong></td>
                                    <td>@(dto.UserName ?? "Unknown")</td>
                                    <td>
                                        @{
                                            var cats = r.Items?.Select(i => i.Category ?? string.Empty).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct();
                                            var catText = cats != null && cats.Any() ? string.Join(", ", cats) : "-";
                                        }
                                        <div class="cat-truncate" title="@catText">@catText</div>
                                    </td>
                                    <td class="fw-bold">₱@r.TotalAmount.ToString("N2")</td>
                                    <td>@r.SubmissionDate.ToLocalTime().ToString("MMM d, yyyy")</td>
                                    <td>
                                        @switch (r.Status)
                                        {
                                            case CEMS.Models.ReportStatus.Approved:
                                                <span class="status-text">Approved</span>
                                                break;
                                            case CEMS.Models.ReportStatus.Rejected:
                                                <span class="status-text">Rejected</span>
                                                break;
                                            case CEMS.Models.ReportStatus.PendingCEOApproval:
                                                <span class="status-text">Pending CEO</span>
                                                break;
                                            default:
                                                <span class="status-text">Submitted</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        <span class="status-text">
                                            @if (r.BudgetCheck == CEMS.Models.BudgetCheckStatus.OverBudget)
                                            {
                                                <span>Over Budget</span>
                                            }
                                            else
                                            {
                                                <span>Within Budget</span>
                                            }
                                        </span>
                                    </td>

                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Summary -->
                <div class="summary-section">
                    <div class="row">
                        <div class="col-md-4">
                            <small style="color: var(--d-muted);">Total Amount (filtered):</small>
                            <div style="font-weight: 700; font-size: 1.1rem; color: var(--d-text);">₱@reports.Sum(r => r.Report.TotalAmount).ToString("N2")</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="controls-bottom" id="ceoExpensePagination"></div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p>No expense reports found matching the selected filters.</p>
            </div>
        }
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
    function downloadExpenseOverviewPDF() {
        const element = document.querySelector('.page-wrapper');
        const opt = {
            margin: [6, 6, 6, 6], // smaller margins to fit more data
            filename: 'Expense_Overview_' + new Date().toISOString().slice(0, 10) + '.pdf',
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2 },
            jsPDF: { orientation: 'landscape', unit: 'mm', format: 'a4' }
        };

        // Hide non-essential elements temporarily
        const filterCard = document.querySelector('.filter-card');
        const exportBtn = document.querySelector('.export-btn');
        const exportMeta = document.getElementById('exportMetadata');
        const actionCells = document.querySelectorAll('#ceoExpenseTable th:last-child, #ceoExpenseTable td:last-child');

        if (filterCard) filterCard.style.display = 'none';
        if (exportBtn) exportBtn.style.display = 'none';
        if (exportMeta) exportMeta.style.display = 'block';
        if (actionCells) actionCells.forEach(function(c){ c.classList.add('hide-for-pdf'); });

        // compact + blue theme for PDF
        if (element) element.classList.add('export-compact');
        if (element) element.classList.add('pdf-blue');


        // Generate PDF
        html2pdf().set(opt).from(element).save().then(() => {
            // Restore visibility
            if (filterCard) filterCard.style.display = '';
            if (exportBtn) exportBtn.style.display = '';
            if (exportMeta) exportMeta.style.display = 'none';
            if (actionCells) actionCells.forEach(function(c){ c.classList.remove('hide-for-pdf'); });
            if (element) element.classList.remove('export-compact');
            if (element) element.classList.remove('pdf-blue');
        }).catch(err => {
            console.error('PDF export failed', err);
            if (filterCard) filterCard.style.display = '';
            if (exportBtn) exportBtn.style.display = '';
            if (exportMeta) exportMeta.style.display = 'none';
            if (actionCells) actionCells.forEach(function(c){ c.classList.remove('hide-for-pdf'); });
            if (element) element.classList.remove('export-compact');
            if (element) element.classList.remove('pdf-blue');
        });
    }

    // auto-apply filters on this page
    document.addEventListener('DOMContentLoaded', function(){
        var start = document.getElementById('expenseStart');
        var end = document.getElementById('expenseEnd');
        var quickButtons = document.querySelectorAll('.quick-filter [data-range]');

        var selectedRange = null; // persist which quick-range was chosen
        function apply(){
            var s = start?.value || ''; var e = end?.value || ''; var qs = [];
            if(s) qs.push('start=' + encodeURIComponent(s)); if(e) qs.push('end=' + encodeURIComponent(e));
            if(selectedRange) qs.push('range=' + encodeURIComponent(selectedRange));
            var url = '@Url.Action("ExpenseOverview","CEO")' + (qs.length ? ('?' + qs.join('&')) : '');
            window.location.href = url;
        }

        // debounce for manual date changes
        var _deb;
        [start,end].forEach(function(el){
            if(!el) return;
            el.addEventListener('change', function(){
                // manual change clears any selected quick-range
                selectedRange = null;
                if(_deb) clearTimeout(_deb);
                _deb = setTimeout(apply, 250);
            });
        });

        // Quick button clicks: set dates, mark active and navigate immediately
        quickButtons.forEach(function(btn){
            btn.addEventListener('click', function(){
                quickButtons.forEach(function(b){ b.classList.remove('active'); });
                this.classList.add('active');
                var range = this.getAttribute('data-range');
                selectedRange = range;
                var now = new Date(); var sdate;
                if(range==='today') sdate = new Date(now.getFullYear(), now.getMonth(), now.getDate());
                else if(range==='week') sdate = new Date(now.getFullYear(), now.getMonth(), now.getDate() - now.getDay());
                else if(range==='month') sdate = new Date(now.getFullYear(), now.getMonth(), 1);
                else if(range==='year') sdate = new Date(now.getFullYear(), 0, 1);
                if(start && sdate) start.value = sdate.toISOString().slice(0,10);
                if(end) end.value = now.toISOString().slice(0,10);
                apply();
            });
        });

        // If URL has start/end params, ensure inputs reflect them (useful after redirect)
        try {
            var params = new URLSearchParams(window.location.search);
            if(params.get('start')) start.value = params.get('start');
            if(params.get('end')) end.value = params.get('end');
            // if URL includes explicit range param, mark that button active
            if(params.get('range')){
                var r = params.get('range'); selectedRange = r;
                var btn = document.querySelector('.quick-filter [data-range="' + r + '"]');
                if(btn) { document.querySelectorAll('.quick-filter [data-range]').forEach(function(b){ b.classList.remove('active'); }); btn.classList.add('active'); }
            }
        } catch(e) { /* ignore */ }

        // Highlight the quick filter that matches current range (compare ISO date strings)
        function highlightMatchingRange(){
            if(!start || !end) return;
            var s = start.value; var e = end.value; if(!s || !e) return;
            quickButtons.forEach(function(b){ b.classList.remove('active'); });
            var now = new Date();
            function iso(d){ return new Date(d.getFullYear(), d.getMonth(), d.getDate()).toISOString().slice(0,10); }
            var today = iso(now);
            if (s === today && e === today) { document.querySelector('.quick-filter [data-range="today"]').classList.add('active'); return; }
            var weekStart = iso(new Date(now.getFullYear(), now.getMonth(), now.getDate() - now.getDay()));
            if (s === weekStart && e === today) { document.querySelector('.quick-filter [data-range="week"]').classList.add('active'); return; }
            var monthStart = iso(new Date(now.getFullYear(), now.getMonth(), 1));
            if (s === monthStart && e === today) { document.querySelector('.quick-filter [data-range="month"]').classList.add('active'); return; }
            var yearStart = iso(new Date(now.getFullYear(), 0, 1));
            if (s === yearStart && e === today) { document.querySelector('.quick-filter [data-range="year"]').classList.add('active'); return; }
        }
        highlightMatchingRange();
    });
</script>

<script>
    (function(){
    var PAGE_SIZE = 10;
    var table = document.getElementById('ceoExpenseTable');
    if(!table) return;
    var rows = Array.from(table.querySelectorAll('tbody tr'));
    // Always compute at least 1 page so pagination UI is rendered consistently
    var totalPages = Math.max(1, Math.ceil(rows.length / PAGE_SIZE));
    var currentPage = 1;

    function renderPage(page){
        currentPage = page;
        rows.forEach(function(r,i){
            r.style.display = (i >= (page-1)*PAGE_SIZE && i < page*PAGE_SIZE) ? '' : 'none';
        });
        renderPaginationControls();
    }

    function renderPaginationControls(){
        var container = document.getElementById('ceoExpensePagination');
        if(!container) return;
        var startP = Math.max(1, currentPage - 2);
        var endP = Math.min(totalPages, currentPage + 2);
        var html = '<nav aria-label="Report pages" class="controls-pagination"><ul class="pagination mb-0">';
        html += '<li class="page-item '+(currentPage===1?'disabled':'')+'"><a class="page-link" href="#" data-page="'+(currentPage-1)+'"><i class="bi bi-chevron-left"></i> Prev</a></li>';
        if(startP > 1){
            html += '<li class="page-item"><a class="page-link" href="#" data-page="1">1</a></li>';
            if(startP > 2) html += '<li class="page-item disabled"><span class="page-link">...</span></li>';
        }
        for(var p=startP;p<=endP;p++){
            html += '<li class="page-item '+(p===currentPage?'active':'')+'"><a class="page-link" href="#" data-page="'+p+'">'+p+'</a></li>';
        }
        if(endP < totalPages){
            if(endP < totalPages-1) html += '<li class="page-item disabled"><span class="page-link">...</span></li>';
            html += '<li class="page-item"><a class="page-link" href="#" data-page="'+totalPages+'">'+totalPages+'</a></li>';
        }
        html += '<li class="page-item '+(currentPage===totalPages?'disabled':'')+'"><a class="page-link" href="#" data-page="'+(currentPage+1)+'">Next <i class="bi bi-chevron-right"></i></a></li>';
        html += '</ul></nav>';
        html += '<div class="pagination-info">Page <strong>'+currentPage+'</strong> of <strong>'+totalPages+'</strong> ('+rows.length+' records)</div>';
        container.innerHTML = html;
        container.querySelectorAll('a[data-page]').forEach(function(a){
            a.addEventListener('click', function(e){
                e.preventDefault();
                var pg = parseInt(this.getAttribute('data-page'));
                if(pg >= 1 && pg <= totalPages) renderPage(pg);
            });
        });
    }

    renderPage(1);
})();
</script>
