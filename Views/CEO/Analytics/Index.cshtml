@{
    ViewData["Title"] = "Financial Reports & Analytics";
    Layout = "~/Views/Shared/_CEOLayout.cshtml";

    // ViewBag.Budgets may be passed as a List<Budget> or as an anonymous/dynamic projection from the controller.
    // Normalize into three lists for use in charts and tables: labels, allocated, spent.
    var budgetsEnum = ViewBag.Budgets as System.Collections.IEnumerable ?? new List<object>();
    var budgetLabels = new List<string>();
    var budgetAllocated = new List<decimal>();
    var budgetSpent = new List<decimal>();
    var budgetIsActive = new List<bool>();

    foreach (var bi in budgetsEnum)
    {
        if (bi == null) continue;
        var t = bi.GetType();
        var cat = t.GetProperty("Category")?.GetValue(bi)?.ToString() ?? "";
        var allocObj = t.GetProperty("Allocated")?.GetValue(bi);
        var spentObj = t.GetProperty("Spent")?.GetValue(bi);
        var activeObj = t.GetProperty("IsActive")?.GetValue(bi);

        decimal alloc = 0m;
        decimal spent = 0m;
        bool isActive = true;

        if (allocObj != null)
        {
            try { alloc = Convert.ToDecimal(allocObj); } catch { alloc = 0m; }
        }
        if (spentObj != null)
        {
            try { spent = Convert.ToDecimal(spentObj); } catch { spent = 0m; }
        }
        if (activeObj != null)
        {
            try { isActive = Convert.ToBoolean(activeObj); } catch { isActive = true; }
        }

        budgetLabels.Add(cat);
        budgetAllocated.Add(alloc);
        budgetSpent.Add(spent);
        budgetIsActive.Add(isActive);
    }

    int totalReports = ViewBag.TotalReports ?? 0;
    int approvedCount = ViewBag.ApprovedCount ?? 0;
    int rejectedCount = ViewBag.RejectedCount ?? 0;
    int pendingCount = ViewBag.PendingCount ?? 0;
    decimal monthlyReimbursed = ViewBag.MonthlyReimbursed ?? 0m;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<style>
    .chart-card {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 10px;
        overflow: hidden;
    }

    .chart-card-head {
        background: #f8fafc;
        padding: 16px 18px;
        border-bottom: 1px solid var(--d-border);
        font-weight: 600;
        color: var(--d-text);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .chart-card-body {
        padding: 20px;
    }

    .export-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #1a6bb5; /* blue */
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 8px 16px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
    }

    .export-btn:hover {
        background: #155a9a; /* darker blue */
        transform: translateY(-1px);
        box-shadow: 0 2px 8px rgba(26, 107, 181, 0.2);
    }

    .table-card-head {
        background: #f8fafc;
        padding: 16px 18px;
        border-bottom: 1px solid var(--d-border);
        font-weight: 600;
        color: var(--d-text);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .empty-text {
        color: var(--d-muted);
        text-align: center;
        padding: 20px;
    }

    @@media print {
        body, html { background: #fff !important; }
        nav, header, footer, .no-print, .export-btn { display: none !important; }
        .page-wrapper { padding: 0 !important; min-height: auto !important; }
        .stat-card { break-inside: avoid; border: 1px solid #ddd !important; }
        .chart-card, .table-card { break-inside: avoid; border: 1px solid #ddd !important; }
        .container-fluid { padding: 0 !important; }
        .page-title { font-size: 1.3rem !important; }
        canvas { max-height: 250px !important; }
    }
</style>

<div class="page-wrapper">
    <div class="container-fluid px-4">
        <div class="page-header d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                @* <h1 class="page-title">
                    <i class="bi bi-bar-chart"></i>
                    Financial Reports & Analytics
                </h1> *@
                <p class="page-subtitle">Summarized expense and budget reports with charts and trends.</p>
            </div>
            <div style="display:flex;gap:10px;align-items:center;">
                <form id="analyticsFilters" class="d-flex gap-2 no-print">
                    <input type="date" id="analyticsStart" name="start" class="form-control form-control-sm" value="@(ViewBag.FilterStart ?? new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1).ToString("yyyy-MM-dd"))" />
                    <input type="date" id="analyticsEnd" name="end" class="form-control form-control-sm" value="@(ViewBag.FilterEnd ?? DateTime.UtcNow.ToString("yyyy-MM-dd"))" />
                    @* Apply is automatic on change; no button required *@
                </form>
                <button id="exportPdfBtn" class="export-btn no-print">
                     Export PDF
                </button>
            </div>
        </div>

        <!-- Charts -->
        <div class="row g-3 mb-4">
            <div class="col-lg-6">
                <div class="chart-card">
                    <div class="chart-card-head">
                        <i class="bi bi-bar-chart"></i>
                        Budget Usage by Category
                    </div>
                    <div class="chart-card-body">
                        <canvas id="budgetChart" height="300"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="chart-card">
                    <div class="chart-card-head">
                        <i class="bi bi-pie-chart"></i>
                        Report Status Distribution
                    </div>
                    <div class="chart-card-body">
                        <canvas id="statusChart" height="300"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Monthly Trend -->
        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="chart-card">
                    <div class="chart-card-head">
                        <i class="bi bi-graph-up"></i>
                        Monthly Expense Trend (Last 6 Months)
                    </div>
                    <div class="chart-card-body">
                        <canvas id="trendChart" height="200"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Budget Summary Table -->
        <div class="table-card">
            <div class="table-card-head">
                <i class="bi bi-table"></i>
                Budget Summary
            </div>
            @if (budgetLabels.Count > 0)
            {
                <div class="table-responsive">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th>Allocated</th>
                                <th>Spent</th>
                                <th>Remaining</th>
                                <th>Usage</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < budgetLabels.Count; i++)
                            {
                                var cat = budgetLabels[i] ?? "";
                                var alloc = budgetAllocated.Count > i ? budgetAllocated[i] : 0m;
                                var spent = budgetSpent.Count > i ? budgetSpent[i] : 0m;
                                var remaining = alloc - spent;
                                var pct = alloc == 0 ? 0 : (int)Math.Round((double)(spent / alloc * 100));
                                var barClass = pct >= 100 ? "budget-bar-fill--danger" : pct >= 75 ? "budget-bar-fill--warn" : "budget-bar-fill--ok";
                                <tr>
                                    <td class="fw-600">@cat</td>
                                    <td>₱@alloc.ToString("N2")</td>
                                    <td>₱@spent.ToString("N2")</td>
                                    <td class="@(remaining < 0 ? "fw-bold" : "")">
                                        <span style="color: @(remaining < 0 ? "#ef4444" : "#0d8b7d");">₱@remaining.ToString("N2")</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="budget-bar" style="flex: 1; min-width: 80px;">
                                                <div class="budget-bar-fill @barClass" style="width:@Math.Min(pct, 100)%"></div>
                                            </div>
                                            <span style="font-weight: 600; font-size: 0.85rem;">@pct%</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-text">
                    <p>No budget data available.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script>
    // Budget usage chart - use normalized budget lists prepared in Razor to avoid relying on specific ViewBag shape
    const budgetCtx = document.getElementById('budgetChart').getContext('2d');
    new Chart(budgetCtx, {
        type: 'bar',
        data: {
            labels: [@Html.Raw(System.Text.Json.JsonSerializer.Serialize(budgetLabels))].flat().map(s => s),
            datasets: [
                {
                    label: 'Allocated',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(budgetAllocated)),
                    backgroundColor: 'rgba(26, 107, 181, 0.6)',
                    borderColor: 'rgba(26, 107, 181, 1)',
                    borderWidth: 1
                },
                {
                    label: 'Spent',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(budgetSpent)),
                    backgroundColor: 'rgba(239, 68, 68, 0.6)',
                    borderColor: 'rgba(239, 68, 68, 1)',
                    borderWidth: 1
                }
            ]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'top' } } }
    });

    // Status distribution chart - use server-provided counts (safely serialized)
    const statusCtx = document.getElementById('statusChart').getContext('2d');
    new Chart(statusCtx, {
        type: 'doughnut',
        data: {
            labels: ['Approved', 'Rejected', 'Pending'],
            datasets: [{
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new[]{ approvedCount, rejectedCount, pendingCount })),
                backgroundColor: ['rgba(16, 185, 129, 0.7)', 'rgba(239, 68, 68, 0.7)', 'rgba(245, 158, 11, 0.7)'],
                borderColor: '#ffffff',
                borderWidth: 2
            }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
    });

    // Monthly trend chart (loaded via API). Also provide an export that includes chart images.
    async function loadTrend() {
        try {
            // NOTE: use the actual controller action that returns JSON for dashboard/metrics data.
            // The controller provides categoryLabels/categoryAllocated/categorySpent and trendLabels/trendData.
            const res = await fetch('@Url.Action("GetDashboardData", "CEO")' + window.location.search);
            if (!res.ok) throw new Error('Metrics endpoint failed: ' + res.status);
            const data = await res.json();

            // Normalize monthly data from controller's trendLabels/trendData (controller returns trendLabels & trendData)
            let monthlyData = [];
            if (Array.isArray(data.trendLabels) && Array.isArray(data.trendData)) {
                monthlyData = data.trendLabels.map((label, i) => ({ label: label, total: Number(data.trendData[i] || 0) }));
            } else if (Array.isArray(data.monthlyData)) {
                // backward compatibility if endpoint uses monthlyData
                monthlyData = data.monthlyData.map(m => ({ label: m.label, total: Number(m.total || 0) }));
            }

            const trendCtx = document.getElementById('trendChart').getContext('2d');
            const trendChart = new Chart(trendCtx, {
                type: 'line',
                data: {
                    labels: monthlyData.map(m => m.label),
                    datasets: [{
                        label: 'Monthly Expenses (₱)',
                        data: monthlyData.map(m => m.total),
                        borderColor: 'rgba(26, 107, 181, 1)',
                        backgroundColor: 'rgba(26, 107, 181, 0.1)',
                        fill: true,
                        tension: 0.3,
                        pointBackgroundColor: 'rgba(26, 107, 181, 1)',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'top' } } }
            });

            // Build budgetsData from API response if available, otherwise fallback to server-side Razor arrays
            let budgetsData = [];
            if (Array.isArray(data.categoryLabels) && Array.isArray(data.categoryAllocated) && Array.isArray(data.categorySpent)) {
                budgetsData = data.categoryLabels.map((cat, i) => ({
                    Category: cat || 'Unspecified',
                    Allocated: Number(data.categoryAllocated[i] || 0),
                    Spent: Number(data.categorySpent[i] || 0)
                }));
            } else if (Array.isArray(data.budgets)) {
                budgetsData = data.budgets.map(b => ({ Category: b.Category || 'Unspecified', Allocated: Number(b.Allocated || 0), Spent: Number(b.Spent || 0) }));
            } else {
                // fallback to server-side serialized arrays prepared by Razor (safe JSON literals)
                try {
                    const fallbackLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(budgetLabels));
                    const fallbackAllocs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(budgetAllocated));
                    const fallbackSpents = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(budgetSpent));
                    for (let i = 0; i < Math.max(fallbackLabels.length, fallbackAllocs.length, fallbackSpents.length); i++) {
                        budgetsData.push({
                            Category: fallbackLabels[i] || 'Unspecified',
                            Allocated: Number(fallbackAllocs[i] || 0),
                            Spent: Number(fallbackSpents[i] || 0)
                        });
                    }
                } catch (e) {
                    budgetsData = [];
                }
            }

            // Expose export button to produce a text-only summary PDF (no graphs)
            const exportBtn = document.getElementById('exportPdfBtn');
            if (exportBtn) {
                exportBtn.addEventListener('click', function () {
                    try {
                        const { jsPDF } = window.jspdf;
                        const doc = new jsPDF('p', 'pt', 'a4');
                        const pageWidth = doc.internal.pageSize.getWidth();
                        const margin = 40;
                        let y = margin;

                        doc.setFontSize(16);
                        doc.text('CEMS - Analytics Summary', margin, y);
                        doc.setFontSize(10);
                        y += 18;
                        doc.text('Generated: ' + new Date().toLocaleString(), margin, y);
                        y += 18;

                        // Top-level counts (use server-side totals as authoritative)
                        doc.setFontSize(12);
                        doc.text('Total Reports: @totalReports', margin, y);
                        y += 16;
                        // Use the numeric counts available from server-side variables as fallback
                        const approvedCnt = @approvedCount;
                        const rejectedCnt = @rejectedCount;
                        const pendingCnt = @pendingCount;
                        doc.text(`Approved: ${approvedCnt}`, margin, y); y += 14;
                        doc.text(`Rejected: ${rejectedCnt}`, margin, y); y += 14;
                        doc.text(`Pending/Submissions: ${pendingCnt}`, margin, y); y += 18;

                        // Monthly reimbursed if available server-side (use ASCII currency label to avoid glyph issues)
                        doc.text('This Month Reimbursed (PHP): @monthlyReimbursed.ToString("N2")', margin, y); y += 18;

                        // Budgets summary table
                        doc.setFontSize(13);
                        doc.text('Budget Summary:', margin, y); y += 16;
                        doc.setFontSize(10);

                        // Write each budget line and compute totals for conclusion
                        var totalAlloc = 0;
                        var totalSpentCalc = 0;
                        budgetsData.forEach(function(b){
                            const cat = b.Category || 'Unspecified';
                            const allocNum = Number(b.Allocated || 0);
                            const spentNum = Number(b.Spent || 0);
                            const remaining = allocNum - spentNum;
                            const pct = allocNum ? Math.round((spentNum / allocNum) * 100) : 0;
                            const line = `${cat} — Allocated: PHP ${allocNum.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})}, Spent: PHP ${spentNum.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})}, Remaining: PHP ${remaining.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})}, Usage: ${pct}%`;
                            if (y > doc.internal.pageSize.getHeight() - 60) { doc.addPage(); y = margin; }
                            doc.text(line, margin, y);
                            y += 12;
                            totalAlloc += allocNum;
                            totalSpentCalc += spentNum;
                        });

                        y += 8;
                        doc.setFontSize(12);
                        doc.text('Monthly Trend (last 6 months):', margin, y); y += 14;
                        doc.setFontSize(10);
                        var monthly = [];
                        if (monthlyData && monthlyData.length) {
                            monthlyData.forEach(function(m){
                                if (y > doc.internal.pageSize.getHeight() - 60) { doc.addPage(); y = margin; }
                                doc.text(`${m.label}: PHP ${(m.total||0).toFixed(2)}`, margin, y);
                                y += 12;
                                monthly.push({ label: m.label, total: m.total || 0 });
                            });
                        } else {
                            // fallback: use server-side month labels/totals if present
                            var monthLabels = @Html.Raw(ViewBag.MonthLabels ?? "[]");
                            var monthTotals = @Html.Raw(ViewBag.MonthTotals ?? "[]");
                            for(var i=0;i<monthLabels.length;i++){
                                if (y > doc.internal.pageSize.getHeight() - 60) { doc.addPage(); y = margin; }
                                doc.text(`${monthLabels[i]}: PHP ${(monthTotals[i]||0).toFixed(2)}`, margin, y);
                                y += 12;
                                monthly.push({ label: monthLabels[i], total: monthTotals[i] || 0 });
                            }
                        }

                        // Build a short conclusion based on the collected data
                        y += 12;
                        doc.setFontSize(13);
                        doc.text('Conclusion & Recommendations:', margin, y); y += 16;
                        doc.setFontSize(10);

                        // Overall budget usage
                        var overallPct = totalAlloc ? Math.round((totalSpentCalc / totalAlloc) * 100) : 0;
                        var conclLines = [];
                        conclLines.push(`Overall budget usage: ₱${totalSpentCalc.toFixed(2)} of ₱${totalAlloc.toFixed(2)} (${overallPct}%).`);

                        // Over-budget categories
                        var overCats = budgetsData.filter(function(b){ return (b.Spent||0) > (b.Allocated||0); });
                        if (overCats.length > 0) {
                            overCats.sort(function(a,b){ return ((b.Spent||0)-(b.Allocated||0)) - ((a.Spent||0)-(a.Allocated||0)); });
                            var topNames = overCats.slice(0,3).map(function(c){ return `${c.Category} (exceed ₱${((c.Spent||0)-(c.Allocated||0)).toFixed(2)})`; }).join(', ');
                            conclLines.push(`There are ${overCats.length} category(ies) over budget. Top: ${topNames}. Consider reviewing allocations or controlling spend in these areas.`);
                        } else {
                            conclLines.push('All tracked categories are within their allocated budgets. Continue monitoring monthly trends.');
                        }

                        // Monthly trend change (compare last two months if available)
                        if (monthly.length >= 2) {
                            var last = monthly[monthly.length-1].total || 0;
                            var prev = monthly[monthly.length-2].total || 0;
                            var diff = last - prev;
                            var pctChange = prev ? Math.round((diff / prev) * 100) : null;
                            if (pctChange === null) {
                                conclLines.push(`Latest month (${monthly[monthly.length-1].label}) total: ₱${last.toFixed(2)} (no previous month to compare).`);
                            } else {
                                var arrow = diff >= 0 ? 'increase' : 'decrease';
                                conclLines.push(`Monthly change: ${arrow} of ₱${Math.abs(diff).toFixed(2)} (${Math.abs(pctChange)}%) compared to previous month.`);
                            }
                        }

                        // Write conclusion lines
                        conclLines.forEach(function(cl){
                            if (y > doc.internal.pageSize.getHeight() - 60) { doc.addPage(); y = margin; }
                            doc.text(cl, margin, y);
                            y += 14;
                        });

                        doc.save('ceo_analytics_summary.pdf');
                        return;
                    } catch (err) {
                        console.warn('Text PDF generation failed, falling back to print.', err);
                    }
                    window.print();
                });
            }
        } catch (e) { console.error('Failed to load trend data', e); }
    }
    loadTrend();
    // Apply filters automatically when date inputs change
    ['analyticsStart','analyticsEnd'].forEach(function(id){
        var el = document.getElementById(id);
        if (el) {
            el.addEventListener('change', function(){
                const s = document.getElementById('analyticsStart').value;
                const e = document.getElementById('analyticsEnd').value;
                const params = new URLSearchParams(window.location.search);
                if (s) params.set('start', s); else params.delete('start');
                if (e) params.set('end', e); else params.delete('end');
                // navigate with new params
                window.location.search = params.toString();
            });
        }
    });
</script>
}
