@using System.Text.Json
@{
    ViewData["Title"] = "Budget Monitoring";
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
    var budgets = ViewBag.Budgets as List<CEMS.Models.Budget> ?? new List<CEMS.Models.Budget>();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<style>
    :root {
        --d-primary: #1a6bb5;
        --d-accent: #2ec4b6;
        --d-bg: #f7fbfc;
        --d-card: #ffffff;
        --d-border: #e9eef6;
        --d-text: #0f1724;
        --d-muted: #6b7280;
        --d-radius: 8px;
    }

    .page-wrapper {
        background: var(--d-bg);
        min-height: calc(100vh - 80px);
        padding: 28px 0 40px;
    }

    .page-header {
        margin-bottom: 28px;
    }

    .page-title {
        font-size: 1.65rem;
        font-weight: 700;
        color: var(--d-text);
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .page-subtitle {
        color: var(--d-muted);
        font-size: .95rem;
        margin-top: 4px;
    }

    .page-title i {
        color: var(--d-primary);
        font-size: 1.8rem;
    }

    .info-banner {
        background: rgba(26, 107, 181, 0.05);
        border: 1px solid rgba(26, 107, 181, 0.2);
        border-radius: 10px;
        padding: 16px;
        margin-bottom: 24px;
        color: #164e63;
    }

    .info-banner i {
        margin-right: 8px;
        color: var(--d-primary);
    }

    .table-card {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 24px;
    }

    .table-card-head {
        background: #f8fafc;
        padding: 14px 18px;
        border-bottom: 1px solid var(--d-border);
        font-weight: 600;
        color: var(--d-text);
    }

    .dash-table {
        width: 100%;
        margin-bottom: 0;
    }

    .dash-table thead th {
        background: #f8fafc;
        color: var(--d-muted);
        font-weight: 600;
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        padding: 12px 16px;
        border: none;
    }

    .dash-table tbody td {
        padding: 14px 16px;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
        color: var(--d-text);
        font-size: .9rem;
    }

    .dash-table tbody tr:last-child td {
        border-bottom: none;
    }

    .dash-table tbody tr:hover {
        background: #f8fafc;
    }

    .dash-table tfoot tr {
        background: #f8fafc;
        border-top: 2px solid var(--d-border);
    }

    .budget-bar {
        height: 8px;
        border-radius: 4px;
        background: #f1f5f9;
        overflow: hidden;
    }

    .budget-bar-fill {
        height: 100%;
        border-radius: 4px;
        transition: width .3s ease;
    }

    .budget-bar-fill--ok { background: var(--d-primary); }
    .budget-bar-fill--warn { background: #f59e0b; }
    .budget-bar-fill--danger { background: #ef4444; }

    .empty-state {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 10px;
        padding: 40px;
        text-align: center;
    }

    .empty-state i {
        font-size: 3rem;
        color: var(--d-border);
        margin-bottom: 16px;
    }

    .empty-state p {
        color: var(--d-muted);
        margin: 0;
    }

    @@media (max-width: 768px) {
        .page-wrapper { padding: 20px 0 32px; }
        .page-title { font-size: 1.4rem; }
    }

    .filter-bar {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 10px;
        padding: 16px;
        margin-bottom: 24px;
        display: flex;
        align-items: flex-end;
        gap: 16px;
        flex-wrap: wrap;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .filter-group label {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        color: #64748b;
        letter-spacing: 0.3px;
    }

    .filter-group input {
        padding: 8px 12px;
        border: 1px solid var(--d-border);
        border-radius: 6px;
        font-size: 0.9rem;
        color: var(--d-text);
        background: white;
    }

    .filter-group input:focus {
        outline: none;
        border-color: var(--d-primary);
        box-shadow: 0 0 0 3px rgba(26, 107, 181, 0.1);
    }

    .quick-filters {
        display: flex;
        align-items: center;
        gap: 2px;
        background: #f8fafc;
        padding: 4px;
        border-radius: 8px;
        border: 1px solid var(--d-border);
    }

    .filter-btn {
        padding: 6px 14px;
        border: none;
        background: transparent;
        border-radius: 6px;
        font-size: 0.82rem;
        font-weight: 500;
        color: #475569;
        cursor: pointer;
        transition: all 0.2s ease;
        white-space: nowrap;
    }

    .filter-btn:hover {
        background: #e2e8f0;
        color: var(--d-primary);
    }

    .filter-btn.active {
        background: var(--d-primary);
        color: white;
    }

    .filter-btn.active:hover {
        background: #155a9a;
    }

    .export-btn {
        display: inline-flex; align-items: center; gap: 6px;
        background: #10b981; color: #fff; border: none; border-radius: 6px;
        padding: 8px 16px; font-size: .85rem; font-weight: 600;
        cursor: pointer; transition: background .15s;
        margin-left: auto;
    }
    .export-btn:hover { background: #059669; }

    @@media print {
        body, html { background: #fff !important; }
        nav, header, footer, .no-print, .export-btn, .info-banner { display: none !important; }
        .page-wrapper { padding: 0 !important; min-height: auto !important; }
        .table-card { break-inside: avoid; border: 1px solid #ddd !important; }
        .container-fluid { padding: 0 !important; }
        .page-title { font-size: 1.3rem !important; }
    }
</style>

<div class="page-wrapper">
    <div class="container-fluid px-4">
        <!-- Page Header -->
        <div class="page-header d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <h1 class="page-title">
                    <i class="bi bi-calculator"></i>
                    Budget Monitoring
                </h1>
                <p class="page-subtitle">Budgets are set by the CEO. Track allocations and spending below.</p>
            </div>
        </div>

        <!-- Filter Bar -->
        <div class="filter-bar">
            <div class="filter-group">
                <label>From Date</label>
                <input type="date" id="filterStart" value="@DateTime.UtcNow.AddMonths(-1).ToString("yyyy-MM-dd")">
            </div>
            <div class="filter-group">
                <label>To Date</label>
                <input type="date" id="filterEnd" value="@DateTime.UtcNow.ToString("yyyy-MM-dd")">
            </div>
            <div class="quick-filters">
                <button class="filter-btn" data-range="today">Today</button>
                <button class="filter-btn" data-range="week">Week</button>
                <button class="filter-btn active" data-range="month">Month</button>
                <button class="filter-btn" data-range="year">Year</button>
            </div>
            <button onclick="exportBudgetToPDF()" class="export-btn">
                <i class="bi bi-file-earmark-pdf"></i> Export PDF
            </button>
        </div>

        <!-- Info Banner -->
        <div class="info-banner">
            <i class="bi bi-info-circle"></i>
            <strong>Note:</strong> Budget allocations are set by the CEO. Use this view to monitor your team's spending against limits.
        </div>

        <!-- Budget Summary Table -->
        @if (budgets.Any())
        {
            <div class="table-card">
                <div class="table-card-head">
                    <i class="bi bi-list-check me-2"></i> Budget Summary
                </div>
                <div class="table-responsive">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th>Allocated</th>
                                <th>Spent</th>
                                <th>Remaining</th>
                                <th>Usage %</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in budgets)
                            {
                                var remaining = b.Allocated - b.Spent;
                                var pct = b.Allocated == 0 ? 0 : (int)Math.Round((double)(b.Spent / b.Allocated * 100));
                                var barClass = pct >= 100 ? "budget-bar-fill--danger" : pct >= 75 ? "budget-bar-fill--warn" : "budget-bar-fill--ok";
                                <tr>
                                    <td class="fw-600">@b.Category</td>
                                    <td>₱<strong>@b.Allocated.ToString("N2")</strong></td>
                                    <td>₱<strong>@b.Spent.ToString("N2")</strong></td>
                                    <td class="@(remaining < 0 ? "fw-bold" : "")">
                                        <span style="color: @(remaining < 0 ? "#ef4444" : "#0d8b7d");">₱@remaining.ToString("N2")</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="budget-bar" style="flex: 1;">
                                                <div class="budget-bar-fill @barClass" style="width:@Math.Min(pct, 100)%"></div>
                                            </div>
                                            <span class="badge @(pct >= 100 ? "bg-danger" : pct >= 75 ? "bg-warning" : "bg-success")">@pct%</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td class="fw-bold">TOTAL</td>
                                <td>₱<strong>@budgets.Sum(b => b.Allocated).ToString("N2")</strong></td>
                                <td>₱<strong>@budgets.Sum(b => b.Spent).ToString("N2")</strong></td>
                                <td style="color: @(budgets.Sum(b => b.Allocated - b.Spent) < 0 ? "#ef4444" : "#0d8b7d"); font-weight: 700;">₱@budgets.Sum(b => b.Allocated - b.Spent).ToString("N2")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p>No budgets have been set by the CEO yet.</p>
            </div>
        }

        <!-- Budget Details Section -->
        <div class="row g-3">
            <div class="col-lg-8">
                <div class="table-card">
                    <div class="table-card-head">
                        <i class="bi bi-graph-up me-2"></i> Budget Details
                    </div>
                    <div style="padding: 18px;">
                        <div id="budgetList">
                            <p class="text-muted text-center py-4">Loading budget details...</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="table-card">
                    <div class="table-card-head">
                        <i class="bi bi-bar-chart me-2"></i> Budget Chart
                    </div>
                    <div style="padding: 18px;">
                        <canvas id="budgetChart" height="200"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
async function loadBudgets(){
    try{
        const res = await fetch('@Url.Action("Metrics","Manager")' + getFilterParams());
        const data = await res.json();
        const container = document.getElementById('budgetList');
        container.innerHTML = '';
        const labels = [];
        const used = [];
        const allocated = [];

        for(const b of data.budgets || []){
            labels.push(b.category);
            used.push(b.spent);
            allocated.push(b.allocated);
            const percent = b.allocated === 0 ? 0 : Math.min(100, Math.round((b.spent / b.allocated) * 100));
            const barClass = percent >= 100 ? 'budget-bar-fill--danger' : percent >= 75 ? 'budget-bar-fill--warn' : 'budget-bar-fill--ok';

            const div = document.createElement('div');
            div.className = 'mb-4';
            div.style.paddingBottom = '16px';
            div.style.borderBottom = '1px solid #f1f5f9';
            div.innerHTML = `
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="fw-600">${b.category}</div>
                    <div class="text-muted small">₱${b.spent.toFixed(2)} / ₱${b.allocated.toFixed(2)}</div>
                </div>
                <div class="budget-bar">
                    <div class="budget-bar-fill ${barClass}" style="width:${percent}%"></div>
                </div>
                <div class="text-muted small mt-2">${percent}% used</div>
            `;
            container.appendChild(div);
        }

        // render chart
        const ctx = document.getElementById('budgetChart').getContext('2d');
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: used,
                    backgroundColor: [
                        '#1a6bb5',
                        '#2ec4b6',
                        '#10b981',
                        '#f59e0b',
                        '#ef4444'
                    ],
                    borderColor: '#ffffff',
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            font: { size: 12 },
                            padding: 12
                        }
                    }
                }
            }
        });
    }catch(e){ console.error(e); }
}

function getFilterParams() {
    const start = document.getElementById('filterStart')?.value;
    const end = document.getElementById('filterEnd')?.value;
    const params = new URLSearchParams();
    if (start) params.append('start', start);
    if (end) params.append('end', end);
    const query = params.toString();
    return query ? '?' + query : '';
}

function setDateRange(rangeType) {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    let startDate = new Date(today);
    let endDate = new Date(today);

    switch(rangeType) {
        case 'today':
            startDate = new Date(today);
            endDate = new Date(today);
            break;
        case 'week':
            startDate = new Date(today);
            startDate.setDate(today.getDate() - today.getDay());
            endDate = new Date(today);
            break;
        case 'month':
            startDate = new Date(today.getFullYear(), today.getMonth(), 1);
            endDate = new Date(today);
            break;
        case 'year':
            startDate = new Date(today.getFullYear(), 0, 1);
            endDate = new Date(today);
            break;
    }

    document.getElementById('filterStart').value = startDate.toISOString().split('T')[0];
    document.getElementById('filterEnd').value = endDate.toISOString().split('T')[0];

    applyBudgetFilter();
}

function highlightActiveFilter() {
    const startInput = document.getElementById('filterStart');
    const endInput = document.getElementById('filterEnd');
    if (!startInput || !endInput) return;

    const start = new Date(startInput.value);
    const end = new Date(endInput.value);
    const now = new Date();
    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());

    document.querySelectorAll('.filter-btn').forEach(function(btn) {
        btn.classList.remove('active');
    });

    let matchingRange = null;

    if (start.getTime() === today.getTime() && end.getTime() === today.getTime()) {
        matchingRange = 'today';
    } else {
        const weekStart = new Date(today);
        weekStart.setDate(today.getDate() - today.getDay());
        if (start.getTime() === weekStart.getTime() && end.getTime() === today.getTime()) {
            matchingRange = 'week';
        }
    }

    if (!matchingRange) {
        const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
        if (start.getTime() === monthStart.getTime() && end.getTime() === today.getTime()) {
            matchingRange = 'month';
        }
    }

    if (!matchingRange) {
        const yearStart = new Date(now.getFullYear(), 0, 1);
        if (start.getTime() === yearStart.getTime() && end.getTime() === today.getTime()) {
            matchingRange = 'year';
        }
    }

    if (matchingRange) {
        const activeBtn = document.querySelector('[data-range="' + matchingRange + '"]');
        if (activeBtn) activeBtn.classList.add('active');
    }
}

function applyBudgetFilter() {
    highlightActiveFilter();
    loadBudgets();
}

function exportBudgetToPDF() {
    const start = document.getElementById('filterStart')?.value || 'All';
    const end = document.getElementById('filterEnd')?.value || 'All';

    // Create table HTML
    const tableHtml = `
        <div style="font-family: Arial, sans-serif; padding: 20px;">
            <h2 style="text-align: center; color: #1a6bb5; margin-bottom: 10px;">Budget Monitoring Report</h2>
            <p style="text-align: center; color: #666; margin-bottom: 20px;">
                Generated: ${new Date().toLocaleString()}<br>
                Date Range: ${start} to ${end}
            </p>
            <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 2px solid #1a6bb5;">
                        <th style="padding: 12px; text-align: left; font-weight: 700; border: 1px solid #ddd;">Category</th>
                        <th style="padding: 12px; text-align: right; font-weight: 700; border: 1px solid #ddd;">Allocated</th>
                        <th style="padding: 12px; text-align: right; font-weight: 700; border: 1px solid #ddd;">Spent</th>
                        <th style="padding: 12px; text-align: right; font-weight: 700; border: 1px solid #ddd;">Remaining</th>
                        <th style="padding: 12px; text-align: center; font-weight: 700; border: 1px solid #ddd;">Usage %</th>
                    </tr>
                </thead>
                <tbody>
                    ${generateBudgetTableRows()}
                </tbody>
            </table>
            <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd;">
                <p style="color: #666; font-size: 12px;">This report was generated automatically. Please verify all amounts are correct.</p>
            </div>
        </div>
    `;

    const element = document.createElement('div');
    element.innerHTML = tableHtml;

    const opt = {
        margin: 10,
        filename: `budget-report-${new Date().toISOString().split('T')[0]}.pdf`,
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { scale: 2 },
        jsPDF: { orientation: 'landscape', unit: 'mm', format: 'a4' }
    };

    html2pdf().set(opt).from(element).save();
}

function generateBudgetTableRows() {
    const budgets = @Html.Raw(JsonSerializer.Serialize(ViewBag.Budgets ?? new List<CEMS.Models.Budget>()));
    let html = '';

    if (!budgets || budgets.length === 0) {
        html = '<tr><td colspan="5" style="text-align: center; padding: 20px; color: #666;">No budget data available</td></tr>';
    } else {
        let totalAllocated = 0, totalSpent = 0, totalRemaining = 0;

        budgets.forEach(b => {
            const remaining = b.allocated - b.spent;
            const percent = b.allocated === 0 ? 0 : Math.round((b.spent / b.allocated) * 100);
            const bgColor = percent >= 100 ? '#ffebee' : percent >= 75 ? '#fff3e0' : '#f1f5f9';

            html += `
                <tr style="background: ${bgColor}; border-bottom: 1px solid #ddd;">
                    <td style="padding: 12px; border: 1px solid #ddd; font-weight: 600;">${b.category}</td>
                    <td style="padding: 12px; text-align: right; border: 1px solid #ddd;">₱${b.allocated.toFixed(2)}</td>
                    <td style="padding: 12px; text-align: right; border: 1px solid #ddd;">₱${b.spent.toFixed(2)}</td>
                    <td style="padding: 12px; text-align: right; border: 1px solid #ddd; color: ${remaining < 0 ? '#ef4444' : '#0d8b7d'}; font-weight: 700;">₱${remaining.toFixed(2)}</td>
                    <td style="padding: 12px; text-align: center; border: 1px solid #ddd; font-weight: 700;">${percent}%</td>
                </tr>
            `;

            totalAllocated += b.allocated;
            totalSpent += b.spent;
            totalRemaining += remaining;
        });

        html += `
            <tr style="background: #f8fafc; font-weight: 700; border-top: 2px solid #1a6bb5; border-bottom: 2px solid #1a6bb5;">
                <td style="padding: 12px; border: 1px solid #ddd;">TOTAL</td>
                <td style="padding: 12px; text-align: right; border: 1px solid #ddd;">₱${totalAllocated.toFixed(2)}</td>
                <td style="padding: 12px; text-align: right; border: 1px solid #ddd;">₱${totalSpent.toFixed(2)}</td>
                <td style="padding: 12px; text-align: right; border: 1px solid #ddd; color: ${totalRemaining < 0 ? '#ef4444' : '#0d8b7d'};">₱${totalRemaining.toFixed(2)}</td>
                <td style="padding: 12px; text-align: center; border: 1px solid #ddd;"></td>
            </tr>
        `;
    }

    return html;
}

document.addEventListener('DOMContentLoaded', function() {
    // Initialize with default month filter
    setDateRange('month');
    highlightActiveFilter();

    // Add event listeners to quick filter buttons
    document.querySelectorAll('.filter-btn').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            const range = this.getAttribute('data-range');
            setDateRange(range);
        });
    });

    // Add event listeners to date inputs for automatic reload
    document.getElementById('filterStart')?.addEventListener('change', applyBudgetFilter);
    document.getElementById('filterEnd')?.addEventListener('change', applyBudgetFilter);
});

</script>
}
