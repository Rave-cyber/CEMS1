@{
    ViewData["Title"] = "Over-Budget Reports";
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<style>
    :root {
        --d-primary: #1a6bb5;
        --d-accent: #2ec4b6;
        --d-bg: #f7fbfc;
        --d-card: #ffffff;
        --d-border: #e9eef6;
        --d-text: #0f1724;
        --d-muted: #6b7280;
        --d-radius: 8px;
    }

    .page-wrapper {
        background: var(--d-bg);
        min-height: calc(100vh - 80px);
        padding: 28px 0 40px;
    }

    .page-header {
        margin-bottom: 28px;
    }

    .page-title {
        font-size: 1.65rem;
        font-weight: 700;
        color: var(--d-text);
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .page-title i {
        color: #ef4444;
        font-size: 1.8rem;
    }

    .alert-over-budget {
        background: rgba(239, 68, 68, 0.05);
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: 10px;
        padding: 16px;
        margin-bottom: 24px;
        color: #991b1b;
    }

    .alert-over-budget i {
        margin-right: 8px;
        color: #ef4444;
    }

    .table-card {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 10px;
        overflow: hidden;
    }

    .dash-table {
        width: 100%;
        margin-bottom: 0;
    }

    .dash-table thead th {
        background: #f8fafc;
        color: var(--d-muted);
        font-weight: 600;
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        padding: 12px 16px;
        border: none;
    }

    .dash-table tbody td {
        padding: 14px 16px;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
        color: var(--d-text);
        font-size: .9rem;
    }

    .dash-table tbody tr:last-child td {
        border-bottom: none;
    }

    .dash-table tbody tr:hover {
        background: #f8fafc;
    }

    .exceed-badge {
        display: inline-block;
        padding: 0;
        border-radius: 0;
        font-size: .9rem;
        font-weight: 700;
        background: transparent;
        color: var(--d-text);
    }

    /* row accent for over-budget items to match reports list */
    .report-overbudget td:first-child {
        border-left: 4px solid #ef4444;
        padding-left: 10px;
    }
    .report-overbudget { background: rgba(239,68,68,0.02); }

    .action-btn {
        font-size: .85rem;
        padding: 6px 12px;
        border-radius: 6px;
        text-decoration: none;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: none;
        cursor: pointer;
    }

    .action-btn--primary {
        background: var(--d-primary);
        color: #fff;
    }

    .action-btn--primary:hover {
        background: #154a8a;
        color: #fff;
        text-decoration: none;
    }

    .action-btn--danger {
        background: #ef4444;
        color: #fff;
    }

    .action-btn--danger:hover {
        background: #dc2626;
        color: #fff;
        text-decoration: none;
    }

    /* Consistent view / approve button styles used elsewhere */
    .view-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        background: rgba(26, 107, 181, .08);
        color: var(--d-primary);
        border: 1px solid rgba(26, 107, 181, .2);
        border-radius: 6px;
        font-size: .85rem;
        font-weight: 500;
        text-decoration: none;
        transition: all .2s;
    }

    .view-btn:hover { background: rgba(26,107,181,.12); color:#155a9a; }

    .approve-btn, .reject-btn {
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        color: #fff;
        border: none;
        cursor: pointer;
    }

    .approve-btn { background: #10b981; }
    .approve-btn:hover { filter: brightness(.95); }

    .reject-btn { background: #ef4444; }
    .reject-btn:hover { filter: brightness(.95); }

    .empty-state {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 10px;
        padding: 40px;
        text-align: center;
    }

    .empty-state i {
        font-size: 3rem;
        color: #10b981;
        margin-bottom: 16px;
    }

    .empty-state p {
        color: var(--d-muted);
        margin: 0;
    }

    @@media (max-width: 768px) {
        .page-wrapper { padding: 20px 0 32px; }
        .page-title { font-size: 1.4rem; }
    }
</style>

<div class="page-wrapper">
    <div class="container-fluid px-4">
        <!-- Page Header -->
        <div class="page-header">
            @* <h1 class="page-title">
                <i class="bi bi-exclamation-triangle"></i>
                Over-Budget Reports
            </h1> *@
        </div>

        <!-- Alert -->
        <div class="alert-over-budget">
            <i class="bi bi-info-circle"></i>
            <strong>Attention:</strong> These expense reports exceed the approved budget. Review and forward to CEO for final approval.
        </div>

        <!-- Reports Table -->
        @if(ViewBag.OverBudget != null && ((List<CEMS.Models.OverBudgetReportDto>)ViewBag.OverBudget).Count > 0)
        {
            <div class="table-card">
                <div class="table-responsive">
                    <table class="dash-table" id="overBudgetTable">
                        <thead>
                            <tr>
                                <th>Report ID</th>
                                <th>Driver</th>
                                <th>Total Amount</th>
                                <th>Exceed Amount</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var dto in ViewBag.OverBudget as List<CEMS.Models.OverBudgetReportDto>)
                            {
                                <tr class="report-overbudget">
                                    <td><strong>@dto.Report.Id</strong></td>
                                    <td>@(dto.UserName ?? "Unknown")</td>
                                    <td><strong>₱@dto.Report.TotalAmount.ToString("N2")</strong></td>
                                    <td>
                                        <span class="exceed-badge">+₱@dto.ExceedAmount.ToString("N2")</span>
                                    </td>
                                    <td>
                                        @if (dto.Report.Status == CEMS.Models.ReportStatus.Submitted)
                                        {
                                            <span style="color:#0288d1;font-weight:600;font-size:.85rem;">Pending</span>
                                        }
                                        else if (dto.Report.Status == CEMS.Models.ReportStatus.PendingCEOApproval)
                                        {
                                            <span style="color:#f59e0b;font-weight:600;font-size:.85rem;">Awaiting CEO</span>
                                        }
                                    </td>
                                    <td>
                                        <a class="view-btn" href="@Url.Action("ReportDetails", "Manager", new { id = dto.Report.Id, source = "OverBudget" })">View</a>
                                        @if (dto.Report.Status == CEMS.Models.ReportStatus.Submitted)
                                        {
                                            <form method="post" asp-action="ApproveReport" asp-controller="Manager" style="display: inline-block; margin-left: 6px;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@dto.Report.Id" />
                                                <button class="approve-btn" type="submit">Forward to CEO</button>
                                            </form>
                                        }
                                        else if (dto.Report.Status == CEMS.Models.ReportStatus.PendingCEOApproval)
                                        {
                                            <span class="status-text" style="margin-left:8px;color:#f59e0b;font-weight:600;font-size:.85rem;">
                                                <i class="bi bi-clock-history"></i> Forwarded
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="controls-bottom" id="overBudgetPagination"></div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-check-circle"></i>
                <p>Great! No over-budget reports at this time.</p>
            </div>
        }
    </div>
</div>

<script>
(function(){
    var PAGE_SIZE = 10;
    var table = document.getElementById('overBudgetTable');
    if(!table) return;
    var rows = Array.from(table.querySelectorAll('tbody tr'));
    var totalPages = Math.ceil(rows.length / PAGE_SIZE);
    if(totalPages <= 1) return;
    var currentPage = 1;

    function renderPage(page){
        currentPage = page;
        rows.forEach(function(r,i){
            r.style.display = (i >= (page-1)*PAGE_SIZE && i < page*PAGE_SIZE) ? '' : 'none';
        });
        renderPaginationControls();
    }

    function renderPaginationControls(){
        var container = document.getElementById('overBudgetPagination');
        if(!container) return;
        var startP = Math.max(1, currentPage - 2);
        var endP = Math.min(totalPages, currentPage + 2);
        var html = '<nav aria-label="Report pages" class="controls-pagination"><ul class="pagination mb-0">';
        html += '<li class="page-item '+(currentPage===1?'disabled':'')+'"><a class="page-link" href="#" data-page="'+(currentPage-1)+'"><i class="bi bi-chevron-left"></i> Prev</a></li>';
        if(startP > 1){
            html += '<li class="page-item"><a class="page-link" href="#" data-page="1">1</a></li>';
            if(startP > 2) html += '<li class="page-item disabled"><span class="page-link">...</span></li>';
        }
        for(var p=startP;p<=endP;p++){
            html += '<li class="page-item '+(p===currentPage?'active':'')+'"><a class="page-link" href="#" data-page="'+p+'">'+p+'</a></li>';
        }
        if(endP < totalPages){
            if(endP < totalPages-1) html += '<li class="page-item disabled"><span class="page-link">...</span></li>';
            html += '<li class="page-item"><a class="page-link" href="#" data-page="'+totalPages+'">'+totalPages+'</a></li>';
        }
        html += '<li class="page-item '+(currentPage===totalPages?'disabled':'')+'"><a class="page-link" href="#" data-page="'+(currentPage+1)+'">Next <i class="bi bi-chevron-right"></i></a></li>';
        html += '</ul></nav>';
        html += '<div class="pagination-info">Page <strong>'+currentPage+'</strong> of <strong>'+totalPages+'</strong> ('+rows.length+' records)</div>';
        container.innerHTML = html;
        container.querySelectorAll('a[data-page]').forEach(function(a){
            a.addEventListener('click', function(e){
                e.preventDefault();
                var pg = parseInt(this.getAttribute('data-page'));
                if(pg >= 1 && pg <= totalPages) renderPage(pg);
            });
        });
    }

    renderPage(1);
})();
</script>
