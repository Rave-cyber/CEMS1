@{
    ViewData["Title"] = "Reimbursements";
    Layout = "~/Views/Shared/_FinanceLayout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<style>
    :root {
        --d-primary: #1a6bb5;
        --d-accent: #2ec4b6;
        --d-bg: #f7fbfc;
        --d-card: #ffffff;
        --d-border: #e9eef6;
        --d-text: #0f1724;
        --d-muted: #6b7280;
    }

    .page-wrapper {
        background: var(--d-bg);
        min-height: calc(100vh - 80px);
        padding: 28px 0 40px;
    }

    .page-header {
        margin-bottom: 28px;
    }

    .page-title {
        font-size: 1.65rem;
        font-weight: 700;
        color: var(--d-text);
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .page-title i {
        color: var(--d-primary);
        font-size: 1.8rem;
    }

    .page-subtitle {
        color: var(--d-muted);
        font-size: .95rem;
        margin-top: 4px;
    }

    .info-banner {
        background: rgba(26, 107, 181, 0.05);
        border: 1px solid rgba(26, 107, 181, 0.2);
        border-radius: 10px;
        padding: 16px;
        margin-bottom: 24px;
        color: #164e63;
    }

    .info-banner i {
        margin-right: 8px;
        color: var(--d-primary);
    }

    /* compact filter card like dashboard */
    .filter-card {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 8px;
        padding: 12px 12px;
        margin-bottom: 12px;
    }
    .filter-card .form-label {
        font-size: .85rem;
        font-weight: 600;
        color: var(--d-muted);
        margin-bottom: 4px;
    }
    .filter-card .form-control,
    .filter-card .form-select {
        border-color: var(--d-border);
        border-radius: 6px;
        font-size: .88rem;
        padding: 6px 8px;
    }
    .filter-card .form-control:focus,
    .filter-card .form-select:focus {
        border-color: var(--d-primary);
        box-shadow: 0 0 0 0.2rem rgba(26, 107, 181, 0.1);
    }
    .quick-filter-btn {
        padding: 6px 12px;
        border: 1px solid var(--d-border);
        background: var(--d-card);
        color: var(--d-text);
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .quick-filter-btn:hover {
        background: var(--d-primary);
        color: #fff;
        border-color: var(--d-primary);
    }
    .quick-filter-btn.active {
        background: var(--d-primary);
        color: #fff;
        border-color: var(--d-primary);
        box-shadow: 0 0 0 3px rgba(26, 107, 181, 0.1);
    }

    .table-card {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 10px;
        overflow: hidden;
    }

    .dash-table {
        width: 100%;
        margin-bottom: 0;
    }

    .dash-table thead th {
        background: #f8fafc;
        color: var(--d-muted);
        font-weight: 600;
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        padding: 12px 16px;
        border: none;
    }

    .dash-table tbody td {
        padding: 14px 16px;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
        color: var(--d-text);
        font-size: .9rem;
    }

    .dash-table tbody tr:last-child td {
        border-bottom: none;
    }

    .dash-table tbody tr:hover {
        background: #f8fafc;
    }

    /* primary blue action (view/pay) */
    .view-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        background: rgba(26, 107, 181, .08);
        color: var(--d-primary);
        border: 1px solid rgba(26, 107, 181, .2);
        border-radius: 6px;
        font-size: .85rem;
        font-weight: 500;
        text-decoration: none;
        transition: all .2s;
    }
    .view-btn:hover { background: rgba(26,107,181,.12); color:#155a9a; }

    /* approve / success action (green) */
    .approve-btn {
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        color: #fff;
        border: none;
        background: #10b981;
        cursor: pointer;
    }
    .approve-btn:hover { filter: brightness(.95); }

    /* neutral status text (no colored badges) */
    .status-text { font-weight: 600; color: var(--d-text); font-size: .88rem; }

    .empty-state {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 10px;
        padding: 40px;
        text-align: center;
    }

    .empty-state i {
        font-size: 3rem;
        color: var(--d-border);
        margin-bottom: 16px;
    }

    .empty-state p {
        color: var(--d-muted);
        margin: 0;
    }

    @@media (max-width: 768px) {
        .page-wrapper { padding: 20px 0 32px; }
        .page-title { font-size: 1.4rem; }
    }
</style>

<div class="page-wrapper">
    <div class="container-fluid px-4">
        <div class="page-header">
            @* <h1 class="page-title">
                <i class="bi bi-arrow-left-right"></i>
                Reimbursements
            </h1> *@
            <p class="page-subtitle">Process approved expense reimbursements via PayMongo.</p>
        </div>

        <div class="filter-card">
            <form id="reimbursementFilters" class="row g-3" method="get" action="@Context.Request.Path">
                <div class="col-12">
                    <label class="form-label">Search</label>
                    <div class="d-flex" style="gap:8px;">
                        <input type="text" name="search" id="reimSearch" class="form-control form-control-sm" placeholder="Report ID or driver name" value="@Context.Request.Query["search"]" style="flex:1;" />
                        <div class="d-flex" style="gap:6px; align-items:center;">
                            <button type="button" class="quick-filter-btn" data-range="today">Today</button>
                            <button type="button" class="quick-filter-btn" data-range="week">Week</button>
                            <button type="button" class="quick-filter-btn" data-range="month">Month</button>
                            <button type="button" class="quick-filter-btn" data-range="year">Year</button>
                        </div>
                    </div>
                </div>

                <input type="hidden" name="start" id="reimStart" value="@Context.Request.Query["start"]" />
                <input type="hidden" name="end" id="reimEnd" value="@Context.Request.Query["end"]" />
            </form>
        </div>

        <div class="position-fixed top-0 end-0 p-3" style="z-index: 1080">
            @if (TempData["Success"] != null)
            {
                <div class="toast align-items-center text-bg-success border-0" role="alert" aria-live="polite" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="toast align-items-center text-bg-danger border-0" role="alert" aria-live="polite" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["Error"]
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                </div>
            }
        </div>

        <div class="info-banner">
            <i class="bi bi-info-circle"></i>
            <strong>How it works:</strong> Click <strong>"Pay via GCash/Card"</strong> to open a PayMongo checkout page.
            Complete the payment there and you'll be redirected back automatically.
            Use <strong>"Check Status"</strong> to verify pending payments, or <strong>"Manual"</strong> to mark as reimbursed without PayMongo.
        </div>

        @if(ViewBag.Reports != null && ((List<CEMS.Models.PendingExpenseReportDto>)ViewBag.Reports).Count > 0)
        {
            <div class="table-card">
                <div class="table-responsive">
                    <table class="dash-table" id="reimbursementsTable">
                        <thead>
                            <tr>
                                <th>Report ID</th>
                                <th>Driver</th>
                                <th>Total Amount</th>
                                <th>Submitted Date</th>
                                <th>Payment Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var dto in ViewBag.Reports as List<CEMS.Models.PendingExpenseReportDto>)
                            {
                                var r = dto.Report;
                                var payment = ViewBag.Payments as Dictionary<int, CEMS.Models.ReimbursementPayment>;
                                var hasPayment = payment != null && payment.ContainsKey(r.Id);
                                var paymentRecord = hasPayment ? payment![r.Id] : null;
                                <tr>
                                    <td><strong>@r.Id</strong></td>
                                    <td>@(dto.UserName ?? "Unknown")</td>
                                    <td><strong>₱@r.TotalAmount.ToString("N2")</strong></td>
                                    <td>@r.SubmissionDate.ToLocalTime().ToString("MMM d, yyyy")</td>
                                    <td>
                                        @if (hasPayment)
                                        {
                                            <span class="status-text">@paymentRecord.Status</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (hasPayment && paymentRecord!.Status == "paid")
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Paid</span>
                                        }
                                        else if (hasPayment)
                                        {
                                            <!-- Check Status -->
                                            <form method="post" asp-action="CheckPaymentStatus" asp-controller="Finance" style="display:inline-block;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@paymentRecord!.Id" />
                                                <button type="submit" class="view-btn">Check Status</button>
                                            </form>
                                            <!-- Retry payment -->
                                            <form method="post" asp-action="Reimburse" asp-controller="Finance" style="display:inline-block; margin-left:6px;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@r.Id" />
                                                <button type="submit" class="approve-btn">Retry Payment</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <!-- Pay via PayMongo -->
                                            <form method="post" asp-action="Reimburse" asp-controller="Finance" style="display:inline-block;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@r.Id" />
                                                <button type="submit" class="view-btn">Pay via GCash/Card</button>
                                            </form>
                                            <!-- Manual fallback -->
                                            <form method="post" asp-action="MarkReimbursedManual" asp-controller="Finance" style="display:inline-block; margin-left:6px;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@r.Id" />
                                                <button type="submit" class="approve-btn" onclick="return confirm('Mark as reimbursed without PayMongo?');">Manual</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="controls-bottom" id="reimbursementsPagination"></div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p>No reimbursements pending.</p>
            </div>
        }
    </div>
</div>

<script>
    // Setup toast display and search behavior
    document.addEventListener('DOMContentLoaded', function(){
        // initialize bootstrap toasts in this page
        var toastElList = [].slice.call(document.querySelectorAll('.toast'));
        toastElList.forEach(function(toastEl){
            try{
                var t = new bootstrap.Toast(toastEl, { delay: 3000 });
                t.show();
            }catch(e){ /* ignore if bootstrap not available */ }
        });

        var filtersForm = document.getElementById('reimbursementFilters');
        if(filtersForm){
            var search = document.getElementById('reimSearch');
            if(search){
                // submit on Enter
                search.addEventListener('keydown', function(e){ if(e.key === 'Enter'){ e.preventDefault(); filtersForm.submit(); } });
            }

            // Quick-range buttons
            document.querySelectorAll('.quick-filter-btn[data-range]').forEach(function(btn){
                btn.addEventListener('click', function(){
                    var range = btn.getAttribute('data-range');
                    var now = new Date();
                    var start;
                    if(range === 'today') start = new Date(now.getFullYear(), now.getMonth(), now.getDate());
                    else if(range === 'week') start = new Date(now.getFullYear(), now.getMonth(), now.getDate() - now.getDay());
                    else if(range === 'month') start = new Date(now.getFullYear(), now.getMonth(), 1);
                    else if(range === 'year') start = new Date(now.getFullYear(), 0, 1);

                    var s = document.getElementById('reimStart');
                    var e = document.getElementById('reimEnd');
                    if(s && start) s.value = start.toISOString().slice(0,10);
                    if(e) e.value = now.toISOString().slice(0,10);
                    setTimeout(function(){ highlightReimActiveFilter(); filtersForm.submit(); }, 150);
                });
            });

            // Highlight active quick filter on load
            highlightReimActiveFilter();
        }
    });

    function highlightReimActiveFilter() {
        var startInput = document.getElementById('reimStart');
        var endInput = document.getElementById('reimEnd');
        if (!startInput || !endInput) return;

        var start = new Date(startInput.value);
        var end = new Date(endInput.value);
        var now = new Date();
        var today = new Date(now.getFullYear(), now.getMonth(), now.getDate());

        document.querySelectorAll('.quick-filter-btn').forEach(function(btn) { btn.classList.remove('active'); });

        var matchingRange = null;
        if (start.getTime() === today.getTime() && end.getTime() === today.getTime()) matchingRange = 'today';
        else {
            var weekStart = new Date(today);
            weekStart.setDate(today.getDate() - today.getDay());
            if (start.getTime() === weekStart.getTime() && end.getTime() === today.getTime()) matchingRange = 'week';
        }
        if (!matchingRange) {
            var monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
            if (start.getTime() === monthStart.getTime() && end.getTime() === today.getTime()) matchingRange = 'month';
        }
        if (!matchingRange) {
            var yearStart = new Date(now.getFullYear(), 0, 1);
            if (start.getTime() === yearStart.getTime() && end.getTime() === today.getTime()) matchingRange = 'year';
        }
        if (matchingRange) {
            var activeBtn = document.querySelector('[data-range="' + matchingRange + '"]');
            if (activeBtn) activeBtn.classList.add('active');
        }
    }
</script>

<script>
(function(){
    var PAGE_SIZE = 10;
    var table = document.getElementById('reimbursementsTable');
    if(!table) return;
    var rows = Array.from(table.querySelectorAll('tbody tr'));
    var totalPages = Math.ceil(rows.length / PAGE_SIZE);
    if(totalPages <= 1) return;
    var currentPage = 1;

    function renderPage(page){
        currentPage = page;
        rows.forEach(function(r,i){
            r.style.display = (i >= (page-1)*PAGE_SIZE && i < page*PAGE_SIZE) ? '' : 'none';
        });
        renderPaginationControls();
    }

    function renderPaginationControls(){
        var container = document.getElementById('reimbursementsPagination');
        if(!container) return;
        var startP = Math.max(1, currentPage - 2);
        var endP = Math.min(totalPages, currentPage + 2);
        var html = '<nav aria-label="Report pages" class="controls-pagination"><ul class="pagination mb-0">';
        html += '<li class="page-item '+(currentPage===1?'disabled':'')+'"><a class="page-link" href="#" data-page="'+(currentPage-1)+'"><i class="bi bi-chevron-left"></i> Prev</a></li>';
        if(startP > 1){
            html += '<li class="page-item"><a class="page-link" href="#" data-page="1">1</a></li>';
            if(startP > 2) html += '<li class="page-item disabled"><span class="page-link">...</span></li>';
        }
        for(var p=startP;p<=endP;p++){
            html += '<li class="page-item '+(p===currentPage?'active':'')+'"><a class="page-link" href="#" data-page="'+p+'">'+p+'</a></li>';
        }
        if(endP < totalPages){
            if(endP < totalPages-1) html += '<li class="page-item disabled"><span class="page-link">...</span></li>';
            html += '<li class="page-item"><a class="page-link" href="#" data-page="'+totalPages+'">'+totalPages+'</a></li>';
        }
        html += '<li class="page-item '+(currentPage===totalPages?'disabled':'')+'"><a class="page-link" href="#" data-page="'+(currentPage+1)+'">Next <i class="bi bi-chevron-right"></i></a></li>';
        html += '</ul></nav>';
        html += '<div class="pagination-info">Page <strong>'+currentPage+'</strong> of <strong>'+totalPages+'</strong> ('+rows.length+' records)</div>';
        container.innerHTML = html;
        container.querySelectorAll('a[data-page]').forEach(function(a){
            a.addEventListener('click', function(e){
                e.preventDefault();
                var pg = parseInt(this.getAttribute('data-page'));
                if(pg >= 1 && pg <= totalPages) renderPage(pg);
            });
        });
    }

    renderPage(1);
})();
</script>
