@{
    ViewData["Title"] = "Approved Expense Reports";
    Layout = "~/Views/Shared/_FinanceLayout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<style>
    :root {
        --d-primary: #1a6bb5;
        --d-accent: #2ec4b6;
        --d-bg: #f7fbfc;
        --d-card: #ffffff;
        --d-border: #e9eef6;
        --d-text: #0f1724;
        --d-muted: #6b7280;
    }

    /* Filter card styles (match Reimbursements view) */
    .filter-card {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 8px;
        padding: 12px 12px;
        margin-bottom: 12px;
    }
    .filter-card .form-label {
        font-size: .85rem;
        font-weight: 600;
        color: var(--d-muted);
        margin-bottom: 4px;
    }
    .filter-card .form-control,
    .filter-card .form-select {
        border-color: var(--d-border);
        border-radius: 6px;
        font-size: .88rem;
        padding: 6px 8px;
    }
    .filter-card .form-control:focus,
    .filter-card .form-select:focus {
        border-color: var(--d-primary);
        box-shadow: 0 0 0 0.2rem rgba(26, 107, 181, 0.1);
    }
    .quick-filter-btn {
        padding: 6px 12px;
        border: 1px solid var(--d-border);
        background: var(--d-card);
        color: var(--d-text);
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .quick-filter-btn:hover {
        background: var(--d-primary);
        color: #fff;
        border-color: var(--d-primary);
    }
    .quick-filter-btn.active {
        background: var(--d-primary);
        color: #fff;
        border-color: var(--d-primary);
        box-shadow: 0 0 0 3px rgba(26, 107, 181, 0.1);
    }

    .page-wrapper {
        background: var(--d-bg);
        min-height: calc(100vh - 80px);
        padding: 28px 0 40px;
    }

    .page-header {
        margin-bottom: 28px;
    }

    .page-title {
        font-size: 1.65rem;
        font-weight: 700;
        color: var(--d-text);
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .page-title i {
        color: var(--d-primary);
        font-size: 1.8rem;
    }

    .page-subtitle {
        color: var(--d-muted);
        font-size: .95rem;
        margin-top: 4px;
    }

    .table-card {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 10px;
        overflow: hidden;
    }

    .dash-table {
        width: 100%;
        margin-bottom: 0;
    }

    .dash-table thead th {
        background: #f8fafc;
        color: var(--d-muted);
        font-weight: 600;
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        padding: 12px 16px;
        border: none;
    }

    .dash-table tbody td {
        padding: 14px 16px;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
        color: var(--d-text);
        font-size: .9rem;
    }

    .dash-table tbody tr:last-child td {
        border-bottom: none;
    }

    .dash-table tbody tr:hover {
        background: #f8fafc;
    }

    /* neutral status text (no colored badges) */
    .status-text { font-weight: 600; color: var(--d-text); font-size: .88rem; }

    .view-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        background: rgba(26, 107, 181, .08);
        color: var(--d-primary);
        border: 1px solid rgba(26, 107, 181, .2);
        border-radius: 6px;
        font-size: .85rem;
        font-weight: 500;
        text-decoration: none;
        transition: all .2s;
    }

    .view-btn:hover { background: rgba(26,107,181,.12); color:#155a9a; }

    .approve-btn, .reject-btn {
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        color: #fff;
        border: none;
        cursor: pointer;
    }

    .approve-btn { background: #10b981; }
    .approve-btn:hover { filter: brightness(.95); }

    .reject-btn { background: #ef4444; }
    .reject-btn:hover { filter: brightness(.95); }

    .empty-state {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 10px;
        padding: 40px;
        text-align: center;
    }

    .empty-state i {
        font-size: 3rem;
        color: var(--d-border);
        margin-bottom: 16px;
    }

    .empty-state p {
        color: var(--d-muted);
        margin: 0;
    }
    /* dashboard-like card styles for consistency */
    .dash-card {
        background: var(--d-card);
        border: 1px solid var(--d-border);
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 12px;
    }
    .dash-card-head {
        padding: 8px 12px;
        display:flex;
        align-items:center;
        justify-content:space-between;
        border-bottom:1px solid var(--d-border);
    }
    .dash-card-title { font-size: .95rem; font-weight:600; color:var(--d-text); display:flex; align-items:center; gap:8px; }
    .dash-card-body { padding:8px 12px; }
    .quick-filter button { margin-left:6px; }

    /* Align filter controls in card header */
    .dash-card-head .form-control-sm {
        width: 140px;
        padding: 6px 8px;
        height: 34px;
        box-sizing: border-box;
    }
    .dash-card-head .quick-filter {
        display: flex;
        gap: 6px;
        align-items: center;
    }
    .dash-card-head .quick-filter .btn {
        padding: 4px 8px;
        font-size: .78rem;
    }
    @@media (max-width: 768px) {
        .dash-card-head { flex-direction: column; align-items: flex-start; gap: 8px; }
        .dash-card-head .form-control-sm { width: 100%; }
        .dash-card-head .quick-filter { width: 100%; justify-content: flex-start; }
    }
</style>

<div class="page-wrapper">
    <div class="container-fluid px-4">
        <div class="page-header">
            @* <h1 class="page-title">
                <i class="bi bi-check2-circle"></i>
                Approved Expense Reports
            </h1> *@
            <p class="page-subtitle">Reports ready for reimbursement processing.</p>
        </div>

    <script>
    // Auto-apply filters for Approved Reports (like Reimbursements)
    function highlightActiveFilter() {
        var startInput = document.getElementById('approvedStart');
        var endInput = document.getElementById('approvedEnd');
        if (!startInput || !endInput) return;

        var start = new Date(startInput.value);
        var end = new Date(endInput.value);
        var now = new Date();
        var today = new Date(now.getFullYear(), now.getMonth(), now.getDate());

        // Remove active class from all buttons
        document.querySelectorAll('.quick-filter-btn').forEach(function(btn) {
            btn.classList.remove('active');
        });

        // Determine which range matches current filter
        var matchingRange = null;

        // Check if it's today range
        if (start.getTime() === today.getTime() && end.getTime() === today.getTime()) {
            matchingRange = 'today';
        }
        // Check if it's week range (Sunday to today)
        else {
            var weekStart = new Date(today);
            weekStart.setDate(today.getDate() - today.getDay());
            if (start.getTime() === weekStart.getTime() && end.getTime() === today.getTime()) {
                matchingRange = 'week';
            }
        }

        // Check if it's month range (1st to today)
        if (!matchingRange) {
            var monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
            if (start.getTime() === monthStart.getTime() && end.getTime() === today.getTime()) {
                matchingRange = 'month';
            }
        }

        // Check if it's year range (Jan 1 to today)
        if (!matchingRange) {
            var yearStart = new Date(now.getFullYear(), 0, 1);
            if (start.getTime() === yearStart.getTime() && end.getTime() === today.getTime()) {
                matchingRange = 'year';
            }
        }

        // Apply active class to matching button
        if (matchingRange) {
            var activeBtn = document.querySelector('[data-range="' + matchingRange + '"]');
            if (activeBtn) {
                activeBtn.classList.add('active');
            }
        }
    }

    document.addEventListener('DOMContentLoaded', function(){
        highlightActiveFilter();

        var filtersForm = document.getElementById('approvedFilters');
        if(filtersForm){
            var inputs = filtersForm.querySelectorAll('input, select');
            inputs.forEach(function(input){ 
                input.addEventListener('change', function(){ 
                    highlightActiveFilter();
                    filtersForm.submit();
                }); 
            });
        }

        // Quick-range buttons reuse the same class
        document.querySelectorAll('.quick-filter-btn[data-range]').forEach(function(btn){
            btn.addEventListener('click', function(){
                var range = btn.getAttribute('data-range');
                var now = new Date();
                var start;
                if(range === 'today') start = new Date(now.getFullYear(), now.getMonth(), now.getDate());
                else if(range === 'week') start = new Date(now.getFullYear(), now.getMonth(), now.getDate() - now.getDay());
                else if(range === 'month') start = new Date(now.getFullYear(), now.getMonth(), 1);
                else if(range === 'year') start = new Date(now.getFullYear(), 0, 1);

                var s = document.getElementById('approvedStart');
                var e = document.getElementById('approvedEnd');
                if(s && start) s.value = start.toISOString().slice(0,10);
                if(e) e.value = now.toISOString().slice(0,10);
                setTimeout(function(){ 
                    highlightActiveFilter();
                    filtersForm?.submit();
                }, 150);
            });
        });
    });
    </script>
        <!-- Filters: styled like Reimbursements filter card -->
        <div class="filter-card">
            <form id="approvedFilters" class="row g-3" method="get" action="@Context.Request.Path">
                <div class="col-md-3">
                    <label class="form-label">From</label>
                    <input type="date" name="start" id="approvedStart" class="form-control form-control-sm" value="@((string)ViewBag.FilterStart ?? "")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">To</label>
                    <input type="date" name="end" id="approvedEnd" class="form-control form-control-sm" value="@((string)ViewBag.FilterEnd ?? "")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    @{ var _selReimb = ((string)ViewBag.FilterReimbursed ?? "pending").ToLowerInvariant(); }
                    <select id="approvedReimbursed" name="reimbursed" class="form-select form-select-sm">
                        @if (_selReimb == "pending") {
                            <option value="pending" selected>Pending</option>
                            <option value="initiated">Initiated</option>
                            <option value="done">Done</option>
                        } else if (_selReimb == "initiated") {
                            <option value="pending">Pending</option>
                            <option value="initiated" selected>Initiated</option>
                            <option value="done">Done</option>
                        } else if (_selReimb == "done") {
                            <option value="pending">Pending</option>
                            <option value="initiated">Initiated</option>
                            <option value="done" selected>Done</option>
                        } else {
                            <option value="pending">Pending</option>
                            <option value="initiated">Initiated</option>
                            <option value="done">Done</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">&nbsp;</label>
                    <div class="d-flex gap-2">
                        <button type="button" class="quick-filter-btn" data-range="today">Today</button>
                        <button type="button" class="quick-filter-btn" data-range="week">Week</button>
                        <button type="button" class="quick-filter-btn" data-range="month">Month</button>
                        <button type="button" class="quick-filter-btn" data-range="year">Year</button>
                    </div>
                </div>
            </form>
        </div>

        @if(ViewBag.ApprovedReports != null && ((List<CEMS.Models.PendingExpenseReportDto>)ViewBag.ApprovedReports).Count > 0)
        {
            <div class="dash-card">
                <div class="dash-card-head">
                    <h4 class="dash-card-title"><i class="bi bi-check2-circle"></i> Approved Reports</h4>
                </div>
                <div class="dash-card-body">
                    <div class="table-responsive">
                        <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Report ID</th>
                                <th>Driver</th>
                                <th>Total Amount</th>
                                <th>Submitted Date</th>
                                <th>Budget Status</th>
                                <th>Approver</th>
                                <th style="width:220px;">Actions</th>
                            </tr>
                        </thead>
                            <tbody>
                                @foreach(var dto in ViewBag.ApprovedReports as List<CEMS.Models.PendingExpenseReportDto>)
                                {
                                    var r = dto.Report;
                                <tr>
                                    <td><strong>@r.Id</strong></td>
                                    <td>
                                        @{
                                            var nameMap = ViewBag.UserFullNames as Dictionary<string, string> ?? new Dictionary<string, string>();
                                            var driverDisplay = dto.Report?.UserId != null && nameMap.ContainsKey(dto.Report.UserId) ? nameMap[dto.Report.UserId] : (dto.UserName ?? "Unknown");
                                        }
                                        @driverDisplay
                                    </td>
                                    <td><strong>₱@r.TotalAmount.ToString("N2")</strong></td>
                                    <td>@r.SubmissionDate.ToLocalTime().ToString("MMM d, yyyy")</td>
                                    <td><span class="status-text">@(r.BudgetCheck)</span></td>
                                    <td>
                                        @{
                                            var approvals = ViewBag.ReportApprovals as Dictionary<int, Dictionary<string, string>> ?? new Dictionary<int, Dictionary<string, string>>();
                                            if (approvals.ContainsKey(r.Id) && approvals[r.Id].Any())
                                            {
                                                // prefer Manager then CEO then Finance
                                                var names = approvals[r.Id];
                                                string approverText = "";
                                                if (names.ContainsKey("Manager")) approverText = names["Manager"];
                                                else if (names.ContainsKey("CEO")) approverText = names["CEO"];
                                                else if (names.ContainsKey("Finance")) approverText = names["Finance"];
                                                else approverText = string.Join(", ", names.Values);
                                                <div style="font-weight:600;">@approverText</div>
                                            }
                                            else
                                            {
                                                <span style="color:var(--d-muted);font-size:.88rem;">—</span>
                                            }
                                        }
                                    </td>
                                    <td>
                                            <a class="view-btn" href="@Url.Action("ReportDetails","Finance", new { id = r.Id })">View</a>
                                            @{
                                                var payments = ViewBag.Payments as Dictionary<int, CEMS.Models.ReimbursementPayment> ?? new Dictionary<int, CEMS.Models.ReimbursementPayment>();
                                                var payment = payments.ContainsKey(r.Id) ? payments[r.Id] : null;
                                            }
                                            @if (r.Reimbursed)
                                            {
                                                <span class="status-text" style="margin-left:8px;color:#10b981;">Done</span>
                                            }
                                            else if (payment != null)
                                            {
                                                <span class="status-text" style="margin-left:8px;color:#f59e0b;">Initiated</span>
                                                <a class="view-btn" style="margin-left:6px;" href="@payment.CheckoutUrl" target="_blank">Open Payment</a>
                                            }
                                            else
                                            {
                                                <form method="post" asp-action="Reimburse" asp-controller="Finance" style="display:inline-block;margin-left:6px;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@r.Id" />
                                                    <button type="submit" class="approve-btn">Reimburse</button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p>No approved reports at this time.</p>
            </div>
        }
    </div>
</div>
