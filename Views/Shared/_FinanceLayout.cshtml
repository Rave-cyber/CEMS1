<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CEMS Finance</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
</head>
<body>
    @{ 
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        Func<string, string, string> active = (c, a) =>
        {
            if (string.Equals(c, currentController, System.StringComparison.OrdinalIgnoreCase) &&
                string.Equals(a, currentAction, System.StringComparison.OrdinalIgnoreCase))
            {
                return "active";
            }
            return string.Empty;
        };
        var userName = ViewBag.UserFullName ?? User.Identity?.Name ?? "User";
        var initial = userName.Length > 0 ? userName[0].ToString().ToUpper() : "U";
        var pageTitle = ViewData["Title"]?.ToString() ?? "Finance Portal";
    }

    <!-- ══ Top Navigation Bar (mobile + desktop) ══ -->
    <header class="driver-topbar">
        <!-- Mobile: hamburger -->
        <button class="driver-topbar-toggle d-md-none" type="button"
                data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas"
                aria-controls="sidebarOffcanvas" aria-label="Toggle navigation">
            <i class="bi bi-list"></i>
        </button>

        <!-- Mobile: logo -->
        <a class="d-flex d-md-none align-items-center text-decoration-none ms-2"
           asp-controller="Finance" asp-action="Dashboard">
            <img src="@(Url.Content("~/images/logo.png"))" alt="CEMS" class="driver-topbar-logo-img" />
        </a>

        <!-- Breadcrumb Navigation (desktop) -->
        <nav class="topbar-breadcrumb d-none d-md-flex" aria-label="breadcrumb">
            <a class="breadcrumb-link" asp-controller="Finance" asp-action="Dashboard">
                <i class="bi bi-house-door-fill"></i>
                <span>Home</span>
            </a>
            <i class="bi bi-chevron-right breadcrumb-sep"></i>
            <span class="breadcrumb-current">@pageTitle</span>
        </nav>

        <!-- Date Display (beside profile) -->
        <div class="d-none d-md-flex align-items-center me-3" style="gap: 8px; font-size: 0.85rem; color: #64748b;">
            <i class="bi bi-calendar3" style="color: #0288d1;"></i>
            <span>@DateTime.Now.ToString("ddd, MMM d")</span>
        </div>

        <!-- Notification Bell -->
        <partial name="_NotificationBell" />

        <!-- Profile dropdown -->
        <div>
            <div class="dropdown">
                <button class="driver-profile-btn dropdown-toggle" type="button"
                        id="financeProfileDropdown"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                        data-bs-offset="0,8">
                    <div class="driver-avatar">@initial</div>
                    <div class="driver-profile-info d-none d-sm-flex">
                        <span class="driver-profile-name">@userName</span>
                        <span class="driver-profile-role">Finance</span>
                    </div>
                    <i class="bi bi-chevron-down driver-profile-caret d-none d-sm-inline-block"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end driver-profile-dropdown"
                    aria-labelledby="financeProfileDropdown">
                    <li>
                        <div class="driver-dropdown-header">
                            <div class="driver-avatar driver-avatar--lg">@initial</div>
                            <div class="driver-dropdown-info">
                                <div class="driver-dropdown-name">@userName</div>
                                <span class="driver-dropdown-badge">
                                    <i class="bi bi-wallet2 me-1"></i>Finance
                                </span>
                            </div>
                        </div>
                    </li>
                    <li><hr class="dropdown-divider my-0"></li>
                    <li>
                        <a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#profileModal" style="padding:10px 16px; font-size:.875rem;">
                            <i class="bi bi-person-circle me-2" style="color:#1a6bb5;"></i>My Profile
                        </a>
                    </li>
                    <li><hr class="dropdown-divider my-0"></li>
                    <li>
                        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                            <button type="submit" class="dropdown-item" style="padding:10px 16px; font-size:.875rem; color:#ef4444;">
                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </header>

    <!-- ══ Desktop Sidebar ══ -->
    <aside class="driver-sidebar d-none d-md-flex flex-column">
        <div class="brand">
            <a class="d-flex align-items-center text-decoration-none" asp-controller="Finance" asp-action="Dashboard">
                <img src="@(Url.Content("~/images/logo.png"))" alt="CEMS" class="driver-logo" />
            </a>
        </div>
        <nav class="nav flex-column p-3">
            <a class="nav-link driver-nav-link @(active("Finance","Dashboard"))" asp-controller="Finance" asp-action="Dashboard">
                <i class="bi bi-speedometer2"></i>
                <span>Dashboard</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
            <a class="nav-link driver-nav-link @(active("Finance","ApprovedReports"))" asp-controller="Finance" asp-action="ApprovedReports">
                <i class="bi bi-check2-circle"></i>
                <span>Approved Reports</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
            <a class="nav-link driver-nav-link @(active("Finance","Reimbursements"))" asp-controller="Finance" asp-action="Reimbursements">
                <i class="bi bi-arrow-left-right"></i>
                <span>Reimbursements</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
            <a class="nav-link driver-nav-link @(active("Finance","Payments"))" asp-controller="Finance" asp-action="Payments">
                <i class="bi bi-credit-card"></i>
                <span>Payment History</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
        </nav>
    </aside>

    <!-- ══ Mobile Offcanvas Sidebar ══ -->
    <div class="offcanvas offcanvas-start d-md-none" tabindex="-1"
         id="sidebarOffcanvas" aria-labelledby="sidebarOffcanvasLabel">
        <div class="offcanvas-header">
            <a class="d-flex align-items-center text-decoration-none"
               asp-controller="Finance" asp-action="Dashboard">
                <img src="@(Url.Content("~/images/logo.png"))" alt="CEMS"
                     style="height:48px;width:auto;object-fit:contain;" />
            </a>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0">
            <nav class="nav flex-column p-3">
                <a class="nav-link driver-nav-link @(active("Finance","Dashboard"))" asp-controller="Finance" asp-action="Dashboard">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
                <a class="nav-link driver-nav-link @(active("Finance","ApprovedReports"))" asp-controller="Finance" asp-action="ApprovedReports">
                    <i class="bi bi-check2-circle"></i>
                    <span>Approved Reports</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
                <a class="nav-link driver-nav-link @(active("Finance","Reimbursements"))" asp-controller="Finance" asp-action="Reimbursements">
                    <i class="bi bi-arrow-left-right"></i>
                    <span>Reimbursements</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
                <a class="nav-link driver-nav-link @(active("Finance","Payments"))" asp-controller="Finance" asp-action="Payments">
                    <i class="bi bi-credit-card"></i>
                    <span>Payment History</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
            </nav>
        </div>
    </div>

    <!-- ══ Main Content ══ -->
    <div class="driver-body-wrapper">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CEMS Finance
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <form id="__notifAntiForgery" method="post" style="display:none;">@Html.AntiForgeryToken()</form>
    <partial name="_NotificationScripts" />
    <partial name="_ProfileModal" />
</body>
</html>
