<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CEMS Super Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        Func<string, string, string> active = (c, a) =>
        {
            if (string.Equals(c, currentController, System.StringComparison.OrdinalIgnoreCase) &&
                string.Equals(a, currentAction, System.StringComparison.OrdinalIgnoreCase))
            {
                return "active";
            }
            return string.Empty;
        };

        var userName = User.Identity?.Name ?? "User";
        var initial = string.IsNullOrEmpty(userName) ? "?" : userName[0].ToString().ToUpper();
        var pageTitle = ViewData["Title"]?.ToString() ?? "Dashboard";
    }

    <!-- ══ Top Navigation Bar (mobile + desktop) ══ -->
    <header class="driver-topbar">
        <!-- Mobile: hamburger -->
        <button class="driver-topbar-toggle d-md-none" type="button"
                data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas"
                aria-controls="sidebarOffcanvas" aria-label="Toggle navigation">
            <i class="bi bi-list"></i>
        </button>

        <!-- Mobile: logo -->
        <a class="d-flex d-md-none align-items-center text-decoration-none ms-2"
           asp-controller="SuperAdmin" asp-action="Dashboard">
            <img src="@(Url.Content("~/images/logo.png"))" alt="CEMS" class="driver-topbar-logo-img" />
        </a>

        <!-- Breadcrumb Navigation (desktop) -->
        <nav class="topbar-breadcrumb d-none d-md-flex" aria-label="breadcrumb">
            <a class="breadcrumb-link" asp-controller="SuperAdmin" asp-action="Dashboard">
                <i class="bi bi-house-door-fill"></i>
                <span>Home</span>
            </a>
            <i class="bi bi-chevron-right breadcrumb-sep"></i>
            <span class="breadcrumb-current">@pageTitle</span>
        </nav>

        <!-- Date Display (beside profile) -->
        <div class="d-none d-md-flex align-items-center me-3" style="gap: 8px; font-size: 0.85rem; color: #64748b;">
            <i class="bi bi-calendar3" style="color: #0288d1;"></i>
            <span>@DateTime.Now.ToString("ddd, MMM d")</span>
        </div>

        <!-- Profile dropdown -->
        <div>
            <div class="dropdown">
                <button class="driver-profile-btn dropdown-toggle" type="button"
                        id="superAdminProfileDropdown"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                        data-bs-offset="0,8">
                    <div class="driver-avatar">@initial</div>
                    <div class="driver-profile-info d-none d-sm-flex">
                        <span class="driver-profile-name">@userName</span>
                        <span class="driver-profile-role">Super Admin</span>
                    </div>
                    <i class="bi bi-chevron-down driver-profile-caret d-none d-sm-inline-block"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end driver-profile-dropdown"
                    aria-labelledby="superAdminProfileDropdown">
                    <li>
                        <div class="driver-dropdown-header">
                            <div class="driver-avatar driver-avatar--lg">@initial</div>
                            <div class="driver-dropdown-info">
                                <div class="driver-dropdown-name">@userName</div>
                                <span class="driver-dropdown-badge">
                                    <i class="bi bi-shield-check me-1"></i>Super Admin
                                </span>
                            </div>
                        </div>
                    </li>
                    <li><hr class="dropdown-divider my-0"></li>
                    <li><partial name="_LoginPartial" /></li>
                </ul>
            </div>
        </div>
    </header>

    <!-- ══ Desktop Sidebar ══ -->
    <aside class="driver-sidebar d-none d-md-flex flex-column">
        <div class="brand">
            <a class="d-flex align-items-center text-decoration-none" asp-controller="SuperAdmin" asp-action="Dashboard">
                <img src="@(Url.Content("~/images/logo.png"))" alt="CEMS" class="driver-logo" />
            </a>
        </div>
        <nav class="nav flex-column p-3">
            <a class="nav-link driver-nav-link @(active("SuperAdmin","Dashboard"))" asp-controller="SuperAdmin" asp-action="Dashboard">
                <i class="bi bi-speedometer2"></i>
                <span>Dashboard</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
            <a class="nav-link driver-nav-link @(active("SuperAdmin","Users"))" asp-controller="SuperAdmin" asp-action="Users">
                <i class="bi bi-people"></i>
                <span>User Management</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
            <a class="nav-link driver-nav-link @(active("SuperAdmin","AuditLogs"))" asp-controller="SuperAdmin" asp-action="AuditLogs">
                <i class="bi bi-journal-text"></i>
                <span>Audit Logs</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
            <a class="nav-link driver-nav-link @(active("SuperAdmin","FuelPrices"))" asp-controller="SuperAdmin" asp-action="FuelPrices">
                <i class="bi bi-fuel-pump"></i>
                <span>Fuel Prices</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
        </nav>
    </aside>

    <!-- ══ Mobile Offcanvas Sidebar ══ -->
    <div class="offcanvas offcanvas-start d-md-none" tabindex="-1" id="sidebarOffcanvas" aria-labelledby="sidebarOffcanvasLabel">
        <div class="offcanvas-header">
            <a class="d-flex align-items-center text-decoration-none"
               asp-controller="SuperAdmin" asp-action="Dashboard">
                <img src="@(Url.Content("~/images/logo.png"))" alt="CEMS"
                     style="height:48px;width:auto;object-fit:contain;" />
            </a>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0 d-flex flex-column">
            <nav class="nav flex-column p-3">
                <a class="nav-link driver-nav-link @(active("SuperAdmin","Dashboard"))" asp-controller="SuperAdmin" asp-action="Dashboard">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
                <a class="nav-link driver-nav-link @(active("SuperAdmin","Users"))" asp-controller="SuperAdmin" asp-action="Users">
                    <i class="bi bi-people"></i>
                    <span>User Management</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
                <a class="nav-link driver-nav-link @(active("SuperAdmin","AuditLogs"))" asp-controller="SuperAdmin" asp-action="AuditLogs">
                    <i class="bi bi-journal-text"></i>
                    <span>Audit Logs</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
                <a class="nav-link driver-nav-link @(active("SuperAdmin","FuelPrices"))" asp-controller="SuperAdmin" asp-action="FuelPrices">
                    <i class="bi bi-fuel-pump"></i>
                    <span>Fuel Prices</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
            </nav>
        </div>
    </div>

    <div class="w-100">
        <main role="main" class="pb-3">
            <!-- Toast container for transient notifications (replaces top alerts) -->
            <div aria-live="polite" aria-atomic="true" class="position-relative">
                <div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3" style="z-index:1080;">
                    @if (TempData["Success"] != null)
                    {
                        <div class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
                            <div class="d-flex">
                                <div class="toast-body">
                                    @TempData["Success"]
                                </div>
                                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                            </div>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="toast align-items-center text-bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true">
                            <div class="d-flex">
                                <div class="toast-body">
                                    @TempData["Error"]
                                </div>
                                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                            </div>
                        </div>
                    }
                </div>
            </div>
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CEMS
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Auto-show and auto-hide bootstrap toasts rendered from TempData
        (function () {
            try {
                document.addEventListener('DOMContentLoaded', function () {
                    var container = document.getElementById('toastContainer');
                    if (!container) return;
                    var toasts = container.querySelectorAll('.toast');
                    toasts.forEach(function (t) {
                        var toast = new bootstrap.Toast(t, { delay: 1000 }); // 1s visible
                        toast.show();
                    });
                });
            } catch (e) { console.warn('Toast init failed', e); }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
