<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CEMS CEO</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
</head>
<body>
    @{ 
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        Func<string, string, string> active = (c, a) =>
        {
            if (string.Equals(c, currentController, System.StringComparison.OrdinalIgnoreCase) &&
                string.Equals(a, currentAction, System.StringComparison.OrdinalIgnoreCase))
            {
                return "active";
            }
            return string.Empty;
        };
        var userName = User.Identity?.Name ?? "User";
        var initial = userName.Length > 0 ? userName[0].ToString().ToUpper() : "U";
        var pageTitle = ViewData["Title"]?.ToString() ?? "CEO Portal";
    }

    <!-- ══ Top Navigation Bar (mobile + desktop) ══ -->
    <header class="driver-topbar">
        <!-- Mobile: hamburger -->
        <button class="driver-topbar-toggle d-md-none" type="button"
                data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas"
                aria-controls="sidebarOffcanvas" aria-label="Toggle navigation">
            <i class="bi bi-list"></i>
        </button>

        <!-- Mobile: logo -->
        <a class="d-flex d-md-none align-items-center text-decoration-none ms-2"
           asp-controller="CEO" asp-action="Dashboard">
            <img src="@(Url.Content("~/images/logo.png"))" alt="CEMS" class="driver-topbar-logo-img" />
        </a>

        <!-- Breadcrumbs/Title (left side desktop) -->
        <div class="d-none d-md-flex align-items-center" style="margin-left: 20px; gap: 8px; font-size: 0.9rem; color: #475569;">
            <i class="bi bi-house-door" style="color: #0288d1;"></i>
            <span style="font-weight: 600; color: #1e293b;">@(ViewData["Title"] ?? "CEO")</span>
        </div>

        <!-- Spacer for desktop -->
        <div class="d-none d-md-flex flex-grow-1"></div>

        <!-- Date Display (beside profile) -->
        <div class="d-none d-md-flex align-items-center me-3" style="gap: 8px; font-size: 0.85rem; color: #64748b;">
            <i class="bi bi-calendar3" style="color: #0288d1;"></i>
            <span>@DateTime.Now.ToString("ddd, MMM d")</span>
        </div>

        <!-- Profile dropdown -->
        <div>
            <div class="dropdown">
                <button class="driver-profile-btn dropdown-toggle" type="button"
                        id="ceoProfileDropdown"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                        data-bs-offset="0,8">
                    <div class="driver-avatar">@initial</div>
                    <div class="driver-profile-info d-none d-sm-flex">
                        <span class="driver-profile-name">@userName</span>
                        <span class="driver-profile-role">CEO</span>
                    </div>
                    <i class="bi bi-chevron-down driver-profile-caret d-none d-sm-inline-block"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end driver-profile-dropdown"
                    aria-labelledby="ceoProfileDropdown">
                    <li>
                        <div class="driver-dropdown-header">
                            <div class="driver-avatar driver-avatar--lg">@initial</div>
                            <div class="driver-dropdown-info">
                                <div class="driver-dropdown-name">@userName</div>
                                <span class="driver-dropdown-badge">
                                    <i class="bi bi-crown me-1"></i>CEO
                                </span>
                            </div>
                        </div>
                    </li>
                    <li><hr class="dropdown-divider my-0"></li>
                    <li><partial name="_LoginPartial" /></li>
                </ul>
            </div>
        </div>
    </header>

    <!-- ══ Desktop Sidebar ══ -->
    <aside class="driver-sidebar d-none d-md-flex flex-column">
        <div class="brand">
            <a class="d-flex align-items-center text-decoration-none" asp-controller="CEO" asp-action="Dashboard">
                <img src="@(Url.Content("~/images/logo.png"))" alt="CEMS" class="driver-logo" />
            </a>
        </div>
        <nav class="nav flex-column p-3">
            <a class="nav-link driver-nav-link @(active("CEO","Dashboard"))" asp-controller="CEO" asp-action="Dashboard">
                <i class="bi bi-speedometer2"></i>
                <span>Dashboard</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
            <a class="nav-link driver-nav-link @(active("CEO","Approvals"))" asp-controller="CEO" asp-action="Approvals">
                <i class="bi bi-exclamation-triangle"></i>
                <span>Over-Budget Reports</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
            <a class="nav-link driver-nav-link @(active("CEO","Budget"))" asp-controller="CEO" asp-action="Budget">
                <i class="bi bi-calculator"></i>
                <span>Budget Management</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
            <a class="nav-link driver-nav-link @(active("CEO","ExpenseOverview"))" asp-controller="CEO" asp-action="ExpenseOverview">
                <i class="bi bi-graph-up"></i>
                <span>Expense Overview</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
            <a class="nav-link driver-nav-link @(active("CEO","Analytics"))" asp-controller="CEO" asp-action="Analytics">
                <i class="bi bi-bar-chart"></i>
                <span>Reports &amp; Analytics</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
        </nav>
    </aside>

    <!-- ══ Mobile Offcanvas Sidebar ══ -->
    <div class="offcanvas offcanvas-start d-md-none" tabindex="-1"
         id="sidebarOffcanvas" aria-labelledby="sidebarOffcanvasLabel">
        <div class="offcanvas-header">
            <a class="d-flex align-items-center text-decoration-none"
               asp-controller="CEO" asp-action="Dashboard">
                <img src="@(Url.Content("~/images/logo.png"))" alt="CEMS"
                     style="height:48px;width:auto;object-fit:contain;" />
            </a>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0">
            <nav class="nav flex-column p-3">
                <a class="nav-link driver-nav-link @(active("CEO","Dashboard"))" asp-controller="CEO" asp-action="Dashboard">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
                <a class="nav-link driver-nav-link @(active("CEO","Approvals"))" asp-controller="CEO" asp-action="Approvals">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>Over-Budget Reports</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
                <a class="nav-link driver-nav-link @(active("CEO","Budget"))" asp-controller="CEO" asp-action="Budget">
                    <i class="bi bi-calculator"></i>
                    <span>Budget Management</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
                <a class="nav-link driver-nav-link @(active("CEO","ExpenseOverview"))" asp-controller="CEO" asp-action="ExpenseOverview">
                    <i class="bi bi-graph-up"></i>
                    <span>Expense Overview</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
                <a class="nav-link driver-nav-link @(active("CEO","Analytics"))" asp-controller="CEO" asp-action="Analytics">
                    <i class="bi bi-bar-chart"></i>
                    <span>Reports &amp; Analytics</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
            </nav>
        </div>
    </div>

    <!-- ══ Main Content ══ -->
    <div class="driver-body-wrapper">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
        </div>
    </header>
    <div class="w-100">
        <main role="main" class="pb-3">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CEMS
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
