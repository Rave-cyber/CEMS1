@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CEMS</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #2ec4b6;
            --primary-dark: #0d8b7d;
            --accent: #1a6bb5;
            --accent-dark: #12507d;
            --surface: #ffffff;
            --bg: #f0f7fa;
            --text: #0f1724;
            --text-muted: #5a6a7a;
            --border: #e2e8f0;
            --danger: #ef4444;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        html, body {
            height: 100%; width: 100%;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        body { background: var(--bg); overflow-x: hidden; }

        /* ── Animated background ── */
        .bg-grid {
            position: fixed; inset: 0; z-index: 0; pointer-events: none;
            background-image: radial-gradient(circle at 1px 1px, rgba(26,107,181,.07) 1px, transparent 0);
            background-size: 40px 40px;
        }
        .bg-glow {
            position: fixed; z-index: 0; pointer-events: none; border-radius: 50%;
            filter: blur(100px); opacity: .45;
        }
        .bg-glow--1 { width: 600px; height: 600px; top: -10%; left: -5%; background: rgba(46,196,182,.3); animation: glow-drift 18s ease-in-out infinite alternate; }
        .bg-glow--2 { width: 500px; height: 500px; bottom: -8%; right: -5%; background: rgba(26,107,181,.25); animation: glow-drift 22s ease-in-out infinite alternate-reverse; }
        .bg-glow--3 { width: 350px; height: 350px; top: 40%; left: 55%; background: rgba(46,196,182,.15); animation: glow-drift 15s ease-in-out infinite alternate; }

        @@keyframes glow-drift {
            0%   { transform: translate(0, 0) scale(1); }
            100% { transform: translate(60px, -40px) scale(1.15); }
        }

        /* ── Layout ── */
        .login-page {
            position: relative; z-index: 1;
            min-height: 100vh; display: grid;
            grid-template-columns: 1fr 1fr;
            align-items: center;
        }

        /* ── Left Panel ── */
        .brand-panel {
            display: flex; flex-direction: column; justify-content: center;
            padding: 60px clamp(40px, 5vw, 80px);
            position: relative; min-height: 100vh;
        }

        .brand-panel > * {
            opacity: 0; transform: translateY(24px);
            animation: fadeUp .6s ease forwards;
        }
        .brand-panel > *:nth-child(1) { animation-delay: .1s; }
        .brand-panel > *:nth-child(2) { animation-delay: .2s; }
        .brand-panel > *:nth-child(3) { animation-delay: .35s; }
        .brand-panel > *:nth-child(4) { animation-delay: .5s; }
        .brand-panel > *:nth-child(5) { animation-delay: .65s; }

        @@keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

        .brand-logo {
            display: flex; align-items: center; gap: 10px;
            font-weight: 800; font-size: 1.6rem; margin-bottom: 48px;
            text-decoration: none;
            background: linear-gradient(135deg, var(--accent), var(--primary));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .brand-logo i {
            font-size: 1.4rem;
            background: linear-gradient(135deg, var(--accent), var(--primary));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .brand-img {
            width: 56px; height: 56px; object-fit: contain; border-radius: 8px;
            display: inline-block; vertical-align: middle;
        }

        .brand-title {
            font-size: clamp(2rem, 3.5vw, 2.8rem); font-weight: 800;
            line-height: 1.2; color: var(--text); margin-bottom: 16px;
        }
        .brand-title span {
            background: linear-gradient(135deg, var(--accent), var(--primary));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .brand-sub {
            font-size: 1.05rem; color: var(--text-muted);
            line-height: 1.7; max-width: 440px; margin-bottom: 40px;
        }

        /* Feature pills */
        .feature-list { display: flex; flex-direction: column; gap: 16px; margin-bottom: 40px; }
        .feature-item {
            display: flex; align-items: center; gap: 14px;
            opacity: 0; transform: translateX(-16px);
            animation: slideRight .5s ease forwards;
        }
        .feature-item:nth-child(1) { animation-delay: .6s; }
        .feature-item:nth-child(2) { animation-delay: .75s; }
        .feature-item:nth-child(3) { animation-delay: .9s; }
        .feature-item:nth-child(4) { animation-delay: 1.05s; }

        @@keyframes slideRight { to { opacity: 1; transform: translateX(0); } }

        .feature-icon {
            width: 42px; height: 42px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: .95rem; flex-shrink: 0;
        }
        .feature-icon--blue  { background: rgba(26,107,181,.1); color: var(--accent); }
        .feature-icon--green { background: rgba(46,196,182,.12); color: var(--primary-dark); }
        .feature-icon--amber { background: rgba(245,158,11,.1); color: #d97706; }
        .feature-icon--rose  { background: rgba(239,68,68,.08); color: #ef4444; }

        .feature-text { font-size: .92rem; color: var(--text); font-weight: 500; }
        .feature-text small { display: block; font-size: .78rem; color: var(--text-muted); font-weight: 400; margin-top: 2px; }

        /* Trust bar */
        .trust-bar {
            display: flex; gap: 32px; padding-top: 32px;
            border-top: 1px solid var(--border);
        }
        .trust-stat strong {
            font-size: 1.4rem; font-weight: 800; color: var(--text);
            display: flex; align-items: baseline; gap: 3px;
        }
        .trust-stat strong span { font-size: .75rem; color: var(--primary); font-weight: 700; }
        .trust-stat small { font-size: .78rem; color: var(--text-muted); }

        /* ── Right Panel — Form ── */
        .form-panel {
            display: flex; align-items: center; justify-content: center;
            padding: 40px clamp(24px, 4vw, 60px);
            min-height: 100vh;
        }

        .form-card {
            width: 100%; max-width: 560px;
            background: rgba(255,255,255,.82);
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(26,107,181,.1);
            border-radius: 24px; padding: 52px 48px;
            box-shadow: 0 20px 60px rgba(15,23,36,.08), 0 1px 3px rgba(15,23,36,.04);
            opacity: 0; transform: translateY(30px) scale(.97);
            animation: cardIn .7s ease .3s forwards;
        }
        @@keyframes cardIn { to { opacity: 1; transform: translateY(0) scale(1); } }

        .form-header { text-align: center; margin-bottom: 36px; }

        .form-avatar {
            width: 100px; height: 100px; border-radius: 20px; margin: 0 auto 20px;
            background: transparent;
            display: flex; align-items: center; justify-content: center;
        }
        .form-avatar img { width: 100%; height: 100%; object-fit: contain; border-radius: 16px; }

        .form-title {
            font-size: 1.75rem; font-weight: 700; color: var(--text); margin-bottom: 8px;
        }
        .form-subtitle {
            font-size: .95rem; color: var(--text-muted); font-weight: 400;
        }

        /* Inputs */
        .input-group {
            margin-bottom: 26px;
        }
        .input-label {
            display: block; font-size: .9rem; font-weight: 600;
            color: var(--text); margin-bottom: 10px;
        }
        .input-wrap {
            position: relative; display: flex; align-items: center;
        }
        .input-wrap i.input-icon {
            position: absolute; left: 16px;
            font-size: 1rem; color: var(--text-muted);
            pointer-events: none; transition: color .25s;
        }
        .input-wrap input {
            width: 100%; padding: 16px 16px 16px 46px;
            border: 1.5px solid var(--border); border-radius: 12px;
            font-size: 1rem; background: var(--surface);
            transition: border-color .25s, box-shadow .25s;
            color: var(--text);
        }
        .input-wrap input:focus {
            outline: none; border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(46,196,182,.1);
        }
        .input-wrap input:focus ~ i.input-icon,
        .input-wrap input:focus + .pw-toggle ~ i.input-icon { color: var(--primary); }

        .pw-toggle {
            position: absolute; right: 14px; background: none; border: none;
            cursor: pointer; color: var(--text-muted); font-size: .95rem;
            padding: 4px; transition: color .2s;
        }
        .pw-toggle:hover { color: var(--accent); }

        .input-wrap input[type="password"],
        .input-wrap input.pw-field {
            padding-right: 48px;
        }

        /* Validation */
        .validation-summary-errors {
            background: rgba(239,68,68,.06); color: var(--danger);
            padding: 12px 16px; border-radius: 10px; margin-bottom: 20px;
            border: 1px solid rgba(239,68,68,.15); font-size: .88rem;
        }
        .field-validation-error {
            color: var(--danger); font-size: .8rem; margin-top: 6px; display: block;
        }

        /* Submit button */
        .btn-signin {
            width: 100%; padding: 16px; border: none; border-radius: 12px;
            font-size: 1.08rem; font-weight: 700; color: #fff; cursor: pointer;
            background: linear-gradient(135deg, var(--accent), var(--primary));
            box-shadow: 0 8px 24px rgba(26,107,181,.2);
            transition: transform .3s, box-shadow .3s;
            position: relative; overflow: hidden;
            margin-top: 8px; letter-spacing: .3px;
        }
        .btn-signin:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 32px rgba(26,107,181,.3);
        }
        .btn-signin::after {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,.2), transparent);
            transform: translateX(-100%); transition: transform .6s;
        }
        .btn-signin:hover::after { transform: translateX(100%); }

        .btn-signin i { margin-right: 8px; }

        /* Divider */
        .form-divider {
            display: flex; align-items: center; gap: 14px;
            margin: 28px 0; color: var(--text-muted); font-size: .88rem; font-weight: 500;
        }
        .form-divider::before, .form-divider::after {
            content: ''; flex: 1; height: 1px; background: var(--border);
        }

        /* External logins */
        .external-login { display: flex; gap: 12px; flex-wrap: wrap; }
        .external-btn {
            flex: 1; min-width: 120px; padding: 14px;
            border: 1.5px solid var(--border); border-radius: 10px;
            background: var(--surface); color: var(--text);
            font-weight: 500; font-size: .92rem; cursor: pointer;
            display: flex; align-items: center; justify-content: center; gap: 8px;
            transition: border-color .25s, transform .25s, background .25s;
        }
        .external-btn:hover {
            border-color: var(--primary); background: rgba(46,196,182,.04);
            transform: translateY(-2px);
        }

        /* Links */
        .form-links {
            margin-top: 28px; text-align: center;
            display: flex; flex-direction: column; gap: 10px;
        }
        .form-link {
            color: var(--accent); text-decoration: none;
            font-size: .9rem; font-weight: 500;
            transition: color .2s;
        }
        .form-link:hover { color: var(--primary-dark); text-decoration: underline; }

        .back-link {
            display: inline-flex; align-items: center; gap: 6px;
            margin-top: 20px; font-size: .9rem; color: var(--text-muted);
            text-decoration: none; font-weight: 500; transition: color .2s;
        }
        .back-link:hover { color: var(--accent); }

        /* ── Responsive ── */
        @@media (max-width: 1024px) {
            .login-page { grid-template-columns: 1fr; }
            .brand-panel {
                display: none;
            }
            .form-panel { min-height: 100vh; padding: 40px 24px; }
            .form-card { max-width: 560px; }
        }

        @@media (max-width: 576px) {
            .form-panel { padding: 24px 16px; }
            .form-card { padding: 32px 24px; border-radius: 18px; }
            .form-title { font-size: 1.3rem; }
            .input-wrap input { padding: 12px 12px 12px 38px; font-size: 16px; }
            .btn-signin { padding: 13px; font-size: .95rem; }
            .external-login { flex-direction: column; }
            .external-btn { min-width: 100%; }
        }
    </style>
</head>
<body>
    <!-- Background effects -->
    <div class="bg-grid"></div>
    <div class="bg-glow bg-glow--1"></div>
    <div class="bg-glow bg-glow--2"></div>
    <div class="bg-glow bg-glow--3"></div>

    <div class="login-page">
        <!-- Left Panel — Brand / Info -->
        <div class="brand-panel">
        <a href="/" class="brand-logo">
                <img src="/images/logo.png" alt="CEMS logo" class="brand-img" /> CEMS
            </a>

            <h1 class="brand-title">
                Welcome Back to<br><span>Expense Management</span>
            </h1>

            <p class="brand-sub">
                Sign in to submit, track, and approve expense reports in real time.
                Smart budget monitoring keeps your company finances on track.
            </p>

            <div class="feature-list">
                <div class="feature-item">
                    <div class="feature-icon feature-icon--blue"><i class="fas fa-receipt"></i></div>
                    <div class="feature-text">Quick Submissions<small>Submit expenses with receipt uploads in seconds</small></div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon feature-icon--green"><i class="fas fa-sitemap"></i></div>
                    <div class="feature-text">Multi-Level Approvals<small>Manager and CEO approval workflows</small></div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon feature-icon--amber"><i class="fas fa-chart-line"></i></div>
                    <div class="feature-text">Real-Time Analytics<small>Live dashboards with budget monitoring</small></div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon feature-icon--rose"><i class="fas fa-money-bill-transfer"></i></div>
                    <div class="feature-text">Fast Reimbursements<small>End-to-end payment tracking</small></div>
                </div>
            </div>

            <div class="trust-bar">
                <div class="trust-stat">
                    <strong>98<span>%</span></strong>
                    <small>Faster Approvals</small>
                </div>
                <div class="trust-stat">
                    <strong>₱2.4<span>M+</span></strong>
                    <small>Tracked</small>
                </div>
                <div class="trust-stat">
                    <strong>5<span>Roles</span></strong>
                    <small>Access Levels</small>
                </div>
            </div>
        </div>

        <!-- Right Panel — Login Form -->
        <div class="form-panel">
            <div class="form-card">
                <div class="form-header">
                    <div class="form-avatar">
                        <img src="/images/logo.png" alt="CEMS logo" />
                    </div>
                    <h2 class="form-title">Sign in to CEMS</h2>
                    <p class="form-subtitle">Enter your credentials to continue</p>
                </div>

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>

                    <div class="input-group">
                        <label class="input-label" for="Input_Email">Email Address</label>
                        <div class="input-wrap">
                            <input asp-for="Input.Email" autocomplete="username"
                                   aria-required="true" placeholder="name&#64;example.com" />
                            <i class="fas fa-envelope input-icon"></i>
                        </div>
                        <span asp-validation-for="Input.Email" class="field-validation-error"></span>
                    </div>

                    <div class="input-group">
                        <label class="input-label" for="Input_Password">Password</label>
                        <div class="input-wrap">
                            <input asp-for="Input.Password" class="pw-field" autocomplete="current-password"
                                   aria-required="true" placeholder="••••••••" />
                            <button type="button" class="pw-toggle" aria-label="Toggle password visibility">
                                <i class="fas fa-eye"></i>
                            </button>
                            <i class="fas fa-lock input-icon"></i>
                        </div>
                        <span asp-validation-for="Input.Password" class="field-validation-error"></span>
                    </div>

                    <button id="login-submit" type="submit" class="btn-signin">
                         Sign In
                    </button>

                    @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                    {
                        <div class="form-divider">or continue with</div>

                        <div class="external-login">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" class="external-btn" name="provider"
                                        value="@provider.Name" form="external-account"
                                        title="Log in using your @provider.DisplayName account">
                                    <i class="fab fa-@provider.Name.ToLower()"></i>
                                    <span>@provider.DisplayName</span>
                                </button>
                            }
                        </div>
                    }

                    @* <div class="form-links">
                        <a id="forgot-password" asp-page="./ForgotPassword" class="form-link">Forgot your password?</a>
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="form-link">Resend email confirmation</a>
                    </div> *@
                </form>

                @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                {
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" style="display: none;">
                    </form>
                }

                @* <div style="text-align: center;">
                    <a href="/" class="back-link"><i class="fas fa-arrow-left"></i> Back to Home</a>
                </div> *@
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Password visibility toggle
            document.querySelectorAll('.pw-toggle').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var input = this.closest('.input-wrap').querySelector('input');
                    var icon = this.querySelector('i');
                    if (input.type === 'password') {
                        input.type = 'text';
                        icon.classList.replace('fa-eye', 'fa-eye-slash');
                    } else {
                        input.type = 'password';
                        icon.classList.replace('fa-eye-slash', 'fa-eye');
                    }
                });
            });

            // Floating label effect — move icon color on filled inputs
            document.querySelectorAll('.input-wrap input').forEach(function (input) {
                input.addEventListener('input', function () {
                    var icon = this.closest('.input-wrap').querySelector('.input-icon');
                    if (icon) {
                        icon.style.color = this.value ? 'var(--primary)' : '';
                    }
                });
            });
        });
    </script>
</body>
</html>