@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    var isSuccess = Model.StatusMessage.StartsWith("✅") || Model.StatusMessage.StartsWith("Your password");
    var alertBg      = isSuccess ? "#f0fdf4" : "#fef2f2";
    var alertBorder  = isSuccess ? "#86efac" : "#fca5a5";
    var iconClass    = isSuccess ? "bi-check-circle-fill" : "bi-exclamation-circle-fill";
    var iconColor    = isSuccess ? "#16a34a" : "#dc2626";
    var textColor    = isSuccess ? "#166534" : "#991b1b";
    <div style="background:@alertBg;border:1px solid @alertBorder;border-radius:10px;padding:14px 18px;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
        <i class="bi @iconClass" style="color:@iconColor;font-size:1.1rem;flex-shrink:0;"></i>
        <span style="font-size:0.9rem;color:@textColor;font-weight:500;">@Model.StatusMessage</span>
    </div>
}

@if (Model.Requires2faSetup)
{
    <!-- 2FA not set up — block the form -->
    <div style="background:#fff7ed;border:1px solid #fed7aa;border-radius:14px;padding:28px 32px;text-align:center;">
        <div style="width:64px;height:64px;border-radius:50%;background:#fef3c7;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
            <i class="bi bi-shield-exclamation" style="font-size:1.8rem;color:#d97706;"></i>
        </div>
        <h5 style="font-weight:700;color:#92400e;margin-bottom:8px;">Google Authenticator Required</h5>
        <p style="color:#b45309;font-size:0.9rem;line-height:1.7;max-width:420px;margin:0 auto 24px;">
            To protect your account, you must set up <strong>Google Authenticator (2FA)</strong>
            before you can change your password. This ensures only you can make this change.
        </p>
        <a asp-page="./TwoFactorAuthentication"
           style="display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,#1a6bb5,#2ec4b6);color:white;text-decoration:none;border-radius:8px;padding:11px 24px;font-weight:600;font-size:0.9rem;">
            <i class="bi bi-shield-lock-fill"></i> Set Up Google Authenticator
        </a>
    </div>
}
else
{
    <!-- Change password form -->
    <div style="background:white;border:1px solid #e9eef6;border-radius:12px;padding:28px 32px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
            <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#1a6bb5,#2ec4b6);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-key-fill" style="color:white;font-size:1rem;"></i>
            </div>
            <div>
                <h5 style="font-weight:700;color:#1e293b;margin:0;font-size:1rem;">Change Password</h5>
                <p style="color:#64748b;font-size:0.8rem;margin:0;">Verified with your Google Authenticator code</p>
            </div>
        </div>

        <form method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small" role="alert"></div>

            <!-- Current Password -->
            <div style="margin-bottom:14px;">
                <label style="font-size:0.78rem;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:0.4px;display:block;margin-bottom:6px;">
                    Current Password
                </label>
                <div style="position:relative;">
                    <input asp-for="Input.OldPassword" type="password" class="form-control"
                           autocomplete="current-password" placeholder="Your current password"
                           style="padding:10px 40px 10px 14px;border-color:#e2e8f0;border-radius:8px;" />
                    <i class="bi bi-lock" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);color:#94a3b8;pointer-events:none;"></i>
                </div>
                <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
            </div>

            <!-- New Password -->
            <div style="margin-bottom:14px;">
                <label style="font-size:0.78rem;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:0.4px;display:block;margin-bottom:6px;">
                    New Password
                </label>
                <div style="position:relative;">
                    <input asp-for="Input.NewPassword" type="password" class="form-control" id="newPasswordInput"
                           autocomplete="new-password" placeholder="Min 6 chars, 1 number, 1 special char"
                           style="padding:10px 40px 10px 14px;border-color:#e2e8f0;border-radius:8px;" />
                    <i class="bi bi-shield-lock" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);color:#94a3b8;pointer-events:none;"></i>
                </div>
                <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>

                <!-- Password strength indicator -->
                <div id="pwStrengthBar" style="display:none;margin-top:8px;">
                    <div style="height:5px;border-radius:4px;background:#e2e8f0;overflow:hidden;">
                        <div id="pwStrengthFill" style="height:100%;width:0%;border-radius:4px;transition:width .3s,background .3s;"></div>
                    </div>
                    <div id="pwStrengthLabel" style="margin-top:6px;font-size:0.78rem;font-weight:600;"></div>
                    <ul style="margin:6px 0 0 0;padding-left:18px;font-size:0.78rem;" id="pwRulesList">
                        <li id="rule-length" style="color:#94a3b8;">At least 6 characters</li>
                        <li id="rule-number" style="color:#94a3b8;">At least 1 number (0-9)</li>
                        <li id="rule-special" style="color:#94a3b8;">At least 1 special character (e.g. @@, !, #, $)</li>
                    </ul>
                </div>
            </div>

            <!-- Confirm Password -->
            <div style="margin-bottom:20px;">
                <label style="font-size:0.78rem;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:0.4px;display:block;margin-bottom:6px;">
                    Confirm New Password
                </label>
                <div style="position:relative;">
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control"
                           autocomplete="new-password" placeholder="Repeat new password"
                           style="padding:10px 40px 10px 14px;border-color:#e2e8f0;border-radius:8px;" />
                    <i class="bi bi-shield-check" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);color:#94a3b8;pointer-events:none;"></i>
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </div>

            <!-- Divider -->
            <hr style="border:none;border-top:1px solid #f1f5f9;margin:20px 0;" />

            <!-- Authenticator Code -->
            <div style="margin-bottom:24px;">
                <label style="font-size:0.78rem;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:0.4px;display:block;margin-bottom:6px;">
                    Google Authenticator Code
                </label>
                <div style="display:flex;align-items:center;gap:10px;background:#f0f9ff;border:1px solid #bae6fd;border-radius:8px;padding:10px 14px;margin-bottom:10px;">
                    <i class="bi bi-phone-fill" style="color:#0284c7;font-size:1rem;flex-shrink:0;"></i>
                    <span style="font-size:0.82rem;color:#0c4a6e;">
                        Open your authenticator app and enter the 6-digit code shown for <strong>CEMS</strong>.
                    </span>
                </div>
                <input asp-for="Input.TwoFactorCode"
                       class="form-control"
                       autocomplete="one-time-code"
                       inputmode="numeric"
                       maxlength="6"
                       placeholder="000000"
                       style="font-size:1.8rem;font-weight:700;letter-spacing:12px;text-align:center;padding:12px 20px;border-color:#e2e8f0;border-radius:8px;max-width:200px;" />
                <span asp-validation-for="Input.TwoFactorCode" class="text-danger small d-block mt-1"></span>
            </div>

            <button type="submit"
                    style="background:linear-gradient(135deg,#1a6bb5 0%,#2ec4b6 100%);color:white;border:none;border-radius:8px;padding:11px 28px;font-weight:600;font-size:0.9rem;cursor:pointer;display:inline-flex;align-items:center;gap:8px;">
                <i class="bi bi-check-circle"></i> Change Password
            </button>
        </form>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            // Digits only for authenticator code
            var tfInput = document.getElementById('Input_TwoFactorCode');
            if (tfInput) {
                tfInput.addEventListener('input', function () {
                    this.value = this.value.replace(/\D/g, '').slice(0, 6);
                });
            }

            // Live password strength checker
            var pwInput     = document.getElementById('newPasswordInput');
            var bar         = document.getElementById('pwStrengthBar');
            var fill        = document.getElementById('pwStrengthFill');
            var lbl         = document.getElementById('pwStrengthLabel');
            var ruleLength  = document.getElementById('rule-length');
            var ruleNumber  = document.getElementById('rule-number');
            var ruleSpecial = document.getElementById('rule-special');

            if (!pwInput) return;

            pwInput.addEventListener('input', function () {
                var val = this.value;
                bar.style.display = val.length > 0 ? 'block' : 'none';

                var hasLength  = val.length >= 6;
                var hasNumber  = /[0-9]/.test(val);
                var hasSpecial = /[^a-zA-Z0-9\s]/.test(val);

                ruleLength.style.color  = hasLength  ? '#16a34a' : '#dc2626';
                ruleNumber.style.color  = hasNumber  ? '#16a34a' : '#dc2626';
                ruleSpecial.style.color = hasSpecial ? '#16a34a' : '#dc2626';

                var score = (hasLength ? 1 : 0) + (hasNumber ? 1 : 0) + (hasSpecial ? 1 : 0);

                var pct   = ['33%',     '66%',     '100%'   ][score - 1] || '0%';
                var bg    = ['#ef4444', '#f59e0b', '#22c55e'][score - 1] || '#e2e8f0';
                var txt   = ['Weak',    'Fair',    'Strong' ][score - 1] || '';
                var clr   = ['#ef4444', '#d97706', '#16a34a'][score - 1] || '';

                fill.style.width      = score > 0 ? pct : '0%';
                fill.style.background = bg;
                lbl.textContent       = txt;
                lbl.style.color       = clr;
            });
        })();
    </script>
}
