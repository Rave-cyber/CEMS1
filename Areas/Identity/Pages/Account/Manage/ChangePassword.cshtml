@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h3 class="fw-bold mb-4">@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="card border-0 bg-light rounded-4 p-4 mb-4 shadow-sm">
    <p class="text-muted mb-4">Update your password to keep your account secure.</p>
    
    <div class="row">
        <div class="col-md-8">
            <form id="change-password-form" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Old password" />
                    <label asp-for="Input.OldPassword" class="form-label">Current Password</label>
                    <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
                </div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="New password" />
                    <label asp-for="Input.NewPassword" class="form-label">New Password</label>
                    <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                </div>
                
                <div class="form-floating mb-4">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Confirm new password"/>
                    <label asp-for="Input.ConfirmPassword" class="form-label">Confirm New Password</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>
                
                @if (Model.Require2fa)
                {
                    <div class="p-3 bg-white border border-primary border-opacity-25 rounded-3 mb-4 shadow-sm">
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-shield-lock-fill text-primary me-2 fs-5"></i>
                            <strong class="text-dark">Two-Factor Authentication Required</strong>
                        </div>
                        <p class="text-muted small mb-3">Please enter a code from your authenticator app to authorize this password change.</p>
                        
                        <div class="form-floating">
                            <input asp-for="Input.TwoFactorCode" class="form-control border-primary" autocomplete="off" placeholder="Authenticator code" />
                            <label asp-for="Input.TwoFactorCode" class="form-label text-primary">6-Digit Code</label>
                            <span asp-validation-for="Input.TwoFactorCode" class="text-danger small"></span>
                        </div>
                    </div>
                }

                <button type="submit" class="btn btn-primary px-4 py-2 fw-bold" style="background: linear-gradient(135deg, #1a6bb5 0%, #2ec4b6 100%); border: none;">
                    <i class="bi bi-key me-1"></i> Update Password
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
