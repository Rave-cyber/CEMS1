@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = "Configure Authenticator App";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<h3 class="fw-bold mb-4">@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="mb-4">
    <p class="text-muted">Enhance your account security by enabling Two-Factor Authentication (2FA) with an authenticator app.</p>
</div>

<div class="card border-0 bg-light rounded-4 p-4 mb-4 shadow-sm">
    <h5 class="fw-bold text-primary mb-3"><i class="bi bi-1-circle me-2"></i>Step 1: Get an Authenticator App</h5>
    <p class="mb-0 text-muted">Download a two-factor authenticator app on your mobile device:</p>
    <div class="mt-3 d-flex gap-2">
        <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2&amp;hl=en" target="_blank" class="btn btn-outline-secondary btn-sm rounded-pill"><i class="bi bi-google-play me-1"></i> Google Authenticator</a>
        <a href="https://go.microsoft.com/fwlink/?Linkid=825072" target="_blank" class="btn btn-outline-secondary btn-sm rounded-pill"><i class="bi bi-microsoft me-1"></i> Microsoft Authenticator</a>
    </div>
</div>

<div class="card border-0 bg-light rounded-4 p-4 mb-4 shadow-sm">
    <h5 class="fw-bold text-primary mb-3"><i class="bi bi-2-circle me-2"></i>Step 2: Scan the QR Code</h5>
    <p class="text-muted">Scan this QR code with your authenticator app. If you cannot scan it, manually enter this setup key:</p>
    <div class="bg-white p-3 rounded-3 text-center d-inline-block border mb-3">
        <code class="fs-5 fw-bold text-dark user-select-all">@Model.SharedKey</code>
    </div>
    <div class="d-flex justify-content-center bg-white p-4 rounded-4 border mx-auto" style="max-width: fit-content;">
        <div id="qrCode"></div>
        <div id="qrCodeData" data-url="@Model.AuthenticatorUri"></div>
    </div>
</div>

<div class="card border-0 bg-light rounded-4 p-4 shadow-sm">
    <h5 class="fw-bold text-primary mb-3"><i class="bi bi-3-circle me-2"></i>Step 3: Verify Setup</h5>
    <p class="text-muted">Enter the 6-digit verification code generated by your app to complete setup.</p>
    
    <div class="row">
        <div class="col-md-8">
            <form id="send-code" method="post">
                <div class="form-floating mb-3">
                    <input asp-for="Input.Code" class="form-control" autocomplete="off" placeholder="123456" />
                    <label asp-for="Input.Code">6-digit Verification Code</label>
                    <span asp-validation-for="Input.Code" class="text-danger small"></span>
                </div>
                <button type="submit" class="btn btn-primary px-4 py-2 fw-bold" style="background: linear-gradient(135deg, #1a6bb5 0%, #2ec4b6 100%); border: none;">
                    <i class="bi bi-check-circle me-1"></i> Verify & Enable 2FA
                </button>
                <div asp-validation-summary="ModelOnly" class="text-danger mt-2 text-sm" role="alert"></div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script type="text/javascript">
        new QRCode(document.getElementById("qrCode"), {
            text: "@Html.Raw(Model.AuthenticatorUri)",
            width: 220,
            height: 220,
            colorDark: "#0f1724",
            colorLight: "#ffffff"
        });
    </script>
}
