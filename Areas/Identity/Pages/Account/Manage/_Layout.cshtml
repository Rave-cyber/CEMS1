@{
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Back to App Button -->
            <div class="mb-3">
                <a href="/" class="btn btn-sm btn-outline-secondary rounded-pill px-3 shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
                </a>
            </div>
            
            <div class="card shadow border-0" style="border-radius: 16px; overflow: hidden; box-shadow: 0 20px 60px rgba(15,23,36,0.08) !important;">
                <div class="card-header text-white p-4" style="background: linear-gradient(135deg, #1a6bb5 0%, #2ec4b6 100%); border: none;">
                    <h2 class="h4 mb-0 fw-bold"><i class="bi bi-shield-check me-2"></i>Security Settings</h2>
                    <p class="mb-0 small mt-1" style="color: rgba(255,255,255,0.85);">Manage your password and two-factor authentication.</p>
                </div>
                <div class="card-body p-0">
                    <div class="row g-0">
                        <div class="col-md-3 col-lg-3 border-end" style="background: #fafbfc; min-height: 400px;">
                            <div class="p-3">
                                <partial name="_ManageNav" />
                            </div>
                        </div>
                        <div class="col-md-9 col-lg-9 p-4 p-md-5 bg-white">
                            @RenderBody()
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
