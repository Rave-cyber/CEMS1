@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password — CEMS</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            font-family:'Segoe UI',system-ui,sans-serif;
            background:#f0f7fa; min-height:100vh;
            display:flex; align-items:center; justify-content:center;
        }
        .card {
            background:white; border-radius:20px; padding:44px 40px;
            box-shadow:0 20px 60px rgba(15,23,36,.1);
            width:100%; max-width:440px;
        }
        .logo { text-align:center; margin-bottom:28px; }
        .logo img { width:64px; height:64px; object-fit:contain; border-radius:12px; }
        h2 { font-size:1.4rem; font-weight:700; color:#1e293b; text-align:center; margin-bottom:6px; }
        .sub { font-size:.88rem; color:#64748b; text-align:center; margin-bottom:28px; line-height:1.5; }

        .step-bar { display:flex; align-items:center; justify-content:center; gap:0; margin-bottom:32px; }
        .step-dot {
            width:32px; height:32px; border-radius:50%; border:2px solid #e2e8f0;
            display:flex; align-items:center; justify-content:center;
            font-size:.78rem; font-weight:700; color:#94a3b8; background:white;
            transition:.3s;
        }
        .step-dot.active  { border-color:#1a6bb5; color:#1a6bb5; background:#eff6ff; }
        .step-dot.done    { border-color:#22c55e; color:white; background:#22c55e; }
        .step-line { flex:1; height:2px; background:#e2e8f0; max-width:48px; }
        .step-line.done   { background:#22c55e; }

        label { display:block; font-size:.82rem; font-weight:600; color:#374151; margin-bottom:6px; }
        input[type=email], input[type=text], input[type=password] {
            width:100%; padding:12px 14px; border:1.5px solid #e2e8f0; border-radius:10px;
            font-size:.95rem; color:#1e293b; transition:.2s;
        }
        input:focus { outline:none; border-color:#1a6bb5; box-shadow:0 0 0 3px rgba(26,107,181,.1); }
        .field { margin-bottom:18px; }
        .err { color:#ef4444; font-size:.8rem; margin-top:4px; display:block; }

        .otp-wrap { display:flex; gap:10px; justify-content:center; margin-bottom:18px; }
        .otp-wrap input {
            width:48px; height:56px; text-align:center; font-size:1.4rem; font-weight:700;
            border:1.5px solid #e2e8f0; border-radius:10px; padding:0;
        }
        .otp-wrap input:focus { border-color:#1a6bb5; box-shadow:0 0 0 3px rgba(26,107,181,.1); }

        .btn {
            width:100%; padding:13px; border:none; border-radius:10px;
            font-size:.95rem; font-weight:700; cursor:pointer; color:white;
            background:linear-gradient(135deg,#1a6bb5,#2ec4b6);
            transition:.2s; margin-top:4px;
        }
        .btn:hover { opacity:.9; transform:translateY(-1px); }

        .alert-err {
            background:#fef2f2; border:1px solid #fca5a5; border-radius:8px;
            padding:10px 14px; color:#991b1b; font-size:.85rem; margin-bottom:18px;
        }
        .back-link {
            display:block; text-align:center; margin-top:20px;
            font-size:.85rem; color:#64748b; text-decoration:none;
        }
        .back-link:hover { color:#1a6bb5; }

        .pw-wrap { position:relative; }
        .pw-wrap input { padding-right:42px; }
        .pw-toggle {
            position:absolute; right:12px; top:50%; transform:translateY(-50%);
            background:none; border:none; cursor:pointer; color:#94a3b8; font-size:.9rem;
        }

        .strength-bar { height:4px; border-radius:4px; background:#e2e8f0; margin-top:8px; overflow:hidden; }
        .strength-fill { height:100%; border-radius:4px; transition:width .3s,background .3s; width:0; }
        .strength-label { font-size:.75rem; font-weight:600; margin-top:4px; }
        .rules { list-style:none; padding:0; margin:8px 0 0; font-size:.78rem; }
        .rules li { color:#94a3b8; margin-bottom:2px; }
        .rules li.ok { color:#16a34a; }
        .rules li.bad { color:#dc2626; }
    </style>
</head>
<body>
<div class="card">
    <div class="logo">
        <img src="/images/logo.png" alt="CEMS" />
    </div>

    @* Step indicator *@
    @{
        var step = Model.Step ?? "email";
        bool s1done = step == "otp" || step == "password";
        bool s2done = step == "password";
    }
    <div class="step-bar">
        <div class="step-dot @(s1done ? "done" : step == "email" ? "active" : "")">
            @if (s1done) { <i class="fas fa-check"></i> } else { <span>1</span> }
        </div>
        <div class="step-line @(s1done ? "done" : "")"></div>
        <div class="step-dot @(s2done ? "done" : step == "otp" ? "active" : "")">
            @if (s2done) { <i class="fas fa-check"></i> } else { <span>2</span> }
        </div>
        <div class="step-line @(s2done ? "done" : "")"></div>
        <div class="step-dot @(step == "password" ? "active" : "")"><span>3</span></div>
    </div>

    @* Global errors *@
    @if (!ViewData.ModelState.IsValid)
    {
        foreach (var err in ViewData.ModelState[""]?.Errors ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.ModelBinding.ModelError>())
        {
            <div class="alert-err"><i class="fas fa-exclamation-circle"></i> @err.ErrorMessage</div>
        }
    }

    @* ── STEP 1: Enter account email ── *@
    @if (step == "email")
    {
        <h2>Forgot Password</h2>
        <p class="sub">Enter your CEMS account email. We'll send an OTP to your linked Gmail.</p>

        <form method="post" asp-page-handler="SendOtp">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Step" value="email" />

            <div class="field">
                <label>Account Email</label>
                <input asp-for="AccountEmail" type="email" placeholder="yourname@expense.com" autocomplete="email" />
                <span asp-validation-for="AccountEmail" class="err"></span>
            </div>

            <button type="submit" class="btn"><i class="fas fa-paper-plane"></i> Send OTP</button>
        </form>
    }

    @* ── STEP 2: Enter OTP ── *@
    @if (step == "otp")
    {
        <h2>Enter OTP</h2>
        <p class="sub">
            A 6-digit OTP was sent to <strong>@(Model.MaskedGmail ?? "your linked Gmail")</strong>.
            It expires in 10 minutes.
        </p>

        <form method="post" asp-page-handler="VerifyOtp" id="otpForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Step" value="otp" />

            <div class="otp-wrap">
                @for (int i = 0; i < 6; i++)
                {
                    <input type="text" inputmode="numeric" maxlength="1" class="otp-digit"
                           autocomplete="one-time-code" />
                }
            </div>
            <input type="hidden" asp-for="Otp" id="otpHidden" />
            <span asp-validation-for="Otp" class="err" style="text-align:center;display:block;margin-bottom:12px;"></span>

            <button type="submit" class="btn"><i class="fas fa-shield-alt"></i> Verify OTP</button>
        </form>
    }

    @* ── STEP 3: New password ── *@
    @if (step == "password")
    {
        <h2>Set New Password</h2>
        <p class="sub">OTP verified. Choose a strong new password.</p>

        <form method="post" asp-page-handler="ResetPassword">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Step" value="password" />

            <div class="field">
                <label>New Password</label>
                <div class="pw-wrap">
                    <input asp-for="NewPassword" type="password" id="newPw"
                           placeholder="Min 6 chars, 1 number, 1 special" autocomplete="new-password" />
                    <button type="button" class="pw-toggle" onclick="togglePw('newPw',this)">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
                <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                <div class="strength-label" id="strengthLabel"></div>
                <ul class="rules" id="pwRules">
                    <li id="r-len">At least 6 characters</li>
                    <li id="r-num">At least 1 number</li>
                    <li id="r-spc">At least 1 special character</li>
                </ul>
                <span asp-validation-for="NewPassword" class="err"></span>
            </div>

            <div class="field">
                <label>Confirm Password</label>
                <div class="pw-wrap">
                    <input asp-for="ConfirmPassword" type="password" id="confPw"
                           placeholder="Repeat new password" autocomplete="new-password" />
                    <button type="button" class="pw-toggle" onclick="togglePw('confPw',this)">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="err"></span>
            </div>

            <button type="submit" class="btn"><i class="fas fa-lock"></i> Reset Password</button>
        </form>
    }

    <a href="/Identity/Account/Login" class="back-link">
        <i class="fas fa-arrow-left"></i> Back to Login
    </a>
</div>

<script>
    // OTP digit boxes — auto-advance and collect into hidden field
    (function () {
        var digits = document.querySelectorAll('.otp-digit');
        var hidden = document.getElementById('otpHidden');
        if (!digits.length) return;

        digits.forEach(function (d, i) {
            d.addEventListener('input', function () {
                this.value = this.value.replace(/\D/g, '').slice(-1);
                if (this.value && i < digits.length - 1) digits[i + 1].focus();
                syncOtp();
            });
            d.addEventListener('keydown', function (e) {
                if (e.key === 'Backspace' && !this.value && i > 0) digits[i - 1].focus();
            });
            d.addEventListener('paste', function (e) {
                e.preventDefault();
                var text = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '');
                for (var j = 0; j < digits.length && j < text.length; j++) {
                    digits[j].value = text[j];
                }
                syncOtp();
                if (text.length >= digits.length) digits[digits.length - 1].focus();
            });
        });

        function syncOtp() {
            if (hidden) hidden.value = Array.from(digits).map(function (d) { return d.value; }).join('');
        }

        document.getElementById('otpForm')?.addEventListener('submit', function () { syncOtp(); });
    })();

    // Password toggle
    function togglePw(id, btn) {
        var inp = document.getElementById(id);
        var icon = btn.querySelector('i');
        if (inp.type === 'password') {
            inp.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            inp.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }

    // Password strength
    (function () {
        var pw = document.getElementById('newPw');
        if (!pw) return;
        pw.addEventListener('input', function () {
            var v = this.value;
            var hasLen = v.length >= 6;
            var hasNum = /[0-9]/.test(v);
            var hasSpc = /[^a-zA-Z0-9\s]/.test(v);

            document.getElementById('r-len').className = hasLen ? 'ok' : 'bad';
            document.getElementById('r-num').className = hasNum ? 'ok' : 'bad';
            document.getElementById('r-spc').className = hasSpc ? 'ok' : 'bad';

            var score = (hasLen ? 1 : 0) + (hasNum ? 1 : 0) + (hasSpc ? 1 : 0);
            var pct   = ['33%', '66%', '100%'][score - 1] || '0%';
            var bg    = ['#ef4444', '#f59e0b', '#22c55e'][score - 1] || '#e2e8f0';
            var txt   = ['Weak', 'Fair', 'Strong'][score - 1] || '';
            var clr   = ['#ef4444', '#d97706', '#16a34a'][score - 1] || '';

            document.getElementById('strengthFill').style.width      = score > 0 ? pct : '0%';
            document.getElementById('strengthFill').style.background = bg;
            document.getElementById('strengthLabel').textContent      = txt;
            document.getElementById('strengthLabel').style.color      = clr;
        });
    })();
</script>
</body>
</html>
